<div class="col">
    <div class="card xm-summary-card h-100 border-0" style="@AccentStyle">
        <div class="card-body">
            <div class="xm-summary-label">@Title</div>
            @if (Error is not null)
            {
                <div class="text-danger small mt-2">@Error</div>
            }
            else
            {
                <div class="xm-summary-value mt-1">@(Value ?? "—")</div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Value { get; set; }
    [Parameter] public string? Error { get; set; }
    /// <summary>Optional accent token: sky, emerald, amber, violet, slate, rose, cyan.</summary>
    [Parameter] public string? Accent { get; set; }

    private string? AccentStyle => Accent switch
    {
        "emerald" => "--xm-summary-accent: #10b981;",
        "amber" => "--xm-summary-accent: #f59e0b;",
        "violet" => "--xm-summary-accent: #8b5cf6;",
        "slate" => "--xm-summary-accent: #64748b;",
        "rose" => "--xm-summary-accent: #f43f5e;",
        "cyan" => "--xm-summary-accent: #06b6d4;",
        "sky" or null or "" => "--xm-summary-accent: #0ea5e9;",
        _ => "--xm-summary-accent: #0ea5e9;",
    };
}
