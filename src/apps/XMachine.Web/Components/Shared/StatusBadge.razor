<span class="@($"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium {ToneTw}")">@Text</span>

@code {
    /// <summary>
    /// Badge label shown to the user.
    /// </summary>
    [Parameter, EditorRequired] public string Text { get; set; } = "";

    /// <summary>
    /// Visual tone mapped to Tailwind background and text colors.
    /// </summary>
    [Parameter] public StatusBadgeTone Tone { get; set; } = StatusBadgeTone.Neutral;

    /// <summary>
    /// Tailwind utility classes for the selected <see cref="Tone"/>.
    /// </summary>
    private string ToneTw => Tone switch
    {
        StatusBadgeTone.Success => "bg-green-100 text-green-700",
        StatusBadgeTone.Warning => "bg-amber-100 text-amber-700",
        StatusBadgeTone.Danger => "bg-red-100 text-red-700",
        StatusBadgeTone.Info => "bg-blue-100 text-blue-700",
        _ => "bg-slate-100 text-slate-600",
    };
}
