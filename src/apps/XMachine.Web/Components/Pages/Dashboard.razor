    private static int GetProgressPercentage(int completed, int target) =>
        target == 0 ? 0 : Math.Min(100, (int)Math.Round(100.0 * completed / target));

    private static string Capitalize(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];

    private static string? Fmt(int? v) => v?.ToString();

    /// <summary>
    /// Renders a dashboard metric card with optional warning styling when <paramref name="warn"/> is true and value is greater than zero.
    /// </summary>
    private RenderFragment MetricCard(string label, int? value, string iconSvg, bool warn = false) => __builder =>
    {
        var amber = warn && (value ?? 0) > 0;
        var valueClass = amber
            ? "text-3xl font-bold tabular-nums text-amber-600"
            : "text-3xl font-bold tabular-nums text-slate-900";

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <div class="mb-3 flex items-center justify-between gap-2">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">@label</span>
                <span class="inline-flex h-4 w-4 shrink-0 text-slate-400 [&>svg]:block">@((MarkupString)iconSvg)</span>
            </div>
            <div class="@valueClass">@(Fmt(value) ?? "—")</div>
        </div>
    };

