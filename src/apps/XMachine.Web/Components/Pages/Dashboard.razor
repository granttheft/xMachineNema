    private ApiFetch<MesSummaryDto> _mes = ApiFetch<MesSummaryDto>.InProgress();
    private ApiFetch<QualitySummaryDto> _quality = ApiFetch<QualitySummaryDto>.InProgress();
    private ApiFetch<EventingSummaryDto> _eventing = ApiFetch<EventingSummaryDto>.InProgress();
    private ApiFetch<IntegrationHealthSummaryDto> _integration = ApiFetch<IntegrationHealthSummaryDto>.InProgress();
    private ApiFetch<WorkflowSummaryDto> _workflow = ApiFetch<WorkflowSummaryDto>.InProgress();
    private string? _aggregateError;

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _clockTimer = new System.Threading.Timer(_ => _ = InvokeAsync(() =>
            {
                _currentTime = DateTime.Now;
                StateHasChanged();
            }), null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
        }

        if (!firstRender)
            return;

        _lastUpdate = DateTime.Now;
        var tMes = Api.GetMesSummaryAsync();
        var tQuality = Api.GetQualitySummaryAsync();
        var tEventing = Api.GetEventingSummaryAsync();
        var tInt = Api.GetIntegrationHealthAsync();
        var tWf = Api.GetWorkflowSummaryAsync();
        await Task.WhenAll(tMes, tQuality, tEventing, tInt, tWf);
        _mes = await tMes;
        _quality = await tQuality;
        _eventing = await tEventing;
        _integration = await tInt;
        _workflow = await tWf;

        if (_mes.Error is not null && _quality.Error is not null && _eventing.Error is not null && _integration.Error is not null && _workflow.Error is not null)
            _aggregateError = "Could not reach the API. Check XMachine:Api:BaseUrl and that XMachine.Api is running.";
        else
            _aggregateError = null;

        StateHasChanged();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _clockTimer?.Dispose();
        _clockTimer = null;
    }

    private void DismissAlert(int id)
    {
        _alerts.RemoveAll(a => a.Id == id);
    }

