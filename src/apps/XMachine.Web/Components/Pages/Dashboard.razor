@page "/dashboard"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Dashboard · xMachine</PageTitle>

<div class="space-y-10">
    <!-- Page header -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">Operations Dashboard</h1>
            <p class="mt-1 text-sm text-slate-500">
                Cross-module snapshot from XMachine.Api. Ensure the API is running and
                <code class="rounded bg-slate-100 px-1 py-0.5 text-xs text-slate-700">XMachine:Api:BaseUrl</code>
                points to your instance.
            </p>
        </div>
        <div class="shrink-0 text-xs font-medium tabular-nums text-slate-400 sm:text-right">
            @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC
        </div>
    </div>

    @if (_aggregateError is not null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm" role="alert">
            @_aggregateError
        </div>
    }

    <!-- MES -->
    <section class="space-y-4">
        <div>
            <h2 class="text-base font-semibold uppercase tracking-wide text-slate-700">MES</h2>
            <p class="text-sm text-slate-500">Orders, recipes, lots, and shift calendar.</p>
        </div>
        @if (_mes.Loading)
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="h-28 animate-pulse rounded-xl border border-slate-200 bg-slate-100 shadow-sm" />
                }
            </div>
        }
        else if (_mes.Error is not null)
        {
            <p class="text-sm text-red-600">@_mes.Error</p>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @MetricCard("Production orders", _mes.Data?.Orders, ClipboardSvg)
                @MetricCard("Recipes", _mes.Data?.Recipes, BookSvg)
                @MetricCard("Lots", _mes.Data?.Lots, LayersSvg)
                @MetricCard("Shifts", _mes.Data?.Shifts, ClockSvg)
            </div>
        }
    </section>

    <!-- Quality -->
    <section class="space-y-4">
        <div>
            <h2 class="text-base font-semibold uppercase tracking-wide text-slate-700">Quality</h2>
            <p class="text-sm text-slate-500">Checks, measurements, nonconformances, and dispositions.</p>
        </div>
        @if (_quality.Loading)
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="h-28 animate-pulse rounded-xl border border-slate-200 bg-slate-100 shadow-sm" />
                }
            </div>
        }
        else if (_quality.Error is not null)
        {
            <p class="text-sm text-red-600">@_quality.Error</p>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @MetricCard("Checks", _quality.Data?.Checks, CheckSvg)
                @MetricCard("Measurements", _quality.Data?.Measurements, RulerSvg)
                @MetricCard("Nonconformances", _quality.Data?.Nonconformances, AlertSvg)
                @MetricCard("Dispositions", _quality.Data?.Dispositions, FlagSvg)
            </div>
        }
    </section>

    <!-- Eventing -->
    <section class="space-y-4">
        <div>
            <h2 class="text-base font-semibold uppercase tracking-wide text-slate-700">Eventing</h2>
            <p class="text-sm text-slate-500">Alarms, line stops, OEE slices, and KPI materialization.</p>
        </div>
        @if (_eventing.Loading)
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="h-28 animate-pulse rounded-xl border border-slate-200 bg-slate-100 shadow-sm" />
                }
            </div>
        }
        else if (_eventing.Error is not null)
        {
            <p class="text-sm text-red-600">@_eventing.Error</p>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @MetricCard("Alarms", _eventing.Data?.Alarms, BellSvg, warn: true)
                @MetricCard("Downtimes", _eventing.Data?.Downtimes, PauseSvg)
                @MetricCard("OEE snapshots", _eventing.Data?.Oee, ActivitySvg)
                @MetricCard("KPI results", _eventing.Data?.KpiResults, TrendingSvg)
            </div>
        }
    </section>

    <!-- Integration -->
    <section class="space-y-4">
        <div>
            <h2 class="text-base font-semibold uppercase tracking-wide text-slate-700">Integration</h2>
            <p class="text-sm text-slate-500">Connector catalog, instances, mapping profiles, and runtime health snapshot.</p>
        </div>
        @if (_integration.Loading)
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="h-28 animate-pulse rounded-xl border border-slate-200 bg-slate-100 shadow-sm" />
                }
            </div>
        }
        else if (_integration.Error is not null)
        {
            <p class="text-sm text-red-600">@_integration.Error</p>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @MetricCard("Connector definitions", _integration.Data?.Operational.Definitions, PlugSvg)
                @MetricCard("Connector instances", _integration.Data?.Operational.Instances, ServerSvg)
                @MetricCard("Mapping profiles", _integration.Data?.Operational.Profiles, ArrowSvg)
                @MetricCard("Runtime health rows", _integration.Data?.Runtime.ActiveHealthRows, HeartPulseSvg)
            </div>
        }
    </section>

    <!-- Workflow -->
    <section class="space-y-4">
        <div>
            <h2 class="text-base font-semibold uppercase tracking-wide text-slate-700">Workflow</h2>
            <p class="text-sm text-slate-500">Definitions, steps, running instances, and recorded actions.</p>
        </div>
        @if (_workflow.Loading)
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="h-28 animate-pulse rounded-xl border border-slate-200 bg-slate-100 shadow-sm" />
                }
            </div>
        }
        else if (_workflow.Error is not null)
        {
            <p class="text-sm text-red-600">@_workflow.Error</p>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
                @MetricCard("Definitions", _workflow.Data?.Definitions, GitSvg)
                @MetricCard("Steps", _workflow.Data?.Steps, ListSvg)
                @MetricCard("Instances", _workflow.Data?.Instances, PlaySvg)
                @MetricCard("Actions", _workflow.Data?.Actions, ZapSvg)
            </div>
        }
    </section>

    <p class="text-sm text-slate-500">
        Workflow detail:
        <a href="/workflow/definitions" class="font-medium text-blue-700 underline-offset-2 hover:underline">Definitions</a>
        <span class="text-slate-400">·</span>
        <a href="/workflow/instances" class="font-medium text-blue-700 underline-offset-2 hover:underline">Instances</a>
    </p>
</div>

@code {
    private ApiFetch<MesSummaryDto> _mes = ApiFetch<MesSummaryDto>.InProgress();
    private ApiFetch<QualitySummaryDto> _quality = ApiFetch<QualitySummaryDto>.InProgress();
    private ApiFetch<EventingSummaryDto> _eventing = ApiFetch<EventingSummaryDto>.InProgress();
    private ApiFetch<IntegrationHealthSummaryDto> _integration = ApiFetch<IntegrationHealthSummaryDto>.InProgress();
    private ApiFetch<WorkflowSummaryDto> _workflow = ApiFetch<WorkflowSummaryDto>.InProgress();
    private string? _aggregateError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var tMes = Api.GetMesSummaryAsync();
        var tQuality = Api.GetQualitySummaryAsync();
        var tEventing = Api.GetEventingSummaryAsync();
        var tInt = Api.GetIntegrationHealthAsync();
        var tWf = Api.GetWorkflowSummaryAsync();
        await Task.WhenAll(tMes, tQuality, tEventing, tInt, tWf);
        _mes = await tMes;
        _quality = await tQuality;
        _eventing = await tEventing;
        _integration = await tInt;
        _workflow = await tWf;

        if (_mes.Error is not null && _quality.Error is not null && _eventing.Error is not null && _integration.Error is not null && _workflow.Error is not null)
            _aggregateError = "Could not reach the API. Check XMachine:Api:BaseUrl and that XMachine.Api is running.";

        StateHasChanged();
    }

    private static string? Fmt(int? v) => v?.ToString();

    /// <summary>
    /// Renders a dashboard metric card with optional warning styling when <paramref name="warn"/> is true and value is greater than zero.
    /// </summary>
    private RenderFragment MetricCard(string label, int? value, string iconSvg, bool warn = false) => __builder =>
    {
        var amber = warn && (value ?? 0) > 0;
        var valueClass = amber
            ? "text-3xl font-bold tabular-nums text-amber-600"
            : "text-3xl font-bold tabular-nums text-slate-900";

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <div class="mb-3 flex items-center justify-between gap-2">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">@label</span>
                <span class="inline-flex h-4 w-4 shrink-0 text-slate-400 [&>svg]:block">@((MarkupString)iconSvg)</span>
            </div>
            <div class="@valueClass">@(Fmt(value) ?? "—")</div>
        </div>
    };

    private const string ClipboardSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="15" y2="16"/></svg>""";

    private const string BookSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>""";

    private const string LayersSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>""";

    private const string ClockSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>""";

    private const string CheckSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>""";

    private const string RulerSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 8.7 8.7 21.3c-1 1-2.5 1-3.4 0l-2.6-2.6c-1-1-1-2.5 0-3.4L15.3 2.7c1-1 2.5-1 3.4 0l2.6 2.6c1 1 1 2.5 0 3.4Z"/><path d="m7.5 10.5 2 2"/><path d="m10.5 7.5 2 2"/><path d="m13.5 4.5 2 2"/><path d="m4.5 13.5 2 2"/></svg>""";

    private const string AlertSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>""";

    private const string FlagSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>""";

    private const string BellSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>""";

    private const string PauseSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="10" y1="15" x2="10" y2="9"/><line x1="14" y1="15" x2="14" y2="9"/></svg>""";

    private const string ActivitySvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>""";

    private const string TrendingSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>""";

    private const string PlugSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4Z"/></svg>""";

    private const string ServerSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>""";

    private const string ArrowSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>""";

    private const string HeartPulseSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5-.5 1.5H22"/></svg>""";

    private const string GitSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>""";

    private const string ListSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>""";

    private const string PlaySvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>""";

    private const string ZapSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>""";
}
