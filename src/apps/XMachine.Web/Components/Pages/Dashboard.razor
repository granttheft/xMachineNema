@page "/dashboard"
@rendermode InteractiveServer
@using System.Globalization
@inject XMachineApiClient Api
@implements IDisposable

<PageTitle>Dashboard · xMachine</PageTitle>

<div class="min-h-screen bg-slate-50">
    <!-- FactoryDashboard: top navigation -->
    <div class="bg-white border-b border-slate-200 px-6 py-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-10 5L2 8v12Z"/><path d="M22 8V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2"/><path d="M6 2v4"/><path d="M10 2v4"/><path d="M14 2v4"/></svg>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-slate-900">Smart Factory Dashboard</h1>
                    <p class="text-sm text-slate-600">Operations control center</p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <input type="date" @bind="_selectedDate" @bind:format="yyyy-MM-dd" class="w-40 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm" />
                </div>
                <select @bind="_currentShift" class="w-48 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm">
                    <option value="Day Shift A">Day Shift A (08:00-16:00)</option>
                    <option value="Day Shift B">Day Shift B (16:00-24:00)</option>
                    <option value="Night Shift">Night Shift (00:00-08:00)</option>
                </select>
            </div>
            <div class="flex items-center gap-3">
                <div class="text-right">
                    <div class="text-sm font-medium">Production Manager</div>
                    <div class="text-xs text-slate-600">On-site leadership</div>
                </div>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-200 text-sm font-medium text-slate-700">PM</div>
                <div class="flex items-center gap-1">
                    <div class="h-2 w-2 rounded-full bg-green-500"></div>
                    <span class="text-xs text-slate-600">Online</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ExecutiveDashboard: header -->
    <div class="bg-slate-900 text-white p-6">
        <div class="max-w-7xl mx-auto">
            <div class="flex justify-between items-start">
                <div class="flex items-center gap-4">
                    <div class="bg-blue-600 p-3 rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-10 5L2 8v12Z"/><path d="M22 8V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2"/><path d="M6 2v4"/><path d="M10 2v4"/><path d="M14 2v4"/></svg>
                    </div>
                    <div>
                        <h1 class="text-3xl font-semibold">Smart Plastic Factory</h1>
                        <h2 class="text-xl text-slate-300">Executive Dashboard</h2>
                        <p class="text-sm text-slate-400 mt-1">Executive Command Center</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <div class="text-2xl font-semibold font-mono">@FormatExecTime(_currentTime)</div>
                        <div class="text-sm text-slate-300">@FormatExecDate(_currentTime)</div>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border h-9 px-3 bg-white/10 border-white/20 text-white hover:bg-white/20">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mr-2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            Export PDF
                        </button>
                        <button type="button" @onclick="() => StateHasChanged()" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border h-9 px-3 bg-white/10 border-white/20 text-white hover:bg-white/20">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mr-2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                            Refresh
                        </button>
                        <button type="button" @onclick="() => { _chatOpen = !_chatOpen; }" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border h-9 px-3 bg-blue-600/20 border-blue-400/50 text-blue-200 hover:bg-blue-600/30">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mr-2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            AI Chat
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_alerts.Count > 0)
    {
        <div class="bg-red-600 text-white">
            @foreach (var alert in _alerts)
            {
                <div class="flex items-center justify-between px-6 py-3 border-b border-red-500 last:border-b-0">
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <span class="font-medium">@alert.Message</span>
                        <span class="text-sm opacity-80">@alert.Time</span>
                    </div>
                    <button type="button" @onclick="() => DismissAlert(alert.Id)" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-white hover:bg-white/20 p-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
        </div>
    }

    <div class="max-w-7xl mx-auto p-6 space-y-6">
        <!-- FactoryDashboard: factory KPI summary (monitoring tab) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="rounded-lg border text-card-foreground shadow-sm bg-gradient-to-br from-green-500 to-green-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-green-100 text-sm font-medium">🟢 Running Machines</p>
                            <p class="text-xs text-green-100">In production</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-100"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                    <div class="mt-4">
                        <div class="text-3xl font-bold">@FactoryKpiRunningCount</div>
                        <div class="text-sm text-green-100">of @FactoryKpiTotal machines (@FactoryKpiRunningPct%)</div>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border text-card-foreground shadow-sm bg-gradient-to-br from-yellow-500 to-yellow-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-yellow-100 text-sm font-medium">🟡 Idle Machines</p>
                            <p class="text-xs text-yellow-100">Awaiting work</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-yellow-100"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                    </div>
                    <div class="mt-4">
                        <div class="text-3xl font-bold">@FactoryKpiIdleCount</div>
                        <div class="text-sm text-yellow-100">of @FactoryKpiTotal machines (@FactoryKpiIdlePct%)</div>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border text-card-foreground shadow-sm bg-gradient-to-br from-red-500 to-red-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-red-100 text-sm font-medium">🔴 Blocked/Down</p>
                            <p class="text-xs text-red-100">Stopped or blocked</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-red-100"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    </div>
                    <div class="mt-4">
                        <div class="text-3xl font-bold">@FactoryKpiBlockedCount</div>
                        <div class="text-sm text-red-100">of @FactoryKpiTotal machines (@FactoryKpiBlockedPct%)</div>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border text-card-foreground shadow-sm bg-gradient-to-br from-blue-500 to-blue-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-blue-100 text-sm font-medium">📦 Units Produced Today</p>
                            <p class="text-xs text-blue-100">Daily throughput</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-blue-100"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>
                    </div>
                    <div class="mt-4">
                        <div class="text-3xl font-bold">@FactoryKpiProducedCount.ToString("N0")</div>
                        <div class="text-sm text-blue-100">Target: @FactoryKpiProducedTarget.ToString("N0") (@FactoryKpiProducedPct%)</div>
                        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-blue-400">
                            <div class="h-2 rounded-full bg-white/90" style="width: @(FactoryKpiProducedPct)%"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border text-card-foreground shadow-sm bg-gradient-to-br from-orange-500 to-orange-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-orange-100 text-sm font-medium">❌ Defects Today</p>
                            <p class="text-xs text-orange-100">Quality rejects</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-orange-100"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    </div>
                    <div class="mt-4">
                        <div class="text-3xl font-bold">@FactoryKpiDefectsCount</div>
                        <div class="text-sm text-orange-100">@FactoryKpiDefectsRatePct% defect rate</div>
                        <div class="text-xs text-orange-100 mt-1">Top: @FactoryKpiDefectsTopReason</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ExecutiveDashboard: output summary -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-lg border-0 text-card-foreground shadow-sm bg-gradient-to-r from-blue-600 to-blue-700 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-blue-100 mb-1">Total Units Produced</p>
                            <p class="text-3xl font-bold">@TodayKpiTotalUnits.ToString("N0")</p>
                            <p class="text-sm text-blue-100">pcs (Today)</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-blue-200"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border-0 text-card-foreground shadow-sm bg-gradient-to-r from-orange-500 to-orange-600 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-orange-100 mb-1">Defective Products</p>
                            <p class="text-3xl font-bold">@TodayKpiDefectiveProducts</p>
                            <p class="text-sm text-orange-100">pcs (3.4%)</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-orange-200"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border-0 text-card-foreground shadow-sm bg-gradient-to-r from-green-600 to-green-700 text-white">
                <div class="p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-green-100 mb-1">QR-Printed Finished Goods</p>
                            <p class="text-3xl font-bold">@TodayKpiQrPrinted.ToString("N0")</p>
                            <p class="text-sm text-green-100">pcs (93.6%)</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-200"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- ExecutiveDashboard: live machine table -->
        <div class="rounded-lg border border-slate-200 bg-white text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="text-2xl font-semibold leading-none tracking-tight flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Live Machine Status Monitor
                </h3>
            </div>
            <div class="p-6 pt-0">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b">
                                <th class="text-left p-3 font-medium">Machine ID</th>
                                <th class="text-left p-3 font-medium">Status</th>
                                <th class="text-left p-3 font-medium">Product Name</th>
                                <th class="text-left p-3 font-medium">Target vs Done</th>
                                <th class="text-left p-3 font-medium">Progress</th>
                                <th class="text-left p-3 font-medium">Downtime Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var machine in _execMachineRows)
                            {
                                <tr class="border-b hover:bg-slate-50">
                                    <td class="p-3 font-semibold">@machine.Id</td>
                                    <td class="p-3">
                                        <div class="flex items-center gap-2">
                                            <span class="text-lg">@GetStatusEmoji(machine.Status)</span>
                                            <span class="@GetExecStatusBadgeClass(machine.Status) inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold transition-colors">@Capitalize(machine.Status)</span>
                                        </div>
                                    </td>
                                    <td class="p-3">@machine.Product</td>
                                    <td class="p-3">
                                        <div class="text-sm">
                                            <div class="font-medium">@machine.Done / @machine.Target</div>
                                            <div class="text-slate-500">units</div>
                                        </div>
                                    </td>
                                    <td class="p-3">
                                        <div class="flex items-center gap-2">
                                            <div class="relative h-2 w-20 overflow-hidden rounded-full bg-slate-200">
                                                <div class="h-full bg-blue-600 transition-all" style="width: @(Math.Min(100, (double)machine.Progress))%"></div>
                                            </div>
                                            <span class="text-sm font-medium">@machine.Progress%</span>
                                        </div>
                                    </td>
                                    <td class="p-3">
                                        @if (machine.Downtime is not null)
                                        {
                                            <span class="inline-flex items-center rounded-md border border-transparent bg-red-600 px-2.5 py-0.5 text-xs font-semibold text-white">@machine.Downtime</span>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400 text-sm">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- FactoryDashboard: machine tiles (3-column) -->
        <div class="rounded-lg border border-slate-200 bg-white text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-2xl font-semibold leading-none tracking-tight flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-10 5L2 8v12Z"/></svg>
                        <span>Live Machine Status</span>
                        <span class="text-sm font-normal text-slate-600">Real-time equipment</span>
                    </h3>
                    <div class="flex items-center gap-2 text-sm text-slate-600">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                        <span>Last updated: @_lastUpdate.ToString("T")</span>
                    </div>
                </div>
            </div>
            <div class="p-6 pt-0">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var machine in _factoryMachines)
                    {
                        var op = machine.OperatorId is null ? null : _factoryOperators.FirstOrDefault(o => o.Id == machine.OperatorId);
                        var product = machine.ProductId is null ? null : _factoryProducts.FirstOrDefault(p => p.Id == machine.ProductId);
                        var progressPct = GetProgressPercentage(machine.CompletedQty, machine.TargetQty);
                        <div class="cursor-pointer rounded-lg border bg-white text-card-foreground shadow-sm @GetFactoryMachineCardBorderClass(machine.Status)">
                            <div class="p-4">
                                <div class="flex items-center justify-between mb-3">
                                    <div>
                                        <h3 class="font-bold text-base">@machine.Name</h3>
                                        <p class="text-xs text-slate-600">@machine.Id</p>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <div class="w-3 h-3 rounded-full @GetFactoryStatusDotClass(machine.Status) @(machine.Status == "running" ? "animate-pulse" : "")"></div>
                                        @if (machine.Status == "running")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                        }
                                        else if (machine.Status == "idle")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                                        }
                                        else if (machine.Status == "blocked")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                        }
                                        else if (machine.Status == "scheduled")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        }
                                        else if (machine.Status == "maintenance")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                                        }
                                    </div>
                                </div>
