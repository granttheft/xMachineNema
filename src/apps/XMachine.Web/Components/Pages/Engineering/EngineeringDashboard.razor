    private static string FilterBtnClass(bool active) =>
        active
            ? "inline-flex items-center justify-center border border-transparent bg-slate-900 text-white hover:bg-slate-800"
            : "inline-flex items-center justify-center border border-slate-200 bg-white text-slate-900 hover:bg-slate-50";

    private void OnViewDetails(EngMachine machine)
    {
        _toastInfo = $"Opening details for {machine.Name}";
        StateHasChanged();
    }

    private void CloseModalAfterSave()
    {
        _showBreakdownModal = false;
        _toastInfo = "Breakdown report saved and engineer assigned.";
        StateHasChanged();
    }

    private void CloseModalAfterSaveAndRepair()
    {
        _showBreakdownModal = false;
        _toastInfo = "Report saved and repair started.";
        StateHasChanged();
    }
}
