@code {
    private string _activeTab = "breakdowns";
    private bool _initialized;
    private bool _engineeringLoaded;
    private string? _pageLoadError;
    private string? _workOrderActionError;
    private bool _workOrderActionBusy;

    private List<ApiMachine> _apiMachines = new();
    private List<ApiWorkOrder> _apiWorkOrders = new();
    private List<ApiPmSchedule> _apiPmSchedules = new();

    private bool _showBreakdownModal;
    private string? _breakdownModalError;
    private bool _breakdownSaving;
    private Guid _breakdownMachineId;
    private string _breakdownWorkOrderType = "Corrective";
    private string _breakdownPriority = "P2High";
    private string _breakdownAssignedRole = "maintenance";
    private string _breakdownDescription = string.Empty;

    private bool _showPmScheduleModal;
    private string? _pmModalError;
    private bool _pmSaving;
    private Guid _pmMachineId;
    private string _pmName = string.Empty;
    private string _pmIntervalType = "days";
    private int _pmIntervalValue = 7;
    private DateTime? _pmFirstDueDate;
    private string _pmOwnerRole = "maintenance";
    private string _pmDescription = string.Empty;

    private readonly SpareSummary _spareSummary = new(124, 3, 2);

    private static readonly IReadOnlyList<SparePartRow> _spareRows =
    [
        new("SP-001", "Temperature Sensor", "Sensors", "5 qty", "min 3", "InStock", "In Stock"),
        new("SP-002", "Injection Nozzle", "Injection", "2 qty", "min 5", "LowStock", "Low Stock"),
        new("SP-003", "Motor Belt", "Mechanical", "8 qty", "min 4", "InStock", "In Stock"),
        new("SP-004", "Hydraulic Seal", "Hydraulic", "0 qty", "min 2", "OutOfStock", "Out of Stock"),
    ];

    /// <summary>
    /// Summary counts for the Breakdowns tab.
    /// </summary>
    private sealed record BreakdownSummary(int Open, int InProgress, int WaitingParts, int CompletedToday);

    /// <summary>
    /// One row in the breakdown work order table.
    /// </summary>
    private sealed record BreakdownRow(
        Guid Id,
        string WoNumber,
        string Machine,
        string WoType,
        string Priority,
        string Status,
        string AssignedRole,
        string ReportedAt);

    /// <summary>
    /// Summary counts for the Preventive Maintenance tab.
    /// </summary>
    private sealed record PmSummary(int Total, int Overdue, int DueThisWeek, int CompliancePct);

    /// <summary>
    /// One row in the PM schedule table.
    /// </summary>
    private sealed record PmScheduleRow(
        string ScheduleName,
        string Machine,
        string Interval,
        string LastDone,
        string NextDue,
        string Status,
        string OwnerRole);

    /// <summary>
    /// Summary counts for the Spare Parts tab.
    /// </summary>
    private sealed record SpareSummary(int TotalParts, int LowStock, int OrdersPending);

    /// <summary>
    /// One row in the spare parts table.
    /// </summary>
    private sealed record SparePartRow(
        string PartCode,
        string Description,
        string Category,
        string StockQty,
        string MinLevel,
        string Status,
        string StatusLabel);

    private void SetTab(string tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        _initialized = true;
        await LoadEngineeringDataAsync();
        StateHasChanged();
    }

    private async Task LoadEngineeringDataAsync()
    {
        _pageLoadError = null;

        var machinesResult = await Api.GetEngineeringMachineStatusAsync();
        StateHasChanged();
        if (machinesResult.Error is not null)
            _pageLoadError = machinesResult.Error;
        else if (machinesResult.Data is not null)
            _apiMachines = machinesResult.Data;

        var workOrdersResult = await Api.GetEngineeringWorkOrdersAsync();
        StateHasChanged();
        if (workOrdersResult.Error is not null)
            _pageLoadError = string.IsNullOrEmpty(_pageLoadError) ? workOrdersResult.Error : $"{_pageLoadError} {workOrdersResult.Error}";
        else if (workOrdersResult.Data is not null)
            _apiWorkOrders = workOrdersResult.Data;

        var pmResult = await Api.GetEngineeringPmSchedulesAsync();
        StateHasChanged();
        if (pmResult.Error is not null)
            _pageLoadError = string.IsNullOrEmpty(_pageLoadError) ? pmResult.Error : $"{_pageLoadError} {pmResult.Error}";
        else if (pmResult.Data is not null)
            _apiPmSchedules = pmResult.Data;

        _engineeringLoaded = true;
        StateHasChanged();
    }

    private async Task ReloadWorkOrdersAndMachinesAsync()
    {
        var workOrdersResult = await Api.GetEngineeringWorkOrdersAsync();
        StateHasChanged();
        if (workOrdersResult.Data is not null)
            _apiWorkOrders = workOrdersResult.Data;

        var machinesResult = await Api.GetEngineeringMachineStatusAsync();
        StateHasChanged();
        if (machinesResult.Data is not null)
            _apiMachines = machinesResult.Data;

        StateHasChanged();
    }

    private void OpenBreakdownModal()
    {
        _breakdownModalError = null;
        _showBreakdownModal = true;
        if (_breakdownMachineId == Guid.Empty && _apiMachines.Count > 0)
            _breakdownMachineId = _apiMachines[0].Id;
        StateHasChanged();
    }

    private void CloseBreakdownModal()
    {
        _showBreakdownModal = false;
        _breakdownModalError = null;
        StateHasChanged();
    }

    private async Task SaveBreakdownReportAsync()
    {
        _breakdownModalError = null;
        if (_breakdownMachineId == Guid.Empty)
        {
            _breakdownModalError = "Select a machine.";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrWhiteSpace(_breakdownDescription))
        {
            _breakdownModalError = "Description is required.";
            StateHasChanged();
            return;
        }

        var machine = _apiMachines.FirstOrDefault(m => m.Id == _breakdownMachineId);
        var dto = new CreateWorkOrderDto(
            _breakdownMachineId,
            machine is null ? null : machine.LineId,
            _breakdownWorkOrderType,
            _breakdownPriority,
            _breakdownDescription.Trim(),
            null,
            _breakdownAssignedRole);

        _breakdownSaving = true;
        StateHasChanged();
        var result = await Api.PostWorkOrderAsync(dto);
        StateHasChanged();
        _breakdownSaving = false;

        if (result.Error is not null)
        {
            _breakdownModalError = result.Error;
            StateHasChanged();
            return;
        }

        _showBreakdownModal = false;
        _breakdownDescription = string.Empty;
        await ReloadWorkOrdersAndMachinesAsync();
        StateHasChanged();
    }

    private void OpenPmScheduleModal()
    {
        _pmModalError = null;
        _showPmScheduleModal = true;
        if (_pmMachineId == Guid.Empty && _apiMachines.Count > 0)
            _pmMachineId = _apiMachines[0].Id;
        StateHasChanged();
    }

    private void ClosePmScheduleModal()
    {
        _showPmScheduleModal = false;
        _pmModalError = null;
        StateHasChanged();
    }

    private async Task SavePmScheduleAsync()
    {
        _pmModalError = null;
        if (_pmMachineId == Guid.Empty)
        {
            _pmModalError = "Select a machine.";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrWhiteSpace(_pmName))
        {
            _pmModalError = "Name is required.";
            StateHasChanged();
            return;
        }

        if (_pmIntervalValue < 1)
        {
            _pmModalError = "Interval value must be at least 1.";
            StateHasChanged();
            return;
        }

        int? intervalHours = _pmIntervalType == "hours" ? _pmIntervalValue : null;
        int? intervalDays = _pmIntervalType == "days" ? _pmIntervalValue : null;

        DateTimeOffset? firstDue = _pmFirstDueDate is { } fd
            ? new DateTimeOffset(DateTime.SpecifyKind(fd.Date, DateTimeKind.Utc))
            : null;

        var dto = new CreatePmScheduleDto(
            _pmMachineId,
            _pmName.Trim(),
            string.IsNullOrWhiteSpace(_pmDescription) ? null : _pmDescription.Trim(),
            intervalHours,
            intervalDays,
            firstDue,
            string.IsNullOrWhiteSpace(_pmOwnerRole) ? null : _pmOwnerRole.Trim());

        _pmSaving = true;
        StateHasChanged();
        var result = await Api.PostPmScheduleAsync(dto);
        StateHasChanged();
        _pmSaving = false;

        if (result.Error is not null)
        {
            _pmModalError = result.Error;
            StateHasChanged();
            return;
        }

        _showPmScheduleModal = false;
        _pmName = string.Empty;
        _pmDescription = string.Empty;
        _pmIntervalValue = 7;
        _pmFirstDueDate = null;

        var pmResult = await Api.GetEngineeringPmSchedulesAsync();
        StateHasChanged();
        if (pmResult.Data is not null)
            _apiPmSchedules = pmResult.Data;

        StateHasChanged();
    }

