@if (_showBreakdownModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @onclick="() => _showBreakdownModal = false">
        <div class="max-w-2xl w-full rounded-lg border border-slate-200 bg-white p-6 shadow-lg" @onclick:stopPropagation="true">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Breakdown Report</h2>
                    <p class="text-sm text-slate-500 mt-1">Log a new breakdown and assign follow-up.</p>
                </div>
                <button type="button" @onclick="() => _showBreakdownModal = false" class="rounded-md p-1 text-slate-500 hover:bg-slate-100" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900">Machine</label>
                    <select class="flex h-10 w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm">
                        @foreach (var m in _mockMachines)
                        {
                            <option value="@m">@m</option>
                        }
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900">Type</label>
                    <select class="flex h-10 w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option>Corrective</option>
                        <option>Preventive</option>
                        <option>MoldChange</option>
                        <option>Inspection</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900">Priority</label>
                    <select class="flex h-10 w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option>P1Critical</option>
                        <option>P2High</option>
                        <option>P3Medium</option>
                        <option>P4Low</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900">Assigned Role</label>
                    <select class="flex h-10 w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="maintenance">maintenance</option>
                        <option value="mold">mold</option>
                        <option value="plastic">plastic</option>
                        <option value="mold-change">mold-change</option>
                        <option value="technician-head">technician-head</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900">Description</label>
                    <textarea rows="4" placeholder="Describe the issue..." class="flex min-h-[80px] w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm"></textarea>
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @onclick="() => _showBreakdownModal = false" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-slate-200 bg-white h-9 px-4 hover:bg-slate-50">Cancel</button>
                    <button type="button" @onclick="() => _showBreakdownModal = false" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-slate-900 text-white h-9 px-4 hover:bg-slate-800">Save Report</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _activeTab = "breakdowns";
    private bool _showBreakdownModal;

    private static readonly IReadOnlyList<string> _mockMachines = ["M-101", "M-102", "M-201", "M-202"];

    private readonly BreakdownSummary _breakdownSummary = new(12, 5, 3, 8);

    private static readonly IReadOnlyList<BreakdownRow> _breakdownRows =
    [
        new("WO-20240115-001", "M-101", "Corrective", "P1Critical", "InProgress", "maintenance", "3h ago"),
        new("WO-20240115-002", "M-201", "Preventive", "P2High", "Open", "mold", "1h ago"),
        new("WO-20240114-001", "M-102", "Corrective", "P3Medium", "Done", "maintenance", "yesterday"),
    ];

    private readonly PmSummary _pmSummary = new(24, 5, 7, 94);

    private static readonly IReadOnlyList<PmScheduleRow> _pmRows =
    [
        new("Monthly preventive maintenance", "M-101", "30 days", "45 days ago", "15 days overdue", "Overdue", "maintenance"),
        new("Weekly lubrication check", "M-102", "7 days", "3 days ago", "in 4 days", "Due Soon", "maintenance"),
        new("Quarterly mold inspection", "M-201", "90 days", "92 days ago", "2 days overdue", "Overdue", "mold"),
        new("Daily tooling check", "M-202", "1 day", "today", "tomorrow", "OK", "plastic"),
    ];

    private readonly SpareSummary _spareSummary = new(124, 3, 2);

    private static readonly IReadOnlyList<SparePartRow> _spareRows =
    [
        new("SP-001", "Temperature Sensor", "Sensors", "5 qty", "min 3", "InStock", "In Stock"),
        new("SP-002", "Injection Nozzle", "Injection", "2 qty", "min 5", "LowStock", "Low Stock"),
        new("SP-003", "Motor Belt", "Mechanical", "8 qty", "min 4", "InStock", "In Stock"),
        new("SP-004", "Hydraulic Seal", "Hydraulic", "0 qty", "min 2", "OutOfStock", "Out of Stock"),
    ];

    /// <summary>
    /// Summary counts for the Breakdowns tab.
    /// </summary>
    private sealed record BreakdownSummary(int Open, int InProgress, int WaitingParts, int CompletedToday);

    /// <summary>
    /// One row in the breakdown work order table.
    /// </summary>
    private sealed record BreakdownRow(
        string WoNumber,
        string Machine,
        string WoType,
        string Priority,
        string Status,
        string AssignedRole,
        string ReportedAt);

    /// <summary>
    /// Summary counts for the Preventive Maintenance tab.
    /// </summary>
    private sealed record PmSummary(int Total, int Overdue, int DueThisWeek, int CompliancePct);

    /// <summary>
    /// One row in the PM schedule table.
    /// </summary>
    private sealed record PmScheduleRow(
        string ScheduleName,
        string Machine,
        string Interval,
        string LastDone,
        string NextDue,
        string Status,
        string OwnerRole);

    /// <summary>
    /// Summary counts for the Spare Parts tab.
    /// </summary>
    private sealed record SpareSummary(int TotalParts, int LowStock, int OrdersPending);

    /// <summary>
    /// One row in the spare parts table.
    /// </summary>
    private sealed record SparePartRow(
        string PartCode,
        string Description,
        string Category,
        string StockQty,
        string MinLevel,
        string Status,
        string StatusLabel);

    private void SetTab(string tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Task.CompletedTask;
        StateHasChanged();
    }

    private static string TabClass(bool active) =>
        active
            ? "border-b-2 border-slate-900 text-slate-900 font-medium"
            : "border-b-2 border-transparent text-slate-500 hover:text-slate-700";

    private static string GetPriorityClass(string priority) => priority switch
    {
        "P1Critical" => "bg-red-100 text-red-800",
        "P2High" => "bg-orange-100 text-orange-800",
        "P3Medium" => "bg-blue-100 text-blue-800",
        "P4Low" => "bg-slate-100 text-slate-600",
        _ => "bg-slate-100 text-slate-600",
    };

    private static string GetWoStatusClass(string status) => status switch
    {
        "Open" => "bg-yellow-100 text-yellow-800",
        "InProgress" => "bg-blue-100 text-blue-800",
        "WaitingParts" => "bg-orange-100 text-orange-800",
        "Done" => "bg-green-100 text-green-800",
        "Cancelled" => "bg-slate-100 text-slate-500",
        _ => "bg-slate-100 text-slate-500",
    };

    private static string GetPmStatusClass(string status) => status switch
    {
        "Overdue" => "bg-red-100 text-red-800",
        "Due Soon" => "bg-orange-100 text-orange-800",
        "OK" => "bg-green-100 text-green-800",
        _ => "bg-slate-100 text-slate-600",
    };

    private static string GetStockStatusClass(string status) => status switch
    {
        "LowStock" => "bg-yellow-100 text-yellow-800",
        "InStock" => "bg-green-100 text-green-800",
        "OutOfStock" => "bg-red-100 text-red-800",
        _ => "bg-slate-100 text-slate-600",
    };
}
