@page "/engineering"
@rendermode InteractiveServer
@using System.Globalization
@inject XMachineApiClient Api

<PageTitle>Engineering · xMachine</PageTitle>

<div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-6 py-4">
        <h1 class="text-2xl font-semibold text-slate-900">Engineering</h1>
        <p class="text-sm text-slate-500 mt-1">Breakdown Management · Preventive Maintenance · Spare Parts</p>
    </div>

    <div class="bg-white border-b border-slate-200 px-6">
        <div class="flex flex-wrap gap-x-8">
            <button type="button"
                    @onclick='() => SetTab("breakdowns")'
                    class="@TabClass(_activeTab == "breakdowns") py-3 px-1 text-sm mr-8">
                Breakdowns
            </button>
            <button type="button"
                    @onclick='() => SetTab("pm")'
                    class="@TabClass(_activeTab == "pm") py-3 px-1 text-sm mr-8">
                Preventive Maintenance
            </button>
            <button type="button"
                    @onclick='() => SetTab("spares")'
                    class="@TabClass(_activeTab == "spares") py-3 px-1 text-sm mr-8">
                Spare Parts
            </button>
            <button type="button"
                    @onclick='() => SetTab("process")'
                    class="@TabClass(_activeTab == "process") py-3 px-1 text-sm mr-8">
                Process Setup
            </button>
            <button type="button"
                    @onclick='() => SetTab("reports")'
                    class="@TabClass(_activeTab == "reports") py-3 px-1 text-sm mr-8">
                Reports
            </button>
        </div>
    </div>

    <div class="p-6">
        @if (!string.IsNullOrEmpty(_pageLoadError))
        {
            <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-900">@_pageLoadError</div>
        }
        @if (_activeTab == "breakdowns")
        {
            @if (!_engineeringLoaded)
            {
                <p class="text-sm text-slate-600 mb-6">Loading breakdown data…</p>
            }
            else
            {
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 flex-1">
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Open Work Orders</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetBreakdownSummary().Open</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">In Progress</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetBreakdownSummary().InProgress</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Waiting Parts</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetBreakdownSummary().WaitingParts</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Completed Today</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetBreakdownSummary().CompletedToday</p>
                    </div>
                </div>
                <button type="button"
                        @onclick="OpenBreakdownModal"
                        class="shrink-0 inline-flex items-center justify-center rounded-md text-sm font-medium bg-slate-900 text-white h-9 px-4 hover:bg-slate-800 whitespace-nowrap">
                    Report New Breakdown
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_workOrderActionError))
            {
                <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-800">@_workOrderActionError</div>
            }

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">WO Number</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Machine</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Type</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Priority</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Assigned Role</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Reported At</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var row in GetBreakdownRows())
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@row.WoNumber</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.Machine</td>
                                <td class="px-4 py-3 text-sm text-slate-700">@row.WoType</td>
                                <td class="px-4 py-3 text-sm">
                                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetPriorityClass(row.Priority)">@row.Priority</span>
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetWoStatusClass(row.Status)">@row.Status</span>
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-700">@row.AssignedRole</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-600">@row.ReportedAt</td>
                                <td class="px-4 py-3 text-sm">
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-slate-200 bg-white h-8 px-3 hover:bg-slate-50">View Details</button>
                                        @if (IsOpenWoStatus(row.Status))
                                        {
                                            <button type="button" disabled="@_workOrderActionBusy" @onclick="() => StartWorkOrderAsync(row.Id)" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-blue-600 text-white h-8 px-3 hover:bg-blue-700 disabled:opacity-50">Start</button>
                                        }
                                        @if (IsInProgressWoStatus(row.Status))
                                        {
                                            <button type="button" disabled="@_workOrderActionBusy" @onclick="() => MarkDoneWorkOrderAsync(row.Id)" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-green-600 text-white h-8 px-3 hover:bg-green-700 disabled:opacity-50">Mark Done</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            }
        }
        else if (_activeTab == "pm")
        {
            @if (!_engineeringLoaded)
            {
                <p class="text-sm text-slate-600 mb-6">Loading preventive maintenance…</p>
            }
            else
            {
            <div class="flex flex-col lg:flex-row lg:items-stretch lg:justify-between gap-4 mb-6">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 flex-1">
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total PM Schedules</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetPmSummary().Total</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Overdue</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetPmSummary().Overdue</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Due This Week</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetPmSummary().DueThisWeek</p>
                    </div>
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Compliance %</p>
                        <p class="text-2xl font-semibold text-slate-900 mt-1">@GetPmSummary().CompliancePct%</p>
                    </div>
                </div>
                <div class="flex items-start justify-end shrink-0">
                    <button type="button"
                            @onclick="OpenPmScheduleModal"
                            class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-slate-900 text-white h-9 px-4 hover:bg-slate-800 whitespace-nowrap">
                        Schedule PM
                    </button>
                </div>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Schedule Name</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Machine</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Interval</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Last Done</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Next Due</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Owner Role</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var row in GetPmRows())
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3 text-sm text-slate-900 font-medium">@row.ScheduleName</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.Machine</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.Interval</td>
                                <td class="px-4 py-3 text-sm text-slate-600">@row.LastDone</td>
                                <td class="px-4 py-3 text-sm text-slate-600">@row.NextDue</td>
                                <td class="px-4 py-3 text-sm">
                                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetPmStatusClass(row.Status)">@row.Status</span>
                                </td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.OwnerRole</td>
                                <td class="px-4 py-3 text-sm">
                                    <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-green-600 text-white h-8 px-3 hover:bg-green-700">Mark Done</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            }
        }
        else if (_activeTab == "spares")
        {
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Total Parts</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@_spareSummary.TotalParts</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Low Stock Items</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@_spareSummary.LowStock</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Orders Pending</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@_spareSummary.OrdersPending</p>
                </div>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Part Code</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Description</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Category</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Stock Qty</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Min Level</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var row in _spareRows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@row.PartCode</td>
                                <td class="px-4 py-3 text-sm text-slate-700">@row.Description</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.Category</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.StockQty</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-700">@row.MinLevel</td>
                                <td class="px-4 py-3 text-sm">
                                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetStockStatusClass(row.Status)">@row.StatusLabel</span>
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-slate-200 bg-white h-8 px-3 hover:bg-slate-50">Request</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (_activeTab == "process")
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-slate-900 mb-4">Mold Settings</h3>
                    <div class="space-y-4">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Clamp Position 1</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="120.5" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Clamp Position 2</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="118.2" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Core Forward</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="45.0" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Core Back</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="0.0" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Mold Temperature</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="65" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">°C</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Cycle Time</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="42" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">sec</span></div></div>
                    </div>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-slate-900 mb-4">Injection Settings</h3>
                    <div class="space-y-4">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Injection Pressure</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="142" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">MPa</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Injection Speed</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="78" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">%</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Holding Pressure</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="95" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">MPa</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Holding Time</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="8.5" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">sec</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Injection Timer</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="12" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">sec</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Back Pressure</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="12" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">MPa</span></div></div>
                    </div>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-slate-900 mb-4">Screw Settings</h3>
                    <div class="space-y-4">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Screw Speed</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="95" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">RPM</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Cushion</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="8.2" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3"><label class="text-sm font-medium text-slate-700 shrink-0 sm:w-44">Back Position</label><div class="flex flex-1 items-center gap-2 min-w-0"><input type="number" readonly value="142" class="h-10 flex-1 min-w-0 rounded-md border border-slate-200 bg-slate-50 px-3 text-sm text-slate-700" /><span class="text-xs text-slate-500 shrink-0">mm</span></div></div>
