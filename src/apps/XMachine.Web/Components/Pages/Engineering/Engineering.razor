    private BreakdownSummary GetBreakdownSummary()
    {
        var q = _apiWorkOrders
            .Where(w => string.Equals(w.WorkOrderType, "Corrective", StringComparison.OrdinalIgnoreCase))
            .ToList();
        var today = DateTimeOffset.UtcNow.Date;
        return new BreakdownSummary(
            q.Count(w => IsOpenWoStatus(w.WorkOrderStatus)),
            q.Count(w => IsInProgressWoStatus(w.WorkOrderStatus)),
            q.Count(w => IsWaitingPartsWoStatus(w.WorkOrderStatus)),
            q.Count(w =>
                IsDoneWoStatus(w.WorkOrderStatus) &&
                w.CompletedAt is { } ca &&
                ca.UtcDateTime.Date == today));
    }

    private List<BreakdownRow> GetBreakdownRows() =>
        _apiWorkOrders
            .Where(w => string.Equals(w.WorkOrderType, "Corrective", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(w => w.ReportedAt)
            .Select(w => new BreakdownRow(
                w.Id,
                w.WorkOrderNo,
                GetMachineDisplayName(w.MachineId),
                w.WorkOrderType,
                w.Priority,
                NormalizeWoStatus(w.WorkOrderStatus),
                string.IsNullOrWhiteSpace(w.AssignedRole) ? "—" : w.AssignedRole,
                w.ReportedAt.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)))
            .ToList();

    private string GetMachineDisplayName(Guid machineId)
    {
        var m = _apiMachines.FirstOrDefault(x => x.Id == machineId);
        return m is null ? "—" : $"{m.Name} ({m.Code})";
    }

    private static string NormalizeWoStatus(string status) =>
        status.Trim() switch
        {
            "open" => "Open",
            "inProgress" => "InProgress",
            "waitingParts" => "WaitingParts",
            "done" => "Done",
            "cancelled" => "Cancelled",
            _ => status,
        };

    private static bool IsOpenWoStatus(string status) =>
        string.Equals(NormalizeWoStatus(status), "Open", StringComparison.Ordinal);

    private static bool IsInProgressWoStatus(string status) =>
        string.Equals(NormalizeWoStatus(status), "InProgress", StringComparison.Ordinal);

    private static bool IsWaitingPartsWoStatus(string status) =>
        string.Equals(NormalizeWoStatus(status), "WaitingParts", StringComparison.Ordinal);

    private static bool IsDoneWoStatus(string status) =>
        string.Equals(NormalizeWoStatus(status), "Done", StringComparison.Ordinal);

    private PmSummary GetPmSummary()
    {
        var now = DateTimeOffset.UtcNow;
        var weekEnd = now.AddDays(7);
        var total = _apiPmSchedules.Count;
        var overdue = _apiPmSchedules.Count(s =>
            s.NextDueAt is { } nd && nd < now && string.Equals(s.Status, "Active", StringComparison.OrdinalIgnoreCase));
        var dueThisWeek = _apiPmSchedules.Count(s =>
            s.NextDueAt is { } nd &&
            nd >= now &&
            nd <= weekEnd &&
            string.Equals(s.Status, "Active", StringComparison.OrdinalIgnoreCase));
        var compliance = total == 0 ? 94 : Math.Clamp(100 - overdue * 10, 0, 100);
        return new PmSummary(total, overdue, dueThisWeek, compliance);
    }

    private List<PmScheduleRow> GetPmRows()
    {
        var now = DateTimeOffset.UtcNow;
        return _apiPmSchedules
            .OrderBy(s => s.NextDueAt ?? DateTimeOffset.MaxValue)
            .Select(s =>
            {
                var interval = s.IntervalDays is { } d
                    ? $"{d} days"
                    : s.IntervalHours is { } h
                        ? $"{h} hours"
                        : "—";
                var last = s.LastDoneAt?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture) ?? "—";
                var next = s.NextDueAt?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture) ?? "—";
                var statusLabel = s.NextDueAt is { } nd
                    ? nd < now ? "Overdue" : nd <= now.AddDays(7) ? "Due Soon" : "OK"
                    : "OK";
                return new PmScheduleRow(
                    s.Name,
                    GetMachineDisplayName(s.MachineId),
                    interval,
                    last,
                    next,
                    statusLabel,
                    string.IsNullOrWhiteSpace(s.OwnerRole) ? "—" : s.OwnerRole);
            })
            .ToList();
    }

