@page "/not-found"
@layout MainLayout

<PageTitle>Page not found</PageTitle>

<PageHeader Title="Page not found"
            Subtitle="The address may be mistyped, or the page may have been moved.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Not found</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Padded="true">
    <EmptyState Message="We could not find content for this URL." />
    <p class="small text-body-secondary mb-0 mt-3">
        <a href="/dashboard" class="xm-inline-link">Go to the operations dashboard</a>
    </p>
</DataPanel>
