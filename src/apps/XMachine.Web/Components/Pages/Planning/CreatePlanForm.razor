@page "/planning/create"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.AspNetCore.Components
@using XMachine.Web.Services
@implements IDisposable
@inject XMachineApiClient Api
@inject ITranslationService T
@inject NavigationManager Nav

<PageTitle>Create Production Plan</PageTitle>

<div class="flex min-h-screen flex-col bg-slate-50">
    <div class="border-b border-slate-200 bg-white px-6 py-4">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex items-start gap-3">
                <button type="button"
                        class="mt-0.5 rounded-lg border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50"
                        @onclick="@(() => Nav.NavigateTo("/planning/schedule"))">
                    Back
                </button>
                <div>
                    <h1 class="text-2xl font-semibold text-slate-900">Create Production Plan</h1>
                    <p class="mt-1 text-sm text-slate-600">Plan creation and resource allocation</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <div class="font-mono text-sm text-slate-700">@_planNo</div>
                <span class="rounded-md px-2 py-0.5 text-xs font-medium @GetStatusBadgeClass(_status)">@_status</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorBanner))
    {
        <div class="mx-6 mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">@_errorBanner</div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="mx-6 mt-4 rounded-lg border px-4 py-3 text-sm @BannerClass()">
            @_successMessage
        </div>
    }

    <main class="flex-1 space-y-6 p-6 pb-32">
        <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Plan details</h2>
            <div class="mt-4 grid grid-cols-1 gap-6 lg:grid-cols-2">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Name <span class="text-red-600">*</span></label>
                        <input type="text" disabled="@_formLocked"
                               class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100"
                               placeholder="e.g. Week 19 Injection Run"
                               @bind="_planName" @bind:event="oninput" />
                        @if (_errors.TryGetValue("name", out var nameErr))
                        {
                            <p class="mt-1 text-xs text-red-600">@nameErr</p>
                        }
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Priority</label>
                        <select disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_priority">
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Machine <span class="text-red-600">*</span></label>
                        <select disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100"
                                value="@(_selectedMachineId?.ToString() ?? "")" @onchange="OnMachineSelectChange">
                            <option value="">— Select machine —</option>
                            @foreach (var m in _apiMachines.OrderBy(x => x.Code))
                            {
                                var down = string.Equals(m.OperationalStatus, "Down", StringComparison.OrdinalIgnoreCase);
                                <option value="@m.Id" disabled="@down">@m.Code — @m.Name (@m.OperationalStatus)</option>
                            }
                        </select>
                        @if (_errors.TryGetValue("machine", out var machineErr))
                        {
                            <p class="mt-1 text-xs text-red-600">@machineErr</p>
                        }
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Planned start <span class="text-red-600">*</span></label>
                        <input type="date" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100"
                               value="@_plannedStart" @onchange="OnPlannedStartChange" />
                        @if (_errors.TryGetValue("start", out var startErr))
                        {
                            <p class="mt-1 text-xs text-red-600">@startErr</p>
                        }
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Planned end <span class="text-red-600">*</span></label>
                        <input type="date" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100"
                               value="@_plannedEnd" @onchange="OnPlannedEndChange" />
                        @if (_errors.TryGetValue("end", out var endErr))
                        {
                            <p class="mt-1 text-xs text-red-600">@endErr</p>
                        }
                    </div>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Description</label>
                        <textarea rows="3" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_description"></textarea>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Estimated quantity</label>
                        <input type="number" min="0" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_estimatedQty" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Mold</label>
                        <select disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_selectedMoldCode">
                            <option value="">— Select mold —</option>
                            @foreach (var mold in _molds)
                            {
                                <option value="@mold.Code">@mold.Code — @mold.Name (@(mold.CapacityPph) pcs/hr)</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Setup time (minutes)</label>
                        <input type="number" min="0" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_setupTimeMinutes" />
                    </div>
                    @if (_estimatedQty > 0 && !string.IsNullOrEmpty(_selectedMoldCode))
                    {
                        <div class="rounded-lg border border-blue-100 bg-blue-50/80 p-4 text-sm text-slate-800">
                            <p class="font-medium text-blue-900">Duration (from mold capacity)</p>
                            <p class="mt-1 text-slate-700">
                                Calculated: <span class="font-mono">@CalculatedDurationHours.ToString("F2", CultureInfo.InvariantCulture)</span> hours (Qty ÷ mold capacity)
                            </p>
                            <label class="mt-3 flex items-center gap-2 text-sm">
                                <input type="checkbox" disabled="@_formLocked" @bind="_durationOverride" />
                                Override calculated duration
                            </label>
                            @if (_durationOverride)
                            {
                                <div class="mt-2 space-y-2">
                                    <div>
                                        <label class="text-xs text-slate-600">Duration (hours)</label>
                                        <input type="number" step="0.1" min="0" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" @bind="_overrideDurationHours" />
                                    </div>
                                    <div>
                                        <label class="text-xs text-slate-600">Override reason</label>
                                        <textarea rows="2" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" @bind="_overrideReason"></textarea>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div>
                        <label class="block text-xs font-medium text-slate-600">Notes</label>
                        <textarea rows="2" disabled="@_formLocked" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm disabled:bg-slate-100" @bind="_notes"></textarea>
                    </div>
                </div>
            </div>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Inventory check</h2>
            <p class="mt-1 text-sm text-slate-600">Mock availability (not connected to API).</p>
            <div class="mt-4 overflow-x-auto rounded-lg border border-slate-200">
                <table class="min-w-full divide-y divide-slate-100 text-sm">
                    <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Material</th>
                        <th class="px-4 py-3">Required</th>
                        <th class="px-4 py-3">Available</th>
                        <th class="px-4 py-3">Status</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var row in _inventoryRows)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3 font-medium text-slate-900">@row.Material</td>
                            <td class="px-4 py-3 text-slate-700">@row.Required</td>
                            <td class="px-4 py-3 text-slate-700">@row.Available</td>
                            <td class="px-4 py-3"><span class="rounded-md px-2 py-0.5 text-xs font-medium @row.BadgeClass">@row.StatusLabel</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-700">
                <span>✅ 3 OK</span>
                <span>⚠️ 1 Low Stock</span>
                <span>❌ 1 Insufficient</span>
            </div>
        </section>
    </main>

    <footer class="sticky bottom-0 z-10 border-t border-slate-200 bg-white px-6 py-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.06)]">
        <div class="flex flex-wrap justify-end gap-2">
            <button type="button" disabled="@_formLocked" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:opacity-50" @onclick="SaveDraftAsync">
                Save as Draft
            </button>
            <button type="button" disabled="@(_formLocked || HasInsufficientMaterial)" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50" @onclick="ReserveMaterialsAsync">
                Reserve Materials
            </button>
            <button type="button" disabled="@(_formLocked || !CanSubmitForApproval)" class="rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700 disabled:opacity-50" @onclick="SubmitForApprovalAsync">
                Submit for Approval
            </button>
        </div>
    </footer>
</div>

@code {
    private sealed record MockMold(string Code, string Name, int CapacityPph);

    private sealed record InventoryRow(string Material, string Required, string Available, string StatusLabel, string BadgeClass);

    private static readonly List<MockMold> _molds =
    [
        new("MLD-001", "Bottle Mold A", 120),
        new("MLD-002", "Container Mold B", 80),
        new("MLD-003", "Cup Mold C", 200),
        new("MLD-004", "Box Mold D", 60),
        new("MLD-005", "Bag Mold E", 300)
    ];

    private static readonly List<InventoryRow> _inventoryRows =
    [
        new("PP Resin Grade A", "500 kg", "2500 kg", "OK", "bg-green-100 text-green-800"),
        new("PE Granules", "200 kg", "180 kg", "Low Stock", "bg-yellow-100 text-yellow-800"),
        new("PVC Compound", "150 kg", "50 kg", "Insufficient", "bg-red-100 text-red-800"),
        new("Color Masterbatch", "25 kg", "100 kg", "OK", "bg-green-100 text-green-800"),
        new("Additive Package", "10 kg", "45 kg", "OK", "bg-green-100 text-green-800")
    ];

    private string _planNo = string.Empty;
    private string _planName = string.Empty;
    private string _priority = "Medium";
    private Guid? _selectedMachineId;
    private string _plannedStart = string.Empty;
    private string _plannedEnd = string.Empty;
    private string _description = string.Empty;
    private int _estimatedQty;
    private string _selectedMoldCode = string.Empty;
    private int _setupTimeMinutes = 30;
    private bool _durationOverride;
    private double _overrideDurationHours;
    private string _overrideReason = string.Empty;
    private string _notes = string.Empty;
    private string _status = "Draft";

    private List<ApiMachineWithJob> _apiMachines = [];
    private bool _initialized;
    private string? _successMessage;
    private string? _successType;
    private readonly Dictionary<string, string> _errors = new();
    private CancellationTokenSource? _bannerCts;
    private bool _formLocked;
    private Guid? _savedPlanId;
    private string? _errorBanner;

    /// <summary>Hours from estimated quantity and selected mold throughput.</summary>
    private double CalculatedDurationHours =>
        _estimatedQty > 0 && !string.IsNullOrEmpty(_selectedMoldCode)
            ? _estimatedQty / (double)(_molds.FirstOrDefault(m => m.Code == _selectedMoldCode)?.CapacityPph ?? 1)
            : 0;

    /// <summary>Hours used for display when override is enabled.</summary>
    private double EffectiveDurationHours =>
        _durationOverride ? _overrideDurationHours : CalculatedDurationHours;

    private bool HasInsufficientMaterial =>
        _inventoryRows.Any(r => string.Equals(r.StatusLabel, "Insufficient", StringComparison.OrdinalIgnoreCase));

    private bool CanSubmitForApproval =>
        !string.IsNullOrWhiteSpace(_planName) && _selectedMachineId is not null
                                            && !string.IsNullOrWhiteSpace(_plannedStart) && !string.IsNullOrWhiteSpace(_plannedEnd);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;
        _initialized = true;
        await T.EnsureInitializedAsync().ConfigureAwait(false);
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        _planNo = GeneratePlanNo();
        var machinesRes = await Api.GetProductionMachinesAsync().ConfigureAwait(false);
        if (machinesRes.Error is null)
            _apiMachines = machinesRes.Data ?? [];
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    /// <summary>Generates a display-only plan number for draft UI.</summary>
    private static string GeneratePlanNo() =>
        $"PLAN-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1, 1000):D3}";

    private void OnMachineSelectChange(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        _selectedMachineId = Guid.TryParse(v, out var g) ? g : null;
        StateHasChanged();
    }

    private void OnPlannedStartChange(ChangeEventArgs e) =>
        _plannedStart = e.Value?.ToString() ?? string.Empty;

    private void OnPlannedEndChange(ChangeEventArgs e) =>
        _plannedEnd = e.Value?.ToString() ?? string.Empty;

    private async Task SaveDraftAsync()
    {
        _errors.Clear();
        _errorBanner = null;
        if (string.IsNullOrWhiteSpace(_planName))
            _errors["name"] = "Name is required.";
        if (string.IsNullOrWhiteSpace(_plannedStart))
            _errors["start"] = "Planned start is required.";
        if (string.IsNullOrWhiteSpace(_plannedEnd))
            _errors["end"] = "Planned end is required.";
        if (_errors.Count > 0)
        {
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            return;
        }
        if (_savedPlanId.HasValue)
        {
            await ShowBannerAsync("Plan already saved as draft.", "success").ConfigureAwait(false);
            return;
        }
        try
        {
            if (!await TryPersistPlanDraftAsync().ConfigureAwait(false))
                return;
            await ShowBannerAsync("Plan saved as draft.", "success").ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _errorBanner = ex.Message;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task ReserveMaterialsAsync()
    {
        await ShowBannerAsync("Reservation submitted (mock).", "warning").ConfigureAwait(false);
    }

    private async Task SubmitForApprovalAsync()
    {
        _errors.Clear();
        _errorBanner = null;
        if (string.IsNullOrWhiteSpace(_planName))
            _errors["name"] = "Name is required.";
        if (_selectedMachineId is null)
            _errors["machine"] = "Machine is required.";
        if (string.IsNullOrWhiteSpace(_plannedStart))
            _errors["start"] = "Planned start is required.";
        if (string.IsNullOrWhiteSpace(_plannedEnd))
            _errors["end"] = "Planned end is required.";
        if (_errors.Count > 0)
        {
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            return;
        }
        try
        {
            if (!_savedPlanId.HasValue && !await TryPersistPlanDraftAsync().ConfigureAwait(false))
                return;
            if (!_savedPlanId.HasValue)
            {
                _errorBanner = "Could not save plan before submit.";
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                return;
            }
            var put = await Api.PutPlanStatusAsync(
                _savedPlanId.Value,
                new UpdatePlanStatusDto("Submitted", null, null)).ConfigureAwait(false);
            if (put.Error is not null)
            {
                _errorBanner = put.Error;
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                return;
            }
            _status = "Submitted";
            _formLocked = true;
            await ShowBannerAsync("Plan submitted for approval.", "success").ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _errorBanner = ex.Message;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    /// <summary>Persists a new draft plan via POST /api/planning/plans when <see cref="_savedPlanId"/> is not set.</summary>
    private async Task<bool> TryPersistPlanDraftAsync()
    {
        try
        {
            var plannedStartAt = DateTimeOffset.Parse(
                $"{_plannedStart}T00:00:00Z",
                CultureInfo.InvariantCulture,
                DateTimeStyles.AssumeUniversal);
            var plannedEndAt = DateTimeOffset.Parse(
                $"{_plannedEnd}T23:59:59Z",
                CultureInfo.InvariantCulture,
                DateTimeStyles.AssumeUniversal);
            var dto = new CreatePlanDto(
                _planName.Trim(),
                string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
                _priority,
                plannedStartAt,
                plannedEndAt,
                null,
                null,
                string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim());
            var res = await Api.PostPlanAsync(dto).ConfigureAwait(false);
            if (res.Error is not null)
            {
                _errorBanner = res.Error;
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                return false;
            }
            if (res.Data is null)
            {
                _errorBanner = "Empty response from API.";
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                return false;
            }
            _savedPlanId = res.Data.Id;
            _planNo = res.Data.PlanNo;
            _status = res.Data.PlanStatus;
            _errorBanner = null;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            return true;
        }
        catch (Exception ex)
        {
            _errorBanner = ex.Message;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            return false;
        }
    }

    private async Task ShowBannerAsync(string message, string type)
    {
        _bannerCts?.Cancel();
        _bannerCts?.Dispose();
        _bannerCts = new CancellationTokenSource();
        _successMessage = message;
        _successType = type;
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        try
        {
            await Task.Delay(5000, _bannerCts.Token).ConfigureAwait(false);
            _successMessage = null;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        {
            // replaced by a newer banner
        }
    }

    private string BannerClass() =>
        _successType == "warning"
            ? "border-yellow-200 bg-yellow-50 text-yellow-800"
            : "border-green-200 bg-green-50 text-green-800";

    private static string GetStatusBadgeClass(string status) => status switch
    {
        var s when s.Equals("Submitted", StringComparison.OrdinalIgnoreCase) => "bg-blue-100 text-blue-800",
        var s when s.Equals("Approved", StringComparison.OrdinalIgnoreCase) => "bg-green-100 text-green-800",
        var s when s.Equals("Draft", StringComparison.OrdinalIgnoreCase) => "bg-slate-100 text-slate-600",
        _ => "bg-slate-100 text-slate-600"
    };

    public void Dispose()
    {
        _bannerCts?.Cancel();
        _bannerCts?.Dispose();
        _bannerCts = null;
    }
}
