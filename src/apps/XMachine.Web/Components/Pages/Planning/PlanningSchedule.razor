    private static string TabClass(bool active) =>
        active ? "border-b-2 border-slate-900 text-slate-900 font-medium" : "border-b-2 border-transparent text-slate-500 hover:text-slate-700";

    private async Task SetTabAsync(string tab)
    {
        _activeTab = tab;
        if (tab == "plans" && !_plansLoaded)
            await LoadPlansTabAsync();
        if (tab == "analytics" && !_analyticsLoaded)
            await LoadAnalyticsTabAsync();
        await InvokeAsync(StateHasChanged);
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(MachineIdFilter) && Guid.TryParse(MachineIdFilter, out _))
            _activeTab = "schedule";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;
        _initialized = true;
        await T.EnsureInitializedAsync();
        await InvokeAsync(StateHasChanged);

        var machinesTask = Api.GetProductionMachinesAsync();
        var slotsTask = Api.GetPlanningSlotsAsync();
        var activePlansTask = Api.GetPlanningActivePlansAsync();
        var summaryTask = Api.GetPlanningSummaryAsync();
        var alarmsTask = Api.GetAlarmsAsync();

        await Task.WhenAll(machinesTask, slotsTask, activePlansTask, summaryTask, alarmsTask).ConfigureAwait(false);

        var mr = await machinesTask.ConfigureAwait(false);
        var sr = await slotsTask.ConfigureAwait(false);
        var ar = await activePlansTask.ConfigureAwait(false);
        var sumr = await summaryTask.ConfigureAwait(false);
        var alr = await alarmsTask.ConfigureAwait(false);

        if (mr.Error is not null) _error = mr.Error;
        else _machines = mr.Data ?? [];
        if (sr.Error is not null) _error ??= sr.Error;
        else _allSlots = sr.Data ?? [];
        if (ar.Error is not null) _error ??= ar.Error;
        else _activePlans = ar.Data ?? [];
        if (sumr.Error is not null) _error ??= sumr.Error;
        else _summary = sumr.Data;
        if (alr.Error is not null) _error ??= alr.Error;
        else _activeAlarms = (alr.Data ?? []).Where(a => a.AckTime is null).ToList();

        InitMoveFormDefaults();
        _loadingSchedule = false;
        await InvokeAsync(StateHasChanged);
    }

    private void InitMoveFormDefaults()
    {
        if (_selectedSlot is null && _machines.Count > 0)
            _moveNewMachineIdString = _machines[0].Id.ToString();
        _moveNewDate = _selectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        _moveNewTime = "08:00";
    }

    private async Task LoadPlansTabAsync()
    {
        _loadingPlans = true;
        await InvokeAsync(StateHasChanged);
        var res = await Api.GetPlanningPlansAsync();
        _loadingPlans = false;
        if (res.Error is not null)
            _error = res.Error;
        else
            _allPlans = res.Data ?? [];
        _plansLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAnalyticsTabAsync()
    {
        _loadingAnalytics = true;
        await InvokeAsync(StateHasChanged);
        var d = await Api.GetDowntimesAsync();
        if (!_plansLoaded)
        {
            var p = await Api.GetPlanningPlansAsync();
            if (p.Error is null)
                _allPlans = p.Data ?? [];
            _plansLoaded = true;
        }
        _loadingAnalytics = false;
        if (d.Error is not null)
            _error ??= d.Error;
        else
            _downtimes = d.Data ?? [];
        _analyticsLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private IEnumerable<ApiMachineWithJob> FilteredScheduleMachines()
    {
        IEnumerable<ApiMachineWithJob> q = _machines.Where(MachineInGroup).OrderBy(m => m.Code);
        if (!string.IsNullOrWhiteSpace(MachineIdFilter) && Guid.TryParse(MachineIdFilter, out var gid))
            q = q.Where(m => m.Id == gid);
        return q;
    }

    private bool MachineInGroup(ApiMachineWithJob m) => _machineGroupFilter switch
    {
        "molding" => m.Code.StartsWith("M-1", StringComparison.OrdinalIgnoreCase),
        "assembly" => m.Code.StartsWith("M-2", StringComparison.OrdinalIgnoreCase),
        "qc" => m.Code.Contains("QC", StringComparison.OrdinalIgnoreCase) || m.Name.Contains("QC", StringComparison.OrdinalIgnoreCase),
        "packaging" => m.Code.Contains("PACK", StringComparison.OrdinalIgnoreCase) || m.Name.Contains("Pack", StringComparison.OrdinalIgnoreCase),
        _ => true,
    };

    private IEnumerable<ApiPlanSlot> GetSlotsForMachineOnDay(Guid machineId, DateOnly date) =>
        _allSlots.Where(s => s.MachineId == machineId && SlotOnDate(s, date)).OrderBy(s => s.PlannedStartAt);

    private IEnumerable<ApiPlanSlot> GetSlotsForMachineAndDate(Guid machineId, DateOnly date) =>
        GetSlotsForMachineOnDay(machineId, date);

    private IEnumerable<ApiPlanSlot> GetSlotsForMachineToday(Guid machineId) =>
        GetSlotsForMachineOnDay(machineId, DateOnly.FromDateTime(DateTime.UtcNow));

    private static bool SlotOnDate(ApiPlanSlot s, DateOnly d)
    {
        var start = s.PlannedStartAt.ToUniversalTime();
        var day = UtcDayStart(d);
        var dayEnd = day.AddDays(1);
        return start < dayEnd && s.PlannedEndAt.ToUniversalTime() > day;
    }

    private static DateTimeOffset UtcDayStart(DateOnly d) =>
        new(d.Year, d.Month, d.Day, 0, 0, 0, TimeSpan.Zero);

    private IEnumerable<DateOnly> GetWeekDays()
    {
        var monday = MondayOfWeekContaining(_selectedDate);
        for (var i = 0; i < 7; i++)
            yield return monday.AddDays(i);
    }

    private static DateOnly MondayOfWeekContaining(DateOnly d)
    {
        var day = d.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)d.DayOfWeek;
        var fromMon = day - (int)DayOfWeek.Monday;
        return d.AddDays(-fromMon);
    }

    private string GetWeekLabel()
    {
        var monday = MondayOfWeekContaining(_selectedDate);
        var sunday = monday.AddDays(6);
        var dt = monday.ToDateTime(TimeOnly.MinValue);
        var week = ISOWeek.GetWeekOfYear(dt);
        return $"Week {week.ToString(CultureInfo.InvariantCulture)} · {monday:MMM d} – {sunday:MMM d, yyyy}";
    }

    private bool IsSelectedTodayUtc() => _selectedDate == DateOnly.FromDateTime(DateTime.UtcNow);

    private void PrevPeriod()
    {
        if (_viewMode == "day")
            _selectedDate = _selectedDate.AddDays(-1);
        else
            _selectedDate = MondayOfWeekContaining(_selectedDate).AddDays(-7);
        StateHasChanged();
    }

    private void NextPeriod()
    {
        if (_viewMode == "day")
            _selectedDate = _selectedDate.AddDays(1);
        else
            _selectedDate = MondayOfWeekContaining(_selectedDate).AddDays(7);
        StateHasChanged();
    }

    private void GoToday()
    {
        _selectedDate = DateOnly.FromDateTime(DateTime.UtcNow);
        StateHasChanged();
    }

    private int CountMachines(string status) =>
        _machines.Count(m => string.Equals(m.OperationalStatus, status, StringComparison.OrdinalIgnoreCase));

    private int CountDownMachines() =>
        _machines.Count(m =>
            string.Equals(m.OperationalStatus, "Down", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(m.OperationalStatus, "PmDue", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(m.OperationalStatus, "WaitingParts", StringComparison.OrdinalIgnoreCase));

    private int PlanStatusCount(string status) => _allPlans.Count(p => string.Equals(p.PlanStatus, status, StringComparison.OrdinalIgnoreCase));

    /// <summary>Returns machines that have an active job with a positive planned quantity for analytics efficiency bars.</summary>
    private IEnumerable<ApiMachineWithJob> GetMachinesWithActiveJobs() =>
        _machines.Where(m => m.ActiveJob is { PlannedQty: > 0 }).OrderBy(m => m.Code);

    /// <summary>Top downtime reason codes by count with percentage of total downtime rows.</summary>
    private IEnumerable<(string Key, int Count, int Pct)> GetDowntimeTopGroups()
    {
        var total = _downtimes.Count;
        if (total == 0)
            return Enumerable.Empty<(string, int, int)>();
        return _downtimes
            .GroupBy(d => string.IsNullOrEmpty(d.DowntimeReasonCode) ? "(none)" : d.DowntimeReasonCode)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g =>
            {
                var c = g.Count();
                var p = (int)Math.Round(100.0 * c / total);
                return (g.Key, c, p);
            });
    }

    private string MachineLabel(Guid machineId)
    {
        var m = _machines.FirstOrDefault(x => x.Id == machineId);
        return m is null ? machineId.ToString("N")[..8] : $"{m.Code} · {m.Name}";
    }

    private string ResolvePlanNo(Guid planId)
    {
        var p = _activePlans.FirstOrDefault(x => x.Id == planId) ?? _allPlans.FirstOrDefault(x => x.Id == planId);
        return p?.PlanNo ?? planId.ToString("N")[..8];
    }

