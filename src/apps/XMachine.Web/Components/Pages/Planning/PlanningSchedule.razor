    private static string GetMachineStatusBorder(string op) => op switch
    {
        var s when s.Equals("Running", StringComparison.OrdinalIgnoreCase) => "border-l-4 border-l-green-500",
        var s when s.Equals("Idle", StringComparison.OrdinalIgnoreCase) => "border-l-4 border-l-yellow-500",
