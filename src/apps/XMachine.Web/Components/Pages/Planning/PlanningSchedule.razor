    private void OnMoveDateChange(ChangeEventArgs e) =>
        _moveNewDate = e.Value?.ToString() ?? string.Empty;

    private void OnMoveTimeChange(ChangeEventArgs e) =>
        _moveNewTime = e.Value?.ToString() ?? string.Empty;

    private void OnAddStartChange(ChangeEventArgs e) =>
        _addStart = e.Value?.ToString() ?? string.Empty;

    private void SubmitMoveSlotInMemory()
    {
        if (_selectedSlot is null) return;
        if (!DateOnly.TryParse(_moveNewDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d))
            return;
        if (!TimeOnly.TryParse(_moveNewTime, CultureInfo.InvariantCulture, DateTimeStyles.None, out var tm))
            return;
        if (!Guid.TryParse(_moveNewMachineIdString, out var mid))
            return;
        var newStart = new DateTimeOffset(d.ToDateTime(tm), TimeSpan.Zero);
        var duration = _selectedSlot.PlannedEndAt - _selectedSlot.PlannedStartAt;
        if (duration < TimeSpan.Zero) duration = TimeSpan.FromHours(1);
        var newEnd = newStart + duration;
        var idx = _allSlots.FindIndex(x => x.Id == _selectedSlot.Id);
        if (idx < 0) return;
        var updated = _selectedSlot with { PlannedStartAt = newStart, PlannedEndAt = newEnd, MachineId = mid };
        _allSlots[idx] = updated;
        _selectedSlot = updated;
        _moveSuccessMessage = "Slot moved (pending save)";
        _showMoveSlotModal = false;
        StateHasChanged();
    }

    private void OpenAddSlotModal()
    {
        _addSuccessMessage = null;
        _addPlanIdString = _activePlans.FirstOrDefault()?.Id.ToString() ?? string.Empty;
        _addMachineIdString = _machines.FirstOrDefault()?.Id.ToString() ?? string.Empty;
        var start = DateTimeOffset.UtcNow.AddHours(1);
        _addStart = start.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
        _showAddSlotModal = true;
        StateHasChanged();
    }

    private void CloseAddSlotModal()
    {
        _showAddSlotModal = false;
        StateHasChanged();
    }

    private void SubmitAddSlotInMemory()
    {
        if (!Guid.TryParse(_addPlanIdString, out var pid) || !Guid.TryParse(_addMachineIdString, out var mid))
            return;
        if (!DateTimeOffset.TryParse(_addStart, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var start))
            return;
        var end = start.AddMinutes(Math.Max(1, _addDuration));
        var slotNo = $"SLOT-NEW-{_allSlots.Count + 1:D3}";
        var slot = new ApiPlanSlot(
            Guid.NewGuid(),
            pid,
            mid,
            null,
            null,
            slotNo,
            "Scheduled",
            "Medium",
            Math.Max(1, _addQty),
            start,
            end,
            _addDuration,
            _addSetup > 0 ? _addSetup : null,
            string.IsNullOrWhiteSpace(_addNotes) ? null : _addNotes.Trim(),
            0,
            "Active",
            DateTimeOffset.UtcNow,
            DateTimeOffset.UtcNow,
            null,
            null);
        _allSlots.Add(slot);
        _addSuccessMessage = "Slot added (pending save)";
        _showAddSlotModal = false;
        StateHasChanged();
    }

    private async Task TogglePlanSlots(Guid planId)
    {
        if (_expandedPlanId == planId)
        {
            _expandedPlanId = null;
            _expandedPlanDetail = null;
            await InvokeAsync(StateHasChanged);
            return;
        }
        _expandedPlanId = planId;
        _loadingPlanDetail = true;
        await InvokeAsync(StateHasChanged);
        var res = await Api.GetPlanningPlanAsync(planId);
        _loadingPlanDetail = false;
        if (res.Error is not null)
            _error = res.Error;
        else
            _expandedPlanDetail = res.Data;
        await InvokeAsync(StateHasChanged);
    }
}
