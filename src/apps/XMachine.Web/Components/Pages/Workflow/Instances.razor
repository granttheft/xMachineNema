@page "/workflow/instances"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Workflow instances</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active">Workflow</li>
        <li class="breadcrumb-item active">Instances</li>
    </ol>
</nav>

<h1 class="h3 mb-3">Workflow instances</h1>
<p class="text-body-secondary small mb-3">Read-only view from <code>GET /api/workflow/instances</code> and <code>GET /api/workflow/summary</code>. · <a href="/workflow/definitions">Definitions</a></p>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <SummaryCard Title="Definitions" Value="@Fmt(_summary.Data?.Definitions)" Error="@_summary.Error" />
    <SummaryCard Title="Steps" Value="@Fmt(_summary.Data?.Steps)" Error="@_summary.Error" />
    <SummaryCard Title="Instances" Value="@Fmt(_summary.Data?.Instances)" Error="@_summary.Error" />
    <SummaryCard Title="Actions" Value="@Fmt(_summary.Data?.Actions)" Error="@_summary.Error" />
</div>

<ApiStateDisplay Loading="_loading" Error="_error">
    @if (_rows.Count == 0)
    {
        <p class="text-muted my-2">No workflow instances returned.</p>
    }
    else
    {
        <div class="table-responsive border rounded bg-white">
            <table class="table table-sm table-striped table-hover mb-0">
                <thead class="table-light">
                <tr>
                    <th>Reference</th>
                    <th>Definition</th>
                    <th>State</th>
                    <th>Started</th>
                    <th>Ended</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var r in _rows)
                {
                    <tr>
                        <td><span class="font-monospace small">@r.ReferenceType</span> · <span class="font-monospace small">@r.ReferenceId</span></td>
                        <td class="font-monospace small">@r.WorkflowDefinitionId</td>
                        <td>@WorkflowUi.InstanceStateLabel(r.WorkflowState)</td>
                        <td class="small">@(r.StartedAt is { } s ? s.UtcDateTime.ToString("yyyy-MM-dd HH:mm") + " UTC" : "—")</td>
                        <td class="small">@(r.EndedAt is { } e ? e.UtcDateTime.ToString("yyyy-MM-dd HH:mm") + " UTC" : "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</ApiStateDisplay>

@code {
    private bool _loading = true;
    private string? _error;
    private ApiFetch<WorkflowSummaryDto> _summary = ApiFetch<WorkflowSummaryDto>.InProgress();
    private IReadOnlyList<WorkflowInstanceRowDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var tSummary = Api.GetWorkflowSummaryAsync();
        var tInst = Api.GetWorkflowInstancesAsync();
        await Task.WhenAll(tSummary, tInst).ConfigureAwait(false);
        _summary = await tSummary.ConfigureAwait(false);
        var inst = await tInst.ConfigureAwait(false);
        _loading = false;
        _error = inst.Error;
        _rows = inst.Data ?? [];
    }

    private static string? Fmt(int? v) => v?.ToString();
}
