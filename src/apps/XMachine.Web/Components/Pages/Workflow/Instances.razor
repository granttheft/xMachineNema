@page "/workflow/instances"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Workflow instances</PageTitle>

<PageHeader Title="Workflow instances"
            Subtitle="Approval and control flows tied to business objects (orders, quality, and more). Read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Workflow</li>
                <li class="breadcrumb-item active">Instances</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<p class="small text-body-secondary mb-3">
    Related:
    <a href="/workflow/definitions" class="xm-inline-link">Workflow definitions</a>
</p>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <SummaryCard Title="Definitions" Value="@Fmt(_summary.Data?.Definitions)" Error="@_summary.Error" Accent="violet" />
    <SummaryCard Title="Steps" Value="@Fmt(_summary.Data?.Steps)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Instances" Value="@Fmt(_summary.Data?.Instances)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Actions" Value="@Fmt(_summary.Data?.Actions)" Error="@_summary.Error" Accent="emerald" />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No workflow instances returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Object type</th>
                        <th>Object ID</th>
                        <th>Workflow definition</th>
                        <th>Status</th>
                        <th>Started (UTC)</th>
                        <th>Finished (UTC)</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="small">@UiLabels.HumanizeToken(r.ReferenceType)</td>
                            <td class="font-monospace small">@r.ReferenceId</td>
                            <td class="font-monospace small">@r.WorkflowDefinitionId</td>
                            <td><StatusBadge Text="@UiLabels.WorkflowInstanceState(r.WorkflowState)" Tone="@UiLabels.WorkflowInstanceStateTone(r.WorkflowState)" /></td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.StartedAt)</td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.EndedAt)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private ApiFetch<WorkflowSummaryDto> _summary = ApiFetch<WorkflowSummaryDto>.InProgress();
    private IReadOnlyList<WorkflowInstanceRowDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var tSummary = Api.GetWorkflowSummaryAsync();
        var tInst = Api.GetWorkflowInstancesAsync();
        await Task.WhenAll(tSummary, tInst).ConfigureAwait(false);
        _summary = await tSummary.ConfigureAwait(false);
        var inst = await tInst.ConfigureAwait(false);
        _loading = false;
        if (inst.Error is not null)
            _error = inst.Error;
        else
        {
            _error = null;
            _rows = inst.Data ?? [];
        }
    }

    private static string? Fmt(int? v) => v?.ToString();
}
