@page "/workflow/instances"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Workflow instances</PageTitle>

<PageHeader Title="Workflow instances"
            Subtitle="Approval and control flows tied to business objects (orders, quality, and more). Read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Workflow</li>
                <li class="breadcrumb-item active">Instances</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<p class="small text-body-secondary mb-3">
    Related:
    <a href="/workflow/definitions" class="xm-inline-link">Workflow definitions</a>
</p>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <SummaryCard Title="Definitions" Value="@Fmt(_summary.Data?.Definitions)" Error="@_summary.Error" Accent="violet" />
    <SummaryCard Title="Steps" Value="@Fmt(_summary.Data?.Steps)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Instances" Value="@Fmt(_summary.Data?.Instances)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Actions" Value="@Fmt(_summary.Data?.Actions)" Error="@_summary.Error" Accent="emerald" />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No workflow instances returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Object type</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Object ID</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Workflow definition</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Started (UTC)</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Finished (UTC)</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _rows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(r.ReferenceType)</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.ReferenceId</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.WorkflowDefinitionId</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><StatusBadge Text="@UiLabels.WorkflowInstanceState(r.WorkflowState)" Tone="@UiLabels.WorkflowInstanceStateTone(r.WorkflowState)" /></td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-600">@UiFormats.UtcMinute(r.StartedAt)</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-600">@UiFormats.UtcMinute(r.EndedAt)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private ApiFetch<WorkflowSummaryDto> _summary = ApiFetch<WorkflowSummaryDto>.InProgress();
    private IReadOnlyList<WorkflowInstanceRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var tSummary = Api.GetWorkflowSummaryAsync();
        var tInst = Api.GetWorkflowInstancesAsync();
        await Task.WhenAll(tSummary, tInst);
        _summary = await tSummary;
        var inst = await tInst;
        _loading = false;
        if (inst.Error is not null)
            _error = inst.Error;
        else
        {
            _error = null;
            _rows = inst.Data ?? [];
        }

        StateHasChanged();
    }

    private static string? Fmt(int? v) => v?.ToString();
}
