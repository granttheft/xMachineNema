@page "/workflow/definitions"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Workflow definitions</PageTitle>

<PageHeader Title="Workflow definitions"
            Subtitle="Published workflow types and step counts · read-only from XMachine.Api (definitions + summary).">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Workflow</li>
                <li class="breadcrumb-item active">Definitions</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<p class="small text-body-secondary mb-3">
    Cross-link:
    <a href="/workflow/instances" class="xm-inline-link">Instances</a>
</p>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <SummaryCard Title="Definitions" Value="@Fmt(_summary.Data?.Definitions)" Error="@_summary.Error" Accent="violet" />
    <SummaryCard Title="Steps" Value="@Fmt(_summary.Data?.Steps)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Instances" Value="@Fmt(_summary.Data?.Instances)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Actions" Value="@Fmt(_summary.Data?.Actions)" Error="@_summary.Error" Accent="emerald" />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No workflow definitions returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Workflow type</th>
                        <th>Record</th>
                        <th class="text-end">Steps</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td>@r.Name</td>
                            <td class="small">@UiLabels.HumanizeToken(r.WorkflowType)</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                            <td class="text-end fw-semibold">@r.StepCount</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private ApiFetch<WorkflowSummaryDto> _summary = ApiFetch<WorkflowSummaryDto>.InProgress();
    private IReadOnlyList<WorkflowDefinitionRowDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var tSummary = Api.GetWorkflowSummaryAsync();
        var tDefs = Api.GetWorkflowDefinitionsAsync();
        await Task.WhenAll(tSummary, tDefs).ConfigureAwait(false);
        _summary = await tSummary.ConfigureAwait(false);
        var defs = await tDefs.ConfigureAwait(false);
        _loading = false;
        if (defs.Error is not null)
            _error = defs.Error;
        else
        {
            _error = null;
            _rows = defs.Data ?? [];
        }
    }

    private static string? Fmt(int? v) => v?.ToString();
}
