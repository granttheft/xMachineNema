@page "/workflow/definitions"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Workflow definitions</PageTitle>

<PageHeader Title="Workflow definitions"
            Subtitle="Published workflow types and step counts · read-only from XMachine.Api (definitions + summary).">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Workflow</li>
                <li class="breadcrumb-item active">Definitions</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<p class="small text-body-secondary mb-3">
    Cross-link:
    <a href="/workflow/instances" class="xm-inline-link">Instances</a>
</p>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <SummaryCard Title="Definitions" Value="@Fmt(_summary.Data?.Definitions)" Error="@_summary.Error" Accent="violet" />
    <SummaryCard Title="Steps" Value="@Fmt(_summary.Data?.Steps)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Instances" Value="@Fmt(_summary.Data?.Instances)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Actions" Value="@Fmt(_summary.Data?.Actions)" Error="@_summary.Error" Accent="emerald" />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No workflow definitions returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Workflow type</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                            <th class="whitespace-nowrap px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Steps</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _rows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3 text-sm text-slate-700">@r.Name</td>
                                <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(r.WorkflowType)</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                                <td class="whitespace-nowrap px-4 py-3 text-right text-sm font-semibold tabular-nums text-slate-900">@r.StepCount</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private ApiFetch<WorkflowSummaryDto> _summary = ApiFetch<WorkflowSummaryDto>.InProgress();
    private IReadOnlyList<WorkflowDefinitionRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var tSummary = Api.GetWorkflowSummaryAsync();
        var tDefs = Api.GetWorkflowDefinitionsAsync();
        await Task.WhenAll(tSummary, tDefs);
        _summary = await tSummary;
        var defs = await tDefs;
        _loading = false;
        if (defs.Error is not null)
            _error = defs.Error;
        else
        {
            _error = null;
            _rows = defs.Data ?? [];
        }

        StateHasChanged();
    }

    private static string? Fmt(int? v) => v?.ToString();
}
