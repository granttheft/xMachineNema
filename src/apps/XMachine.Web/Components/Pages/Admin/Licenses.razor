@page "/admin/licenses"
@attribute [Authorize(Policy = AuthPolicies.AdminArea)]
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Licenses</PageTitle>

<PageHeader Title="Licenses"
            Subtitle="Commercial modules, activations, license rows, and line entitlements · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Admin</li>
                <li class="breadcrumb-item active">Licenses</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

@if (_aggregateError is not null)
{
    <div class="xm-api-error mb-4" role="alert">@_aggregateError</div>
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 mb-4">
    <SummaryCard Title="Licenses" Value="@Fmt(_summary.Data?.Licenses)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Module catalog" Value="@Fmt(_summary.Data?.Modules)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Module activations" Value="@Fmt(_summary.Data?.ModuleActivations)" Error="@_summary.Error" Accent="emerald" />
    <SummaryCard Title="Licensed lines" Value="@Fmt(_summary.Data?.LicensedLines)" Error="@_summary.Error" Accent="violet" />
</div>

<DataPanel Title="Licenses">
    <ApiStateDisplay Loading="_loadingLicenses" Error="_errLicenses">
        @if (_licenses.Count == 0)
        {
            <EmptyState Message="No license rows returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Tenant id</th>
                        <th>Type</th>
                        <th>Valid from</th>
                        <th>Valid to</th>
                        <th>Record</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _licenses)
                    {
                        <tr>
                            <td class="small font-monospace">@r.TenantId</td>
                            <td><StatusBadge Text="@LicenseTypeLabel(r.LicenseType)" Tone="@StatusBadgeTone.Info" /></td>
                            <td class="small text-nowrap">@FmtDate(r.ValidFrom)</td>
                            <td class="small text-nowrap">@FmtDate(r.ValidTo)</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

<div class="mt-4">
<DataPanel Title="Module catalog">
    <ApiStateDisplay Loading="_loadingModules" Error="_errModules">
        @if (_modules.Count == 0)
        {
            <EmptyState Message="No modules in catalog." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _modules)
                    {
                        <tr>
                            <td class="font-monospace small">@r.Code</td>
                            <td>@r.Name</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>
</div>

<div class="mt-4">
<DataPanel Title="Module activations">
    <ApiStateDisplay Loading="_loadingActivations" Error="_errActivations">
        @if (_activations.Count == 0)
        {
            <EmptyState Message="No module activations returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Tenant id</th>
                        <th>Module</th>
                        <th>Activated</th>
                        <th>Record</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _activations)
                    {
                        <tr>
                            <td class="small font-monospace">@r.TenantId</td>
                            <td><span class="font-monospace small">@r.ModuleCode</span> · @r.ModuleName</td>
                            <td class="small text-nowrap">@r.ActivatedAt.ToString("u")</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>
</div>

<div class="mt-4">
<DataPanel Title="Licensed lines">
    <ApiStateDisplay Loading="_loadingLicensedLines" Error="_errLicensedLines">
        @if (_licensedLines.Count == 0)
        {
            <EmptyState Message="No licensed lines returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Tenant id</th>
                        <th>Line</th>
                        <th>Record</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _licensedLines)
                    {
                        <tr>
                            <td class="small font-monospace">@r.TenantId</td>
                            <td><span class="font-monospace small">@r.LineCode</span> · @r.LineName</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>
</div>

@code {
    private ApiFetch<CommercialSummaryDto> _summary = ApiFetch<CommercialSummaryDto>.InProgress();
    private bool _loadingLicenses = true;
    private bool _loadingModules = true;
    private bool _loadingActivations = true;
    private bool _loadingLicensedLines = true;
    private string? _errLicenses;
    private string? _errModules;
    private string? _errActivations;
    private string? _errLicensedLines;
    private IReadOnlyList<LicenseRowDto> _licenses = [];
    private IReadOnlyList<CommercialModuleRowDto> _modules = [];
    private IReadOnlyList<ModuleActivationRowDto> _activations = [];
    private IReadOnlyList<LicensedLineRowDto> _licensedLines = [];
    private string? _aggregateError;

    protected override async Task OnInitializedAsync()
    {
        var tSummary = Api.GetCommercialSummaryAsync();
        var tLicenses = Api.GetCommercialLicensesAsync();
        var tModules = Api.GetCommercialModulesAsync();
        var tAct = Api.GetCommercialModuleActivationsAsync();
        var tLines = Api.GetCommercialLicensedLinesAsync();
        await Task.WhenAll(tSummary, tLicenses, tModules, tAct, tLines).ConfigureAwait(false);
        _summary = await tSummary.ConfigureAwait(false);
        var fLic = await tLicenses.ConfigureAwait(false);
        var fMod = await tModules.ConfigureAwait(false);
        var fAct = await tAct.ConfigureAwait(false);
        var fLl = await tLines.ConfigureAwait(false);

        _loadingLicenses = _loadingModules = _loadingActivations = _loadingLicensedLines = false;
        _errLicenses = fLic.Error;
        _errModules = fMod.Error;
        _errActivations = fAct.Error;
        _errLicensedLines = fLl.Error;
        _licenses = fLic.Data ?? [];
        _modules = fMod.Data ?? [];
        _activations = fAct.Data ?? [];
        _licensedLines = fLl.Data ?? [];

        if (_summary.Error is not null && _errLicenses is not null && _errModules is not null && _errActivations is not null && _errLicensedLines is not null)
            _aggregateError = "Could not reach the API. Check XMachine:Api:BaseUrl and that XMachine.Api is running.";
    }

    private static string? Fmt(int? v) => v?.ToString();

    private static string? FmtDate(DateTimeOffset? v) => v?.ToString("yyyy-MM-dd");

    private static string LicenseTypeLabel(string? v) => v switch
    {
        "Trial" => "Trial",
        "Subscription" => "Subscription",
        "Offline" => "Offline",
        null or "" => "—",
        _ => v,
    };
}
