@page "/admin/tenants"
@attribute [Authorize(Policy = AuthPolicies.AdminArea)]
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Tenants</PageTitle>

<PageHeader Title="Tenants"
            Subtitle="Platform directory and topology counts · read-only snapshot from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Admin</li>
                <li class="breadcrumb-item active">Tenants</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

@if (_aggregateError is not null)
{
    <div class="xm-api-error mb-4" role="alert">@_aggregateError</div>
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 mb-3">
    <SummaryCard Title="Tenants" Value="@Fmt(_summary.Data?.Tenants)" Error="@_summary.Error" Accent="sky" />
    <SummaryCard Title="Sites" Value="@Fmt(_summary.Data?.Sites)" Error="@_summary.Error" Accent="emerald" />
    <SummaryCard Title="Lines" Value="@Fmt(_summary.Data?.Lines)" Error="@_summary.Error" Accent="cyan" />
    <SummaryCard Title="Machines" Value="@Fmt(_summary.Data?.Machines)" Error="@_summary.Error" Accent="violet" />
</div>
<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 mb-4">
    <SummaryCard Title="Enterprises" Value="@Fmt(_summary.Data?.Enterprises)" Error="@_summary.Error" Accent="slate" />
    <SummaryCard Title="Buildings" Value="@Fmt(_summary.Data?.Buildings)" Error="@_summary.Error" Accent="amber" />
    <SummaryCard Title="Stations" Value="@Fmt(_summary.Data?.Stations)" Error="@_summary.Error" Accent="rose" />
</div>

<DataPanel Title="Tenant directory">
    <ApiStateDisplay Loading="_loadingTenants" Error="_errTenants">
        @if (_tenants.Count == 0)
        {
            <EmptyState Message="No tenants returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th class="text-end">Sites</th>
                        <th class="text-end">Lines</th>
                        <th class="text-end">Machines</th>
                        <th>Record</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in _tenants)
                    {
                        <tr>
                            <td class="font-monospace small">@r.Code</td>
                            <td>@r.Name</td>
                            <td class="text-end">@r.SiteCount</td>
                            <td class="text-end">@r.LineCount</td>
                            <td class="text-end">@r.MachineCount</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private ApiFetch<PlatformSummaryDto> _summary = ApiFetch<PlatformSummaryDto>.InProgress();
    private bool _loadingTenants = true;
    private string? _errTenants;
    private IReadOnlyList<PlatformTenantRowDto> _tenants = [];
    private string? _aggregateError;

    protected override async Task OnInitializedAsync()
    {
        var tSummary = Api.GetPlatformSummaryAsync();
        var tTenants = Api.GetPlatformTenantsAsync();
        await Task.WhenAll(tSummary, tTenants).ConfigureAwait(false);
        _summary = await tSummary.ConfigureAwait(false);
        var tenantsFetch = await tTenants.ConfigureAwait(false);
        _loadingTenants = false;
        _errTenants = tenantsFetch.Error;
        _tenants = tenantsFetch.Data ?? [];

        if (_summary.Error is not null && _errTenants is not null)
            _aggregateError = "Could not reach the API. Check XMachine:Api:BaseUrl and that XMachine.Api is running.";
    }

    private static string? Fmt(int? v) => v?.ToString();
}
