@page "/mes/recipes"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Recipes</PageTitle>

<PageHeader Title="Recipes"
            Subtitle="Master recipes and revisions · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">MES</li>
                <li class="breadcrumb-item active">Recipes</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No recipes returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Code</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Version</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _rows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@r.Code</td>
                                <td class="px-4 py-3 text-sm text-slate-700">@r.Name</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm tabular-nums text-slate-700">@r.Version</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<RecipeRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetRecipesAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _rows = res.Data ?? [];
        }

        StateHasChanged();
    }
}
