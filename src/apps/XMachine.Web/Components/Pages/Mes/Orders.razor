@page "/mes/orders"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Production orders</PageTitle>

<PageHeader Title="Production orders"
            Subtitle="Manufacturing execution · read-only list from the operational API.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">MES</li>
                <li class="breadcrumb-item active">Orders</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No production orders returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Order</th><th>Product</th><th>Order status</th><th>Qty planned</th><th>Qty done</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="font-monospace small">@r.OrderNo</td>
                            <td>@r.ProductCode</td>
                            <td><StatusBadge Text="@UiLabels.ProductionOrderStatus(r.OrderStatus)" Tone="@UiLabels.ProductionOrderStatusTone(r.OrderStatus)" /></td>
                            <td>@r.QuantityPlanned</td>
                            <td>@r.QuantityCompleted</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<ProductionOrderRowDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetProductionOrdersAsync().ConfigureAwait(false);
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
            _rows = res.Data ?? [];
    }
}
