@page "/mes/shifts"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Shifts</PageTitle>

<PageHeader Title="Shifts"
            Subtitle="Shift patterns and calendar · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">MES</li>
                <li class="breadcrumb-item active">Shifts</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No shifts returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Shift date</th><th>Shift window</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="font-monospace small">@r.Code</td>
                            <td>@r.Name</td>
                            <td class="text-nowrap">@r.ShiftDate</td>
                            <td><StatusBadge Text="@UiLabels.WorkShiftLifecycle(r.Lifecycle)" Tone="@UiLabels.WorkShiftLifecycleTone(r.Lifecycle)" /></td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<ShiftRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetShiftsAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _rows = res.Data ?? [];
        }

        StateHasChanged();
    }
}
