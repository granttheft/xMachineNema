@page "/mes/lots"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Lots</PageTitle>

<PageHeader Title="Lots / batches"
            Subtitle="Lot genealogy and quantities · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">MES</li>
                <li class="breadcrumb-item active">Lots</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No lots or batches returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Lot</th><th>Production order</th><th>Lot status</th><th>Good qty</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="font-monospace small">@r.LotNo</td>
                            <td class="small font-monospace">@r.ProductionOrderId</td>
                            <td><StatusBadge Text="@UiLabels.LotBatchStatus(r.LotStatus)" Tone="@UiLabels.LotBatchStatusTone(r.LotStatus)" /></td>
                            <td>@r.QuantityGood</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<LotRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetLotsAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _rows = res.Data ?? [];
        }

        StateHasChanged();
    }
}
