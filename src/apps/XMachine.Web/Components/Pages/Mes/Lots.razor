@page "/mes/lots"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Lots</PageTitle>
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active">MES</li>
        <li class="breadcrumb-item active">Lots</li>
    </ol>
</nav>
<h1 class="h3 mb-3">Lots / batches</h1>
<div class="mb-3"><input class="form-control form-control-sm" style="max-width:20rem" placeholder="Filter (placeholder)" disabled /></div>
<ApiStateDisplay Loading="_loading" Error="_error">
    <div class="table-responsive border rounded bg-white">
        <table class="table table-sm table-striped mb-0">
            <thead class="table-light"><tr><th>Lot</th><th>Order id</th><th>Lot status</th><th>Good qty</th></tr></thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr><td class="font-monospace small">@r.LotNo</td><td class="small">@r.ProductionOrderId</td><td>@r.LotStatus</td><td>@r.QuantityGood</td></tr>
            }
            </tbody>
        </table>
    </div>
</ApiStateDisplay>
@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<LotRowDto> _rows = [];
    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetLotsAsync().ConfigureAwait(false);
        _loading = false;
        _error = res.Error;
        _rows = res.Data ?? [];
    }
}
