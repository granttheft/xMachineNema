@page "/monitoring/live"
@rendermode InteractiveServer
@implements IDisposable
@using System.Globalization
@using XMachine.Web.Services
@inject XMachineApiClient Api
@inject ITranslationService T
@inject XMachineHubClient Hub

<PageTitle>@T["page.live_monitoring.title"]</PageTitle>

<div class="min-h-screen bg-slate-50">
    <div class="border-b border-slate-200 bg-white px-6 py-4">
        <nav class="mb-2 text-xs text-slate-500" aria-label="breadcrumb">
            <a href="/dashboard" class="text-blue-600 hover:underline">Dashboard</a>
            <span class="mx-1">/</span>
            <span>Monitoring</span>
            <span class="mx-1">/</span>
            <span class="text-slate-800">@T["nav.live_monitoring"]</span>
        </nav>
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="min-w-0">
                <h1 class="text-2xl font-semibold text-slate-900">@T["page.live_monitoring.title"]</h1>
                <p class="mt-1 text-sm text-slate-600">@T["page.live_monitoring.subtitle"]</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <button type="button"
                        class="inline-flex items-center gap-2 rounded-lg border border-red-300 text-red-700 hover:bg-red-50 px-4 py-2 text-sm font-medium"
                        @onclick="@(() => { _showDowntimeModal = true; _downtimeError = null; StateHasChanged(); })">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                        <path d="M12 9v4" />
                        <path d="M12 17h.01" />
                    </svg>
                    @T["action.report_downtime"]
                </button>
                @if (Hub.IsConnected)
                {
                    <span class="inline-flex h-5 shrink-0 items-center gap-1.5 rounded-full bg-green-100 px-2 text-xs font-medium text-green-700" title="SignalR">
                        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-600"></span>
                        @T["page.live_monitoring.hub_live"]
                    </span>
                }
                else
                {
                    <span class="inline-flex h-5 shrink-0 items-center gap-1.5 rounded-full bg-orange-100 px-2 text-xs font-medium text-orange-700" title="SignalR">
                        <span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span>
                        @T["page.live_monitoring.hub_reconnecting"]
                    </span>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="border-b border-green-200 bg-green-50 px-6 py-2 text-sm text-green-800">@_successMessage</div>
    }

    <div class="mx-auto max-w-7xl space-y-6 p-6">
        <!-- KPI strip -->
        <div class="grid grid-cols-2 gap-3 lg:grid-cols-4 xl:grid-cols-8">
            @foreach (var k in BuildKpis())
            {
                <div class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm">
                    <div class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">@k.Title</div>
                    @if (k.Loading)
                    {
                        <div class="mt-2 h-8 animate-pulse rounded bg-slate-100"></div>
                    }
                    else if (!string.IsNullOrEmpty(k.Err))
                    {
                        <div class="mt-2 text-xs text-red-600">@T["common.error"]</div>
                    }
                    else
                    {
                        <div class="mt-1 text-xl font-bold tabular-nums text-slate-900">@k.Value</div>
                    }
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_summaryErr))
        {
            <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-900">@T["page.live_monitoring.summary_eventing"]: @_summaryErr</div>
        }

        <!-- Active alarms -->
        <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
                <h2 class="text-sm font-semibold text-slate-900">@T["page.live_monitoring.section_alarms"]</h2>
            </div>
            <div class="p-4">
                @if (_loadAlarms)
                {
                    <div class="h-32 animate-pulse rounded-lg bg-slate-100"></div>
                }
                else if (!string.IsNullOrEmpty(_alarmsErr))
                {
                    <p class="text-sm text-red-700">@_alarmsErr</p>
                }
                else if (_activeAlarms.Count == 0)
                {
                    <p class="text-sm text-slate-600">@T["page.live_monitoring.no_active_alarms"]</p>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_machine"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_code"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_message"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_severity"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_triggered"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_status"]</th>
                                <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">@T["common.actions"]</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                            @foreach (var a in _activeAlarms)
                            {
                                <tr class="hover:bg-slate-50">
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-800">@MachineLabel(a.MachineId)</td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm font-mono text-slate-700">@a.AlarmCode</td>
                                    <td class="max-w-xs truncate px-4 py-2 text-sm text-slate-700" title="@a.AlarmText">@a.AlarmText</td>
                                    <td class="px-4 py-2 text-sm"><span class="@SeverityBadgeClass(a.Severity) rounded-md px-2 py-0.5 text-xs font-medium">@a.Severity</span></td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-600">@FormatUtc(a.StartTime)</td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-700">@a.AlarmStatus</td>
                                    <td class="whitespace-nowrap px-4 py-2 text-right text-sm">
                                        @if (!string.Equals(a.AlarmStatus, "Acknowledged", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button type="button"
                                                    class="text-xs px-2 py-1 rounded border border-blue-300 text-blue-700 hover:bg-blue-50"
                                                    @onclick="@(() => AckAlarmAsync(a.Id))">
                                                @T["action.acknowledge"]
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-xs text-slate-500">@T["action.acknowledged"]</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    @if (!string.IsNullOrEmpty(_alarmAckError))
                    {
                        <p class="mt-2 text-xs text-red-600">@_alarmAckError</p>
                    }
                }
            </div>
        </section>

        <!-- Downtimes today -->
        <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
                <h2 class="text-sm font-semibold text-slate-900">@T["page.live_monitoring.section_downtimes"]</h2>
            </div>
            <div class="p-4">
                @if (_loadDowntimes)
                {
                    <div class="h-32 animate-pulse rounded-lg bg-slate-100"></div>
                }
                else if (!string.IsNullOrEmpty(_downtimesErr))
                {
                    <p class="text-sm text-red-700">@_downtimesErr</p>
                }
                else if (_downtimesToday.Count == 0)
                {
                    <p class="text-sm text-slate-600">@T["page.live_monitoring.no_downtime_today"]</p>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_machine"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_reason"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_started"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_duration"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">@T["page.live_monitoring.col_status"]</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                            @foreach (var d in _downtimesToday)
                            {
                                <tr class="hover:bg-slate-50">
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-800">@MachineLabel(d.MachineId)</td>
                                    <td class="px-4 py-2 text-sm text-slate-700">@(string.IsNullOrEmpty(d.DowntimeReasonText) ? d.DowntimeReasonCode : d.DowntimeReasonText)</td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-600">@FormatUtc(d.StartTime)</td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-700">
                                        @if (d.EndTime is null)
                                        {
                                            <span class="inline-flex items-center gap-1 rounded-md bg-orange-100 px-2 py-0.5 text-xs font-medium text-orange-800">
                                                <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-orange-500"></span>
                                                @T["page.live_monitoring.ongoing"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span>@FormatDowntimeMinutes(d)</span>
                                        }
                                    </td>
                                    <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-700">@d.Status</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        <!-- OEE by machine -->
        <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
                <h2 class="text-sm font-semibold text-slate-900">@T["page.live_monitoring.section_oee"]</h2>
            </div>
            <div class="p-4">
                @if (_loadOee || _loadMachines)
                {
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                        @for (var i = 0; i < 6; i++)
                        {
                            <div class="h-24 animate-pulse rounded-lg bg-slate-100"></div>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(_oeeErr) && _latestOeeByMachine.Count == 0)
                {
                    <p class="text-sm text-red-700">@_oeeErr</p>
                }
                else if (_oeeMachineTiles.Count == 0)
                {
                    <p class="text-sm text-slate-600">@T["page.live_monitoring.no_oee"]</p>
                }
                else
                {
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                        @foreach (var t in _oeeMachineTiles)
                        {
                            <div class="rounded-lg border border-slate-200 p-4">
                                <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">@t.MachineLabel</div>
                                @if (t.Snapshot is null)
                                {
                                    <div class="mt-2 text-sm text-slate-500">@T["page.live_monitoring.no_oee_data"]</div>
                                }
                                else
                                {
                                    <div class="mt-2 grid grid-cols-2 gap-2 text-sm">
                                        <div><span class="text-slate-500">A</span> <span class="font-medium @OeeTextClass(t.Snapshot.Availability)">@Pct(t.Snapshot.Availability)</span></div>
                                        <div><span class="text-slate-500">P</span> <span class="font-medium @OeeTextClass(t.Snapshot.Performance)">@Pct(t.Snapshot.Performance)</span></div>
                                        <div><span class="text-slate-500">Q</span> <span class="font-medium @OeeTextClass(t.Snapshot.Quality)">@Pct(t.Snapshot.Quality)</span></div>
                                        <div><span class="text-slate-500">OEE</span> <span class="font-semibold @OeeTextClass(t.Snapshot.OeeValue)">@Pct(t.Snapshot.OeeValue)</span></div>
                                    </div>
                                    <div class="mt-1 text-xs text-slate-400">@FormatUtc(t.Snapshot.PeriodStart)</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@if (_showDowntimeModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" @onclick="OnDowntimeBackdropClick">
        <div class="max-w-lg w-full rounded-lg border border-slate-200 bg-white p-6 shadow-lg mx-4" @onclick:stopPropagation="true">
            <h3 class="text-lg font-semibold text-slate-900">@T["modal.downtime.title"]</h3>
            <div class="mt-4 space-y-4">
                <div>
                    <label class="block text-xs font-medium text-slate-600">@T["modal.downtime.machine"]</label>
                    @if (_machines.Count > 0)
                    {
                        <select class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"
                                value="@DowntimeMachineSelectValue"
                                @onchange="OnDowntimeMachineSelectChanged">
                            <option value="">—</option>
                            @foreach (var m in _machines.OrderBy(x => x.Code))
                            {
                                <option value="@m.Id">@m.Code · @m.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"
                               placeholder="Machine name"
                               @bind="_downtimeMachineNameFallback" />
                    }
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-600">@T["modal.downtime.reason_code"]</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" @bind="_downtimeReasonCode">
                        <option value="">—</option>
                        @foreach (var r in DowntimeReasonOptions)
                        {
                            <option value="@r.Code">@r.Code — @r.Label</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-600">@T["modal.downtime.reason_text"]</label>
                    <textarea rows="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" @bind="_downtimeReasonText"></textarea>
                </div>
                <label class="flex items-center gap-2 text-sm text-slate-700">
                    <input type="checkbox" class="rounded border-slate-300" @bind="_downtimePlanned" />
                    @T["modal.downtime.planned"]
                </label>
                <p class="text-xs text-slate-500">The downtime will be recorded as ongoing. End time is set when the machine resumes.</p>
                @if (!string.IsNullOrEmpty(_downtimeError))
                {
                    <p class="text-sm text-red-600">@_downtimeError</p>
                }
            </div>
            <div class="mt-6 flex justify-end gap-2">
                <button type="button" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                        @onclick="CloseDowntimeModal" disabled="@_downtimeSaving">
                    @T["common.cancel"]
                </button>
                <button type="button" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 disabled:opacity-50"
                        @onclick="SubmitDowntimeAsync" disabled="@_downtimeSaving">
                    @T["action.report_downtime"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly (string Code, string Label)[] DowntimeReasonOptions =
    [
        ("MECH_FAIL", "Mechanical Failure"),
        ("ELEC_FAIL", "Electrical Failure"),
        ("MATERIAL", "Material Shortage"),
        ("QUALITY", "Quality Issue"),
        ("SETUP", "Setup / Changeover"),
        ("PLANNED", "Planned Maintenance"),
        ("OPERATOR", "Operator Issue"),
        ("OTHER", "Other"),
    ];

    private bool _showDowntimeModal;
    private Guid? _downtimeMachineId;
    private string _downtimeMachineNameFallback = string.Empty;
    private string _downtimeReasonCode = string.Empty;
    private string _downtimeReasonText = string.Empty;
    private bool _downtimePlanned;
    private bool _downtimeSaving;
    private string? _downtimeError;
    private string? _alarmAckError;
    private string? _successMessage;
    private CancellationTokenSource? _successBannerCts;

    private bool _loadSummary = true;
    private bool _loadMachines = true;
    private bool _loadAlarms = true;
    private bool _loadDowntimes = true;
    private bool _loadOee = true;

    private string? _summaryErr;
    private string? _machinesErr;
    private string? _alarmsErr;
    private string? _downtimesErr;
    private string? _oeeErr;

    private EventingSummaryDto? _summary;
    private List<ApiMachineWithJob> _machines = [];
    private List<AlarmRowDto> _allAlarms = [];
    private List<DowntimeRowDto> _allDowntimes = [];
    private List<OeeRowDto> _allOee = [];

    private IReadOnlyList<AlarmRowDto> _activeAlarms = [];
    private IReadOnlyList<DowntimeRowDto> _downtimesToday = [];
    private Dictionary<Guid, OeeRowDto> _latestOeeByMachine = new();
    private IReadOnlyList<OeeMachineTileVm> _oeeMachineTiles = [];

    private int? _activeAlarmCount;
    private int? _downtimeTodayMinutes;
    private decimal? _avgOeePct;
    private int? _runCount;
    private int? _pausedCount;
    private int? _idleCount;
    private int? _downCount;

    private Dictionary<Guid, string> _machineLabels = new();

    private bool _hubHandlersAttached;

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await T.EnsureInitializedAsync();
        await InvokeAsync(StateHasChanged);

        await LoadSummaryAsync();
        await LoadMachinesAsync();
        await LoadAlarmsAsync();
        await LoadDowntimesAsync();
        await LoadOeeAsync();
        RebuildDerived();
        await InvokeAsync(StateHasChanged);

        AttachHubHandlers();
    }

    /// <inheritdoc />
    void IDisposable.Dispose()
    {
        DetachHubHandlers();
        try
        {
            _successBannerCts?.Cancel();
        }
        catch
        {
            // ignored
        }

        _successBannerCts?.Dispose();
        _successBannerCts = null;
    }

    private string DowntimeMachineSelectValue => _downtimeMachineId?.ToString() ?? string.Empty;

    private void OnDowntimeMachineSelectChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        _downtimeMachineId = Guid.TryParse(s, out var g) ? g : null;
    }

    private void OnDowntimeBackdropClick()
    {
        CloseDowntimeModal();
    }

    private void CloseDowntimeModal()
    {
        if (_downtimeSaving)
            return;
        _showDowntimeModal = false;
        _downtimeError = null;
    }

    private void QueueSuccessBannerAutoClear()
    {
        try
        {
            _successBannerCts?.Cancel();
        }
        catch
        {
            // ignored
        }

        _successBannerCts?.Dispose();
        _successBannerCts = new CancellationTokenSource();
        var token = _successBannerCts.Token;
        _ = ClearSuccessBannerAfterDelayAsync(token);
    }

    private async Task ClearSuccessBannerAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(3000, cancellationToken).ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _successMessage = null;
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private void ResetDowntimeForm()
    {
        _downtimeMachineId = null;
        _downtimeMachineNameFallback = string.Empty;
        _downtimeReasonCode = string.Empty;
        _downtimeReasonText = string.Empty;
        _downtimePlanned = false;
        _downtimeError = null;
    }

    private async Task AckAlarmAsync(Guid alarmId)
    {
        _alarmAckError = null;
        await InvokeAsync(StateHasChanged);

        var (ok, err) = await Api.AcknowledgeAlarmAsync(alarmId, new AcknowledgeAlarmDto(null));
        if (!ok)
        {
            _alarmAckError = err ?? "Failed to acknowledge alarm.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        await LoadAlarmsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SubmitDowntimeAsync()
    {
        if (string.IsNullOrWhiteSpace(_downtimeReasonCode))
        {
            _downtimeError = "Reason code is required.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _downtimeError = null;
        _downtimeSaving = true;
        await InvokeAsync(StateHasChanged);

        var (ok, err) = await Api.PostDowntimeAsync(new CreateDowntimeDto(
            _downtimeMachineId,
            null,
            null,
            _downtimeReasonCode.Trim(),
            string.IsNullOrWhiteSpace(_downtimeReasonText) ? null : _downtimeReasonText.Trim(),
            _downtimePlanned));

        _downtimeSaving = false;
        if (!ok)
        {
            _downtimeError = err ?? "Failed to report downtime.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _showDowntimeModal = false;
        ResetDowntimeForm();
        var downtimes = await Api.GetDowntimesAsync();
        _allDowntimes = downtimes.Data ?? [];
        if (downtimes.Error is not null)
            _downtimesErr = downtimes.Error;
        RebuildDerived();
        _successMessage = "Downtime reported successfully.";
        QueueSuccessBannerAutoClear();
        await InvokeAsync(StateHasChanged);
    }

    private void AttachHubHandlers()
    {
        if (_hubHandlersAttached)
            return;
        _hubHandlersAttached = true;
        Hub.OnMachineStatusChanged += HandleMachineStatusChanged;
        Hub.OnJobStatusChanged += HandleJobStatusChanged;
        Hub.OnAlarmTriggered += HandleAlarmTriggered;
        Hub.ConnectionStateChanged += HandleHubConnectionStateChanged;
    }

    private void DetachHubHandlers()
    {
        if (!_hubHandlersAttached)
            return;
        Hub.OnMachineStatusChanged -= HandleMachineStatusChanged;
        Hub.OnJobStatusChanged -= HandleJobStatusChanged;
        Hub.OnAlarmTriggered -= HandleAlarmTriggered;
        Hub.ConnectionStateChanged -= HandleHubConnectionStateChanged;
        _hubHandlersAttached = false;
    }

    private void HandleHubConnectionStateChanged() => _ = InvokeAsync(StateHasChanged);

    private void HandleMachineStatusChanged(MachineStatusChangedEvent evt)
    {
        var idx = _machines.FindIndex(m => m.Id == evt.MachineId);
        if (idx >= 0)
            _machines[idx] = _machines[idx] with { OperationalStatus = evt.NewStatus };
        _machineLabels[evt.MachineId] = $"{evt.MachineCode} · {evt.MachineName}";
        RebuildDerived();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleJobStatusChanged(JobStatusChangedEvent evt)
    {
        var idx = _machines.FindIndex(m => m.Id == evt.MachineId);
        if (idx < 0)
        {
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        var m = _machines[idx];
        if (m.ActiveJob is { } j && j.Id == evt.JobId)
            _machines[idx] = m with { ActiveJob = j with { ExecutionStatus = evt.NewStatus, ProducedQty = evt.ProducedQty, PlannedQty = evt.PlannedQty } };

        RebuildDerived();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleAlarmTriggered(AlarmTriggeredEvent evt)
    {
        var row = new AlarmRowDto(
            evt.AlarmId,
            evt.AlarmCode,
            evt.Message,
            evt.Severity,
            "Hub",
            evt.TriggeredAt,
            null,
            null,
            null,
            null,
            evt.MachineId,
            "Active",
            "Active");
        _allAlarms.RemoveAll(a => a.Id == evt.AlarmId);
        _allAlarms.Insert(0, row);
        RebuildDerived();
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadSummaryAsync()
    {
        var res = await Api.GetEventingSummaryAsync();
        _loadSummary = false;
        _summaryErr = res.Error;
        _summary = res.Data;
        RebuildDerived();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMachinesAsync()
    {
        var res = await Api.GetProductionMachinesAsync();
        _loadMachines = false;
        _machinesErr = res.Error;
        _machines = res.Data ?? [];
        _machineLabels = _machines.ToDictionary(m => m.Id, m => $"{m.Code} · {m.Name}");
        RebuildDerived();
        await InvokeAsync(StateHasChanged);
    }

