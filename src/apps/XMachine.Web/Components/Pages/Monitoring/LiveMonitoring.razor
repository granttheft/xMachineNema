    private async Task LoadOeeAsync()
    {
        var res = await Api.GetOeeSnapshotsAsync();
        _loadOee = false;
        _oeeErr = res.Error;
        _allOee = res.Data ?? [];
        RebuildDerived();
        await InvokeAsync(StateHasChanged);
    }

    private void RebuildDerived()
    {
        var todayStart = new DateTimeOffset(DateTime.UtcNow.Date, TimeSpan.Zero);
        var todayEnd = todayStart.AddDays(1);

        _activeAlarms = _allAlarms
            .Where(a => a.EndTime is null)
            .OrderByDescending(a => a.StartTime)
            .Take(10)
            .ToList();
        _activeAlarmCount = _allAlarms.Count(a => a.EndTime is null);

        _downtimesToday = _allDowntimes
            .Where(d => d.StartTime >= todayStart && d.StartTime < todayEnd)
            .OrderByDescending(d => d.StartTime)
            .Take(10)
            .ToList();

        _downtimeTodayMinutes = 0;
        foreach (var d in _allDowntimes.Where(x => x.StartTime >= todayStart && x.StartTime < todayEnd))
        {
            if (d.DurationMs is long ms && ms > 0)
                _downtimeTodayMinutes += (int)(ms / 60000);
            else if (d.EndTime is { } end)
                _downtimeTodayMinutes += (int)Math.Max(0, (end - d.StartTime).TotalMinutes);
            else
                _downtimeTodayMinutes += (int)Math.Max(0, (DateTimeOffset.UtcNow - d.StartTime).TotalMinutes);
        }

        _latestOeeByMachine = new Dictionary<Guid, OeeRowDto>();
        foreach (var row in _allOee.OrderByDescending(x => x.PeriodStart))
        {
            if (row.MachineId is not { } mid)
                continue;
            if (!_latestOeeByMachine.ContainsKey(mid))
                _latestOeeByMachine[mid] = row;
        }

        var oeeValues = _latestOeeByMachine.Values.Select(x => NormalizeOeePercent(x.OeeValue)).Where(v => v >= 0).ToList();
        _avgOeePct = oeeValues.Count == 0 ? null : Math.Round(oeeValues.Average(), 1);

        _runCount = _machines.Count(m => string.Equals(m.OperationalStatus, "Running", StringComparison.OrdinalIgnoreCase));
        _pausedCount = _machines.Count(m =>
            m.ActiveJob is { } j && string.Equals(j.ExecutionStatus, "Paused", StringComparison.OrdinalIgnoreCase));
        _idleCount = _machines.Count(m => string.Equals(m.OperationalStatus, "Idle", StringComparison.OrdinalIgnoreCase));
        _downCount = _machines.Count(m =>
            string.Equals(m.OperationalStatus, "Down", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(m.OperationalStatus, "PmDue", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(m.OperationalStatus, "WaitingParts", StringComparison.OrdinalIgnoreCase));

        _oeeMachineTiles = _machines
            .OrderBy(m => m.Code)
            .Take(12)
            .Select(m => new OeeMachineTileVm(
                _machineLabels.GetValueOrDefault(m.Id, m.Code),
                _latestOeeByMachine.TryGetValue(m.Id, out var snap) ? snap : null))
            .ToList();
    }

    private sealed record OeeMachineTileVm(string MachineLabel, OeeRowDto? Snapshot);

    private IEnumerable<(string Title, string Value, bool Loading, string? Err)> BuildKpis()
    {
        yield return (T["page.live_monitoring.kpi_eventing_total"], _summary?.Alarms.ToString(CultureInfo.InvariantCulture) ?? "—", _loadSummary, _summaryErr);
        yield return (T["page.live_monitoring.kpi_active_alarms"], _activeAlarmCount?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadAlarms, _alarmsErr);
        yield return (T["page.live_monitoring.kpi_downtime_today_min"], _downtimeTodayMinutes?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadDowntimes, _downtimesErr);
        yield return (T["page.live_monitoring.kpi_avg_oee"], _avgOeePct is null ? "—" : $"{_avgOeePct:0}%", _loadOee, _oeeErr);
        yield return (T["page.live_monitoring.kpi_running"], _runCount?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadMachines, _machinesErr);
        yield return (T["page.live_monitoring.kpi_paused"], _pausedCount?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadMachines, _machinesErr);
        yield return (T["page.live_monitoring.kpi_idle"], _idleCount?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadMachines, _machinesErr);
        yield return (T["page.live_monitoring.kpi_down"], _downCount?.ToString(CultureInfo.InvariantCulture) ?? "—", _loadMachines, _machinesErr);
    }

    private string MachineLabel(Guid? machineId) =>
        machineId is { } id && _machineLabels.TryGetValue(id, out var label) ? label : machineId?.ToString("N")[..8] ?? "—";

    private static string FormatUtc(DateTimeOffset t) =>
        t.ToUniversalTime().ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture) + " UTC";

    private static string FormatDowntimeMinutes(DowntimeRowDto d)
    {
        if (d.DurationMs is long ms && ms > 0)
            return $"{ms / 60000} min";
        if (d.EndTime is { } end)
            return $"{(int)Math.Round((end - d.StartTime).TotalMinutes)} min";
        return "—";
    }

    private static string SeverityBadgeClass(string severity)
    {
        var s = severity.ToLowerInvariant();
        if (s.Contains("crit") || s.Contains("fatal"))
            return "bg-red-100 text-red-800";
        if (s.Contains("high"))
            return "bg-orange-100 text-orange-800";
        if (s.Contains("med") || s.Contains("warn"))
            return "bg-yellow-100 text-yellow-800";
        if (s.Contains("low") || s.Contains("info"))
            return "bg-blue-100 text-blue-800";
        return "bg-slate-100 text-slate-700";
    }

    private static decimal NormalizeOeePercent(decimal v) =>
        v is > 0m and <= 1m ? v * 100m : v;

    private static string OeeTextClass(decimal v)
    {
        var p = NormalizeOeePercent(v);
        if (p >= 85m) return "text-green-600";
        if (p >= 65m) return "text-yellow-600";
        return "text-red-600";
    }

    private static string Pct(decimal v)
    {
        var p = NormalizeOeePercent(v);
        return $"{Math.Round(p, 1)}%";
    }
}
