@page "/quality/checks"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Quality checks</PageTitle>

<PageHeader Title="Quality checks"
            Subtitle="Inspection records and outcomes · summaries and detail from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Quality</li>
                <li class="breadcrumb-item active">Checks</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="row g-3 mb-4 xm-metric-strip">
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Checks</div>
                <div class="fs-5 fw-semibold">@(_summary?.Checks.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Measurements</div>
                <div class="fs-5 fw-semibold">@(_summary?.Measurements.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">NCs</div>
                <div class="fs-5 fw-semibold">@(_summary?.Nonconformances.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Dispositions</div>
                <div class="fs-5 fw-semibold">@(_summary?.Dispositions.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No quality checks returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Check type</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Time (UTC)</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Outcome</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Production order</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Lot</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Machine</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _rows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3 text-sm text-slate-700">@UiLabels.HumanizeToken(r.CheckType)</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-600">@UiFormats.UtcMinute(r.CheckTime)</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><StatusBadge Text="@UiLabels.QualityCheckStatus(r.CheckStatus)" Tone="@UiLabels.QualityCheckStatusTone(r.CheckStatus)" /></td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.ProductionOrderId</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.LotBatchId</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.MachineId</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private QualitySummaryDto? _summary;
    private IReadOnlyList<QualityCheckRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var sum = await Api.GetQualitySummaryAsync();
        var list = await Api.GetQualityChecksAsync();
        _loading = false;
        if (sum.Error is not null)
            _error = sum.Error;
        else
            _summary = sum.Data;

        if (list.Error is not null)
            _error ??= list.Error;
        else
            _rows = list.Data ?? [];

        if (sum.Error is null && list.Error is null)
            _error = null;

        StateHasChanged();
    }
}
