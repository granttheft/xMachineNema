@page "/quality/checks"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Quality checks</PageTitle>

<PageHeader Title="Quality checks"
            Subtitle="Inspection records and outcomes · summaries and detail from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Quality</li>
                <li class="breadcrumb-item active">Checks</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="row g-3 mb-4 xm-metric-strip">
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Checks</div>
                <div class="fs-5 fw-semibold">@(_summary?.Checks.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Measurements</div>
                <div class="fs-5 fw-semibold">@(_summary?.Measurements.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">NCs</div>
                <div class="fs-5 fw-semibold">@(_summary?.Nonconformances.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Dispositions</div>
                <div class="fs-5 fw-semibold">@(_summary?.Dispositions.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No quality checks returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Check type</th><th>Time (UTC)</th><th>Outcome</th><th>Production order</th><th>Lot</th><th>Machine</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="small">@UiLabels.HumanizeToken(r.CheckType)</td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.CheckTime)</td>
                            <td><StatusBadge Text="@UiLabels.QualityCheckStatus(r.CheckStatus)" Tone="@UiLabels.QualityCheckStatusTone(r.CheckStatus)" /></td>
                            <td class="small font-monospace">@r.ProductionOrderId</td>
                            <td class="small font-monospace">@r.LotBatchId</td>
                            <td class="small font-monospace">@r.MachineId</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private QualitySummaryDto? _summary;
    private IReadOnlyList<QualityCheckRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var sum = await Api.GetQualitySummaryAsync();
        var list = await Api.GetQualityChecksAsync();
        _loading = false;
        if (sum.Error is not null)
            _error = sum.Error;
        else
            _summary = sum.Data;

        if (list.Error is not null)
            _error ??= list.Error;
        else
            _rows = list.Data ?? [];

        if (sum.Error is null && list.Error is null)
            _error = null;

        StateHasChanged();
    }
}
