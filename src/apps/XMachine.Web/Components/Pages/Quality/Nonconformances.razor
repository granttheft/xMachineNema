@page "/quality/nonconformances"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Nonconformances</PageTitle>

<PageHeader Title="Nonconformances"
            Subtitle="NC register linked to quality checks · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Quality</li>
                <li class="breadcrumb-item active">Nonconformances</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="row g-3 mb-4 xm-metric-strip">
    <div class="col-md-4">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Quality checks (total)</div>
                <div class="fs-5 fw-semibold">@(_summary?.Checks.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Nonconformances</div>
                <div class="fs-5 fw-semibold">@(_summary?.Nonconformances.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 h-100">
            <div class="card-body py-2">
                <div class="text-muted small">Dispositions</div>
                <div class="fs-5 fw-semibold">@(_summary?.Dispositions.ToString() ?? "—")</div>
            </div>
        </div>
    </div>
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No nonconformances returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">NC code</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Quality check</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Severity</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">NC status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Description</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _rows)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@r.NcCode</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.QualityCheckId</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><StatusBadge Text="@UiLabels.NonconformanceSeverity(r.Severity)" Tone="@UiLabels.NonconformanceSeverityTone(r.Severity)" /></td>
                                <td class="px-4 py-3 text-sm text-slate-700"><StatusBadge Text="@UiLabels.NonconformanceStatus(r.NcStatus)" Tone="@UiLabels.NonconformanceStatusTone(r.NcStatus)" /></td>
                                <td class="max-w-xs truncate px-4 py-3 text-sm text-slate-700" title="@r.Description">@r.Description</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private QualitySummaryDto? _summary;
    private IReadOnlyList<NonconformanceRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var sum = await Api.GetQualitySummaryAsync();
        var list = await Api.GetNonconformancesAsync();
        _loading = false;
        if (sum.Error is not null)
            _error = sum.Error;
        else
            _summary = sum.Data;

        if (list.Error is not null)
            _error ??= list.Error;
        else
            _rows = list.Data ?? [];

        if (sum.Error is null && list.Error is null)
            _error = null;

        StateHasChanged();
    }
}
