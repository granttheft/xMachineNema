@page "/login"
@layout MainLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav

<PageTitle>Sign in</PageTitle>

<PageHeader Title="Sign in"
            Subtitle="Use your assigned operator or administrator account.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item active">Sign in</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="row justify-content-center">
    <div class="col-12" style="max-width:28rem">
        <DataPanel Padded="true">
            <p class="small text-body-secondary mb-3">
                Development sign-in uses the shared password from configuration.
            </p>
            @if (_error is not null)
            {
                <div class="xm-api-error mb-3" role="alert">@_error</div>
            }
            <form method="post" action="/auth/login">
                <input type="hidden" name="returnUrl" value="@_returnUrl" />
                <div class="mb-3">
                    <label class="form-label small text-muted">Username</label>
                    <input class="form-control" name="username"
                           autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Password</label>
                    <input class="form-control" type="password" name="password"
                           autocomplete="current-password" />
                </div>
                <button type="submit" class="btn btn-primary">Sign in</button>
            </form>
        </DataPanel>
    </div>
</div>

@code {
    private string? _error;
    private string? _returnUrl;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var err) && err == "invalid")
            _error = "Invalid username or password.";

        if (query.TryGetValue("returnUrl", out var ret))
            _returnUrl = ret.FirstOrDefault();
    }
}
