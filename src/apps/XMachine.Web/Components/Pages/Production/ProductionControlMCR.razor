    }

    /// <summary>Client-side filtered view of MCR rows.</summary>
    private IEnumerable<McrRow> FilteredMcrs()
    {
        IEnumerable<McrRow> q = _mcrs;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var s = _searchTerm.Trim();
            q = q.Where(m =>
                m.Id.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                m.JobId.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                m.Machine.Contains(s, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.Equals(_statusFilter, "all", StringComparison.OrdinalIgnoreCase))
            q = q.Where(m => string.Equals(m.Status, _statusFilter, StringComparison.OrdinalIgnoreCase));

        if (!string.Equals(_machineFilter, "all", StringComparison.OrdinalIgnoreCase))
            q = q.Where(m => string.Equals(m.Machine, _machineFilter, StringComparison.OrdinalIgnoreCase));

        if (!string.Equals(_dateFilter, "custom", StringComparison.OrdinalIgnoreCase))
        {
            q = _dateFilter switch
            {
                "today" => q.Where(m =>
                {
                    var d = ParsePlannedDate(m.PlannedStart) ?? ParseCreatedDate(m.CreatedAt);
                    return d is { } x && x.Date == MockCalendarDay.Date;
                }),
                "week" => q.Where(m =>
                {
                    var d = ParsePlannedDate(m.PlannedStart) ?? ParseCreatedDate(m.CreatedAt);
                    return d is { } x && x >= MockCalendarDay.AddDays(-2) && x <= MockCalendarDay.AddDays(4);
                }),
                "month" => q.Where(m =>
                {
                    var d = ParsePlannedDate(m.PlannedStart) ?? ParseCreatedDate(m.CreatedAt);
                    return d is { } x && x.Year == 2025 && x.Month == 9;
                }),
                _ => q
