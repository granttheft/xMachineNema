            id, _newJobId.Trim(), _newMachine.Trim(), _newCurrentMold.Trim(), _newRequiredMold.Trim(),
            _newType, 45, "Pending", planned, null, null, _newTechnician, _newPriority,
            "Production Control", DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture),
            string.IsNullOrWhiteSpace(_newNotes) ? null : _newNotes.Trim(), null, null));

        _successMessage = $"MCR {id} created.";
        _showNewMcrModal = false;
        StateHasChanged();
    }

