                <div>
                    <label class="block text-sm font-medium text-slate-900 mb-1">Reason *</label>
                    <select class="w-full h-10 rounded-md border border-slate-200 px-3" @bind="_retReason">
                        @foreach (var o in ReturnReasonOptions)
                        {
                            <option value="@o">@o</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mt-6 flex justify-end gap-2">
                <button type="button" @onclick="() => { _showReturnModal = false; StateHasChanged(); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-slate-200 bg-white h-9 px-4 hover:bg-slate-50">Cancel</button>
                <button type="button" @onclick="AddReturnRequest" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-orange-600 text-white h-9 px-4 hover:bg-orange-700">Submit</button>
            </div>
        </div>
    </div>
}

