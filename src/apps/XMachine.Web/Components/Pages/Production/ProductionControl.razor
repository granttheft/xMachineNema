        _retReason = ReturnReasonOptions[0];
    }

    private void AddNewMaterialRequest()
    {
        if (string.IsNullOrEmpty(_reqJobId) || string.IsNullOrEmpty(_reqMaterialCode) || _reqIssueQty <= 0)
            return;

        var job = _activeJobsWithMaterials.FirstOrDefault(j => j.JobId == _reqJobId);
        var mat = GetReservedForJob(_reqJobId).FirstOrDefault(m => m.MaterialCode == _reqMaterialCode);
        if (job is null || mat is null || _reqIssueQty > mat.Qty)
            return;

        var refNo = $"RMR-{DateTime.UtcNow:yyyyMMdd}-{_nextSeq++:000}";
        _materialRequests.Add(new MaterialRequestRow(
            $"RMR-NEW-{_nextSeq}",
            refNo,
            job.JobId,
            job.Machine,
            job.Product,
            mat.MaterialCode,
            mat.MaterialName,
            mat.Color,
            mat.Qty,
            mat.Qty,
            _reqIssueQty,
            0,
            mat.Unit,
            "Pending"));

        _issueQtyEdits[_materialRequests[^1].Id] = _reqIssueQty;
        _showRequestModal = false;
        ResetRequestForm();
        StateHasChanged();
    }

    private void AddJobTransfer()
    {
        if (string.IsNullOrEmpty(_trFromJobId) || string.IsNullOrEmpty(_trToJobId) || string.IsNullOrEmpty(_trMaterialCode) || _trQty <= 0 || string.IsNullOrEmpty(_trReason))
            return;

        var from = _activeJobsWithMaterials.FirstOrDefault(j => j.JobId == _trFromJobId);
        var to = _activeJobsWithMaterials.FirstOrDefault(j => j.JobId == _trToJobId);
        var mat = GetReservedForJob(_trFromJobId).FirstOrDefault(m => m.MaterialCode == _trMaterialCode);
        if (from is null || to is null || mat is null || _trQty > mat.Qty)
            return;

        var refNo = $"JT-{DateTime.UtcNow:yyyyMMdd}-{_nextSeq++:000}";
        _transfers.Add(new JobTransferRow(
            $"JT-NEW-{_nextSeq}",
            refNo,
            from.JobId,
            from.Machine,
            to.JobId,
            to.Machine,
            mat.MaterialCode,
            mat.MaterialName,
            mat.Color,
            _trQty,
            mat.Unit,
            _trReason,
            "Pending Acknowledgement (Warehouse)"));

        _showTransferModal = false;
        ResetTransferForm();
        StateHasChanged();
    }

    private void AddReturnRequest()
    {
        if (string.IsNullOrEmpty(_retJobId) || string.IsNullOrEmpty(_retMaterialCode) || _retQty <= 0 || string.IsNullOrEmpty(_retReason))
            return;

        var job = _activeJobsWithMaterials.FirstOrDefault(j => j.JobId == _retJobId);
        var mat = GetReservedForJob(_retJobId).FirstOrDefault(m => m.MaterialCode == _retMaterialCode);
        if (job is null || mat is null || _retQty > mat.Qty)
            return;

        var refNo = $"RL-{DateTime.UtcNow:yyyyMMdd}-{_nextSeq++:000}";
        var row = new ReturnLeftoverRow(
            $"RL-NEW-{_nextSeq}",
            refNo,
            job.JobId,
            job.Machine,
            job.Product,
            mat.MaterialCode,
            mat.MaterialName,
            mat.Color,
            mat.Qty,
            _retQty,
            mat.Unit,
            _retReason,
            "Pending");
        _returns.Add(row);
        _returnQtyEdits[row.Id] = _retQty;

        _showReturnModal = false;
        ResetReturnForm();
        StateHasChanged();
    }

