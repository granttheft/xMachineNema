    private static string FormatProgress(int produced, int planned)
    {
        if (planned <= 0)
            return $"{produced} / {planned} (0%)";
        var pct = (int)Math.Round(produced * 100m / planned);
        return $"{produced} / {planned} ({pct}%)";
