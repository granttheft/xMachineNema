    private async void ApprovePlan(string planId)
    {
        var jobNo = $"JOB-{DateTime.UtcNow:yyyyMMdd}-{_jobSeq++:000}";
        for (var i = 0; i < _plans.Count; i++)
        {
            if (_plans[i].PlanId != planId)
                continue;

            var p = _plans[i];
            _plans[i] = p with { Status = "Approved", JobId = jobNo };
            if (IsParent(p) && p.Children.Count > 0)
            {
                foreach (var childId in p.Children)
                {
                    var ci = _plans.FindIndex(x => x.PlanId == childId);
                    if (ci >= 0)
                    {
                        var c = _plans[ci];
                        var suffix = childId.Split('-').LastOrDefault() ?? "C";
                        _plans[ci] = c with { Status = "Approved", JobId = $"{jobNo}-{suffix}" };
                    }
                }
            }

            break;
        }

        StateHasChanged();
        await ShowSuccessBannerAsync($"Plan {planId} approved. Job {jobNo} created.");
    }

    private async void RejectPlan()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            _rejectModalError = "Please enter a rejection reason.";
            StateHasChanged();
            return;
        }

        if (_selectedPlan is null)
            return;

        var id = _selectedPlan.PlanId;
        for (var i = 0; i < _plans.Count; i++)
        {
            if (_plans[i].PlanId == id)
            {
                _plans[i] = _plans[i] with { Status = "Rejected", RejectionReason = _rejectReason.Trim() };
                break;
            }
        }

        _showRejectModal = false;
        _rejectReason = string.Empty;
        _rejectModalError = null;
        StateHasChanged();
        await ShowSuccessBannerAsync($"Plan {id} rejected.", false);
    }

    /// <summary>Shows a temporary banner message (auto-dismiss after 3 seconds).</summary>
    /// <param name="message">Banner text.</param>
    /// <param name="approveStyle">When true, use green success styling; otherwise neutral slate.</param>
    private async Task ShowSuccessBannerAsync(string message, bool approveStyle = true)
    {
        _successBannerCts?.Cancel();
        _successBannerCts?.Dispose();
        _successBannerCts = new CancellationTokenSource();
        var token = _successBannerCts.Token;

        _successBannerCss = approveStyle
            ? "rounded-lg border border-green-200 bg-green-50 px-4 py-2 text-sm text-green-800"
            : "rounded-lg border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-800";
        _planSuccessMessage = message;
        StateHasChanged();

        try
        {
            await Task.Delay(3000, token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (!token.IsCancellationRequested)
        {
            _planSuccessMessage = null;
            StateHasChanged();
        }
    }

