@if (_showPlanDetailModal && _selectedPlan is not null)
{
    var sp = _selectedPlan;
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 overflow-y-auto" @onclick="ClosePlanDetail">
        <div class="max-w-4xl w-full rounded-lg border border-slate-200 bg-white p-6 shadow-lg my-8" @onclick:stopPropagation="true">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Plan @sp.PlanId</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm mb-6">
                <div><p class="text-xs text-slate-500">Plan ID</p><p class="font-medium">@sp.PlanId</p></div>
                <div><p class="text-xs text-slate-500">Product</p><p class="font-medium">@sp.ProductCode — @sp.ProductName</p></div>
                <div><p class="text-xs text-slate-500">Quantity</p><p class="font-medium">@sp.Qty.ToString("N0") @sp.Unit</p></div>
                <div><p class="text-xs text-slate-500">Planner</p><p class="font-medium">@sp.Planner</p></div>
                <div><p class="text-xs text-slate-500">Date</p><p class="font-medium">@sp.SubmittedDate</p></div>
                <div><p class="text-xs text-slate-500">Priority</p><p><span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetPriorityClass(sp.Priority)">@sp.Priority</span></p></div>
                <div><p class="text-xs text-slate-500">Status</p><p><span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetStatusClass(sp.Status)">@sp.Status</span></p></div>
                <div><p class="text-xs text-slate-500">Type</p><p class="font-medium">@sp.PlanType</p></div>
            </div>
            <div class="overflow-hidden rounded-lg border border-slate-200 mb-6">
                <table class="min-w-full divide-y divide-slate-100 text-sm">
                    <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-slate-500">Material Code</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-slate-500">Name</th>
                        <th class="px-4 py-2 text-right text-xs font-semibold text-slate-500">Required Qty</th>
                        <th class="px-4 py-2 text-right text-xs font-semibold text-slate-500">Available Stock</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-slate-500">Status</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var m in sp.RawMaterials)
                    {
                        var ok = m.AvailableStock >= m.RequiredQty;
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-2 font-mono text-blue-600">@m.MaterialCode</td>
                            <td class="px-4 py-2">@m.MaterialName</td>
                            <td class="px-4 py-2 text-right font-mono">@m.RequiredQty.ToString("N2") @m.Unit</td>
                            <td class="px-4 py-2 text-right font-mono">@m.AvailableStock.ToString("N2")</td>
                            <td class="px-4 py-2">@(ok ? "Sufficient" : "Shortage")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            @if (string.Equals(sp.Status, "Pending", StringComparison.OrdinalIgnoreCase))
            {
                <div class="flex justify-end gap-2">
                    <button type="button" @onclick="ClosePlanDetail" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-slate-200 bg-white h-9 px-4 hover:bg-slate-50">Close</button>
                    <button type="button" @onclick="() => { ApprovePlan(sp.PlanId); ClosePlanDetail(); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-green-600 text-white h-9 px-4 hover:bg-green-700">Approve</button>
                    <button type="button" @onclick="() => { ClosePlanDetail(); OpenRejectModal(sp); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-red-600 text-white h-9 px-4 hover:bg-red-700">Reject</button>
                </div>
            }
            else
            {
                <div class="flex justify-end">
                    <button type="button" @onclick="ClosePlanDetail" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-slate-200 bg-white h-9 px-4 hover:bg-slate-50">Close</button>
                </div>
            }
        </div>
    </div>
}

@if (_showRejectModal && _selectedPlan is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @onclick="CloseRejectModal">
        <div class="max-w-md w-full rounded-lg border border-slate-200 bg-white p-6 shadow-lg" @onclick:stopPropagation="true">
            <h2 class="text-lg font-semibold text-slate-900 mb-2">Reject plan @_selectedPlan.PlanId</h2>
            @if (!string.IsNullOrEmpty(_rejectModalError))
            {
                <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800 mb-3">@_rejectModalError</div>
            }
            <label class="block text-sm font-medium text-slate-900 mb-1">Reason</label>
            <textarea @bind="_rejectReason" rows="4" class="w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm mb-4"></textarea>
            <div class="flex justify-end gap-2">
                <button type="button" @onclick="CloseRejectModal" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-slate-200 bg-white h-9 px-4 hover:bg-slate-50">Cancel</button>
                <button type="button" @onclick="RejectPlan" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-red-600 text-white h-9 px-4 hover:bg-red-700">Confirm Reject</button>
            </div>
        </div>
    </div>
}

@if (_showRequestModal)
