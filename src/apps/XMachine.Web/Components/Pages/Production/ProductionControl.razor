@page "/production/control"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Production Control · xMachine</PageTitle>

<div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-6 py-4">
        <h1 class="text-2xl font-semibold text-slate-900">Production Control</h1>
        <p class="text-sm text-slate-500 mt-1">Job Monitoring · Demand Authorization · Material Control</p>
    </div>

    <div class="bg-white border-b border-slate-200 px-6">
        <div class="flex flex-wrap gap-x-8">
            <button type="button" @onclick='() => SetTab("jobs")' class="@TabClass(_activeTab == "jobs") py-3 px-1 text-sm mr-8">Job Monitoring</button>
            <button type="button" @onclick='() => SetTab("demand")' class="@TabClass(_activeTab == "demand") py-3 px-1 text-sm mr-8">Demand Authorization</button>
            <button type="button" @onclick='() => SetTab("material")' class="@TabClass(_activeTab == "material") py-3 px-1 text-sm mr-8">Material Control</button>
        </div>
    </div>

    <div class="p-6 space-y-6">
        @if (!string.IsNullOrEmpty(_planSuccessMessage))
        {
            <div class="@_successBannerCss">@_planSuccessMessage</div>
        }

        @if (_activeTab == "jobs")
        {
            <div class="rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-100 px-6 py-4">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                        <svg class="h-5 w-5 text-blue-600 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
                        Job Monitoring Dashboard
                    </h2>
                </div>
                <div class="p-6">
                    <div class="flex gap-3 mb-6">
                        <div class="flex items-center gap-2 bg-blue-50 px-3 py-2 rounded-lg">
                            <span class="text-sm">Real-time job status monitoring and performance tracking</span>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-green-600">@RunningJobCount</div>
                            <div class="text-sm text-slate-600">Running Jobs</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-blue-600">@CompletedJobCount</div>
                            <div class="text-sm text-slate-600">Completed</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-yellow-600">@PausedJobCount</div>
                            <div class="text-sm text-slate-600">Paused</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-purple-600">@SetupJobCount</div>
                            <div class="text-sm text-slate-600">Setup</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-red-600">@TotalAlerts</div>
                            <div class="text-sm text-slate-600">Active Alerts</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                            <div class="text-2xl font-bold text-indigo-600">@AvgOee%</div>
                            <div class="text-sm text-slate-600">Avg OEE</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="border-b border-slate-100 px-6 py-4 flex items-center gap-2">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2 flex-1">
                        <svg class="h-5 w-5 text-slate-700" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-8-5-8 5v12Z"/><path d="M6 18V10"/><path d="m10 18-2-8"/><path d="m14 18 2-8"/><path d="M18 18v-4"/></svg>
                        Active Jobs List &amp; Status
                    </h2>
                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium bg-slate-100 text-slate-800">@_jobMonitoring.Count jobs</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100 text-sm">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Job ID</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Product</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Machine</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Progress</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">OEE</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Operator</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Alerts</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var job in _jobMonitoring)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3">
                                    <div class="font-medium text-blue-600">@job.JobId</div>
                                    <div class="text-sm text-slate-600">Plan: @job.PlanId</div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="font-medium">@job.ProductCode</div>
                                    <div class="text-sm text-slate-600 max-w-[150px] truncate" title="@job.Product">@job.Product</div>
                                </td>
                                <td class="px-4 py-3 font-mono text-sm">@job.Machine</td>
                                <td class="px-4 py-3">
                                    <div class="space-y-1">
                                        <div class="flex justify-between text-sm">
                                            <span>@job.ProducedQty/@job.TargetQty</span>
                                            <span>@job.ProgressPercentage%</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-slate-200 overflow-hidden">
                                            <div class="h-2 rounded-full bg-blue-500" style="width:@(Math.Clamp(job.ProgressPercentage, 0, 100))%"></div>
                                        </div>
                                        <div class="text-xs text-slate-600">Good: @job.GoodQty | Defect: @job.DefectQty</div>
                                    </div>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetJobStatusClass(job.Status)">@job.Status</span>
                                    <div class="text-xs text-slate-600 mt-1">Eff: @job.Efficiency%</div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="font-medium text-indigo-600">@job.OeeScore%</div>
                                    <div class="text-xs text-slate-600">DT: @job.DowntimeMinutes min</div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="text-sm">@job.Operator</div>
                                    <div class="text-xs text-slate-600">@job.Shift</div>
                                </td>
                                <td class="px-4 py-3">
                                    @if (job.AlertCount > 0)
                                    {
                                        <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium border bg-red-50 text-red-700 border-red-200">@job.AlertCount Alert@(job.AlertCount > 1 ? "s" : "")</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium border bg-green-50 text-green-700 border-green-200">Normal</span>
                                    }
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex flex-wrap gap-1">
                                        <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-slate-200 bg-white h-8 px-2 hover:bg-slate-50">View</button>
                                        @if (string.Equals(job.Status, "Running", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-yellow-600 text-yellow-600 h-8 px-2 hover:bg-yellow-50">Pause</button>
                                        }
                                        @if (string.Equals(job.Status, "Paused", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-green-600 text-green-600 h-8 px-2 hover:bg-green-50">Resume</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                @foreach (var job in _jobMonitoring.Take(4))
                {
                    <div class="rounded-lg border border-slate-200 bg-white shadow-sm relative">
                        @if (job.AlertCount > 0)
                        {
                            <div class="absolute top-3 right-3">
                                <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium border bg-red-50 text-red-700 border-red-200">@job.AlertCount</span>
                            </div>
                        }
                        <div class="border-b border-slate-100 px-6 py-3">
                            <div class="flex items-center gap-2 text-lg font-semibold text-slate-900 pr-16">
                                <div class="w-3 h-3 rounded-full @(job.Status switch { "Running" => "bg-green-500", "Completed" => "bg-blue-500", "Paused" => "bg-yellow-500", "Setup" => "bg-purple-500", _ => "bg-slate-500" })"></div>
                                @job.JobId
                                <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium border @GetPriorityBadgeClass(job.Priority)">@job.Priority</span>
                            </div>
                        </div>
                        <div class="p-6 space-y-4">
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div>
                                    <p class="text-xs text-slate-600">Product</p>
                                    <p class="font-medium text-slate-900">@job.ProductCode</p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-600">Machine</p>
                                    <p class="font-mono text-slate-900">@job.Machine</p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-600">Operator</p>
                                    <p class="text-slate-900">@job.Operator</p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-600">Status</p>
                                    <p class="font-medium @(job.Status switch { "Running" => "text-green-600", "Completed" => "text-blue-600", "Paused" => "text-yellow-600", "Setup" => "text-purple-600", _ => "text-slate-600" })">@job.Status</p>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between text-sm mb-2">
                                    <span class="text-slate-600">Progress</span>
                                    <span class="font-medium">@FormatProgress(job.ProducedQty, job.TargetQty)</span>
                                </div>
                                <div class="h-3 rounded-full bg-slate-200 overflow-hidden">
                                    <div class="h-3 rounded-full bg-blue-500" style="width:@(Math.Clamp(job.ProgressPercentage, 0, 100))%"></div>
                                </div>
                                <div class="text-xs text-slate-600 mt-1 flex justify-between">
                                    <span>Good: @job.GoodQty</span>
                                    <span>Defect: @job.DefectQty</span>
                                </div>
                            </div>
                            <div class="grid grid-cols-3 gap-4 text-sm">
                                <div class="text-center p-2 bg-indigo-50 rounded-lg">
                                    <div class="font-bold text-indigo-600">@job.OeeScore%</div>
                                    <div class="text-indigo-700 text-xs">OEE Score</div>
                                </div>
                                <div class="text-center p-2 bg-green-50 rounded-lg">
                                    <div class="font-bold text-green-600">@job.Efficiency%</div>
                                    <div class="text-green-700 text-xs">Efficiency</div>
                                </div>
                                <div class="text-center p-2 bg-yellow-50 rounded-lg">
                                    <div class="font-bold text-yellow-600">@job.DowntimeMinutes m</div>
                                    <div class="text-yellow-700 text-xs">Downtime</div>
                                </div>
                            </div>
                            <div>
                                <p class="text-xs text-slate-600 mb-1">Raw Materials</p>
                                <div class="space-y-1 mt-1">
                                    @foreach (var m in job.RawMaterials)
                                    {
                                        var pct = m.Required > 0 ? (int)Math.Round(m.Remaining / m.Required * 100) : 0;
                                        <div class="flex justify-between items-center text-xs bg-slate-50 p-2 rounded">
                                            <span class="font-medium">@m.Code</span>
                                            <span class="text-slate-600">@m.Remaining/@m.Required @m.Unit</span>
                                            <span class="px-2 py-1 rounded text-xs @(pct > 30 ? "bg-green-100 text-green-700" : pct > 10 ? "bg-yellow-100 text-yellow-700" : "bg-red-100 text-red-700")">@pct%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div>
                                <p class="text-xs text-slate-600 mb-1">Recent Activity</p>
                                <div class="space-y-1 mt-1">
                                    @foreach (var ev in job.RecentEvents.Take(2))
                                    {
                                        <div class="flex items-center gap-2 text-xs">
                                            <span class="text-slate-500 font-mono">@ev.Time</span>
                                            <div class="w-2 h-2 rounded-full @(ev.Type switch { "success" => "bg-green-500", "warning" => "bg-yellow-500", "error" => "bg-red-500", _ => "bg-blue-500" })"></div>
                                            <span class="flex-1">@ev.Message</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="flex gap-2 pt-2">
                                <button type="button" class="inline-flex flex-1 items-center justify-center rounded-md text-xs font-medium border border-slate-200 bg-white h-8 px-2 hover:bg-slate-50">View Details</button>
                                @if (string.Equals(job.Status, "Running", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-yellow-600 text-yellow-600 h-8 px-2 hover:bg-yellow-50">Pause</button>
                                }
                                @if (string.Equals(job.Status, "Paused", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-green-600 text-green-600 h-8 px-2 hover:bg-green-50">Resume</button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_activeTab == "demand")
        {
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Pending Approval</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@DemandPendingParents</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Approved</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@DemandApprovedParents</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Rejected</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@DemandRejectedParents</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white shadow-sm p-4">
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Draft</p>
                    <p class="text-2xl font-semibold text-slate-900 mt-1">@DemandDraftParents</p>
                </div>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100 text-sm">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Plan ID</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Product</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Quantity</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Planner</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Priority</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Submitted Date</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Job ID</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var p in _plans)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 font-mono text-slate-700">@p.PlanId</td>
                                <td class="px-4 py-3 text-slate-700">@p.ProductCode — @p.ProductName</td>
                                <td class="whitespace-nowrap px-4 py-3">@p.Qty.ToString("N0") @p.Unit</td>
                                <td class="whitespace-nowrap px-4 py-3 text-slate-700">@p.Planner</td>
                                <td class="px-4 py-3"><span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetPriorityClass(p.Priority)">@p.Priority</span></td>
                                <td class="whitespace-nowrap px-4 py-3 text-slate-600">@p.SubmittedDate</td>
                                <td class="px-4 py-3"><span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium @GetStatusClass(p.Status)">@p.Status</span></td>
                                <td class="whitespace-nowrap px-4 py-3 font-mono text-slate-600">@(p.JobId ?? "—")</td>
                                <td class="px-4 py-3">
                                    <div class="flex flex-wrap gap-1">
                                        <button type="button" @onclick="() => OpenPlanDetail(p)" class="inline-flex items-center justify-center rounded-md text-xs font-medium border border-slate-200 bg-white h-8 w-8 p-0 hover:bg-slate-50" title="View">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-600"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                        @if (string.Equals(p.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button type="button" @onclick="() => ApprovePlan(p.PlanId)" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-green-600 text-white h-8 px-2 hover:bg-green-700">✓</button>
                                            <button type="button" @onclick="() => OpenRejectModal(p)" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-red-600 text-white h-8 px-2 hover:bg-red-700">✗</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (_activeTab == "material")
        {
            <div class="rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-100 px-6 py-4">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                        <svg class="h-5 w-5 text-green-600" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m7.5 4.27 9 5.15"/><path d="M21 8V5a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 5v14a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 19v-3"/><path d="M3.27 6.96 12 12.01l8.73-5.05"/><path d="M12 22.08V12"/></svg>
                        Raw Material Control
                    </h2>
                </div>
                <div class="p-6">
                    <div class="flex flex-wrap gap-3">
                        <button type="button" @onclick="() => { _showRequestModal = true; ResetRequestForm(); StateHasChanged(); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-blue-600 text-white h-9 px-4 hover:bg-blue-700">New Material Request</button>
                        <button type="button" @onclick="() => { _showTransferModal = true; ResetTransferForm(); StateHasChanged(); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-purple-600 text-purple-600 h-9 px-4 hover:bg-purple-50">Job-to-Job Transfer</button>
                        <button type="button" @onclick="() => { _showReturnModal = true; ResetReturnForm(); StateHasChanged(); }" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-orange-600 text-orange-600 h-9 px-4 hover:bg-orange-50">Return Leftover</button>
                    </div>
                </div>
            </div>

            <div class="rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="border-b border-slate-100 px-6 py-4 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-slate-900">Raw Material Requests</h2>
                    <span class="text-xs font-medium text-slate-500">@_materialRequests.Count requests</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100 text-sm">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Ref No</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Job ID</th>
