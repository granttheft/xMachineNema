    private static decimal ParseDecimal(object? v)
    {
        if (v is null)
            return 0;
        return decimal.TryParse(v.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d)
            ? d
            : 0;
    }

    private void SubmitMaterialRequest(string requestId)
    {
        var idx = _materialRequests.FindIndex(r => r.Id == requestId);
        if (idx < 0)
            return;

        var r = _materialRequests[idx];
        var qty = GetIssueQtyEdit(r.Id, r.IssueQty);
        _materialRequests[idx] = r with { Status = "Issued", IssueQty = qty, IssuedQty = qty };
        StateHasChanged();
    }

    private void SubmitReturnRequest(string requestId)
    {
        var idx = _returns.FindIndex(r => r.Id == requestId);
        if (idx < 0)
            return;

        var r = _returns[idx];
        var qty = GetReturnQtyEdit(r.Id, r.ReturnedQty);
        if (qty <= 0)
            return;

        _returns[idx] = r with { ReturnedQty = qty, Status = "Approved" };
        StateHasChanged();
    }

    /// <summary>Returns reserved materials for the selected job (mock).</summary>
    private IReadOnlyList<ReservedMaterialRow> GetReservedForJob(string jobId)
    {
        var j = _activeJobsWithMaterials.FirstOrDefault(x => x.JobId == jobId);
        return j?.ReservedMaterials ?? new List<ReservedMaterialRow>();
    }

    private void ResetRequestForm()
    {
