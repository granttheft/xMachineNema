    private List<StageEntry> GetStagesForKey(string key) =>
        _stageData.TryGetValue(key, out var list) ? list : new List<StageEntry>();

    private DefectScrapBundle GetDefectScrap(string key) =>
        _defectScrap.TryGetValue(key, out var b) ? b : new DefectScrapBundle(new List<DefectRow>(), new List<ScrapRow>());

    private List<EventEntry> GetEvents(string key) =>
        _eventHistory.TryGetValue(key, out var e) ? e : new List<EventEntry>();

    /// <summary>Looks up the trimmed search term in mock data (case-insensitive).</summary>
    private void Search()
    {
        var key = _searchTerm.Trim().ToUpperInvariant();
        if (string.IsNullOrEmpty(key))
        {
            _searchResults = null;
            StateHasChanged();
            return;
        }

        _searchResults = _lookup.TryGetValue(key, out var r) ? r : null;
        _splitExpanded = false;
        _assemblyExpanded = false;
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Search();
    }

    private void MockScanQr()
    {
        _searchTerm = "JOB20250907-001-C1";
        Search();
    }

    private void ToggleLive()
    {
        _isLiveMode = !_isLiveMode;
        StateHasChanged();
    }

    private void ToggleSplitExpanded()
    {
        _splitExpanded = !_splitExpanded;
        StateHasChanged();
    }

    /// <summary>Returns Tailwind classes for job/plan lifecycle status badges.</summary>
    private static string GetStatusClass(string status) => status.ToLowerInvariant() switch
    {
        "active" => "bg-blue-100 text-blue-800",
        "completed" => "bg-green-100 text-green-800",
        "waiting-qc" => "bg-yellow-100 text-yellow-800",
        "released" => "bg-purple-100 text-purple-800",
        _ => "bg-slate-100 text-slate-800",
    };

    private static string FormatStatusLabel(string status) => status.ToLowerInvariant() switch
    {
        "active" => "Active",
        "completed" => "Completed",
        "waiting-qc" => "Waiting QC",
        "released" => "Released",
        _ => status,
    };

    /// <summary>Returns Tailwind classes for assembly child QC status badges.</summary>
    private static string GetQcStatusClass(string status) => status.ToLowerInvariant() switch
    {
        "passed" => "bg-green-100 text-green-800",
        "failed" => "bg-red-100 text-red-800",
        "waiting-qc" => "bg-yellow-100 text-yellow-800",
        _ => "bg-slate-100 text-slate-800",
    };

    private static string FormatQcStatus(string status) => status.ToLowerInvariant() switch
    {
        "passed" => "Passed",
        "failed" => "Failed",
        "waiting-qc" => "Waiting QC",
        _ => status,
    };

