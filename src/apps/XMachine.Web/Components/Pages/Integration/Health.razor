@page "/integration/health"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Integration health</PageTitle>

<PageHeader Title="Integration health summary"
            Subtitle="Operational counts and connector runtime registry · from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Integration</li>
                <li class="breadcrumb-item active">Health</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Padded="true">
    <ApiStateDisplay Loading="_loading" Error="@_error">
        @if (_data is not null)
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                    <div class="rounded-lg border border-slate-100 bg-slate-50/80 p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Definitions</div>
                        <div class="mt-1 text-2xl font-bold tabular-nums text-slate-900">@_data.Operational.Definitions</div>
                    </div>
                    <div class="rounded-lg border border-slate-100 bg-slate-50/80 p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Instances</div>
                        <div class="mt-1 text-2xl font-bold tabular-nums text-slate-900">@_data.Operational.Instances</div>
                    </div>
                    <div class="rounded-lg border border-slate-100 bg-slate-50/80 p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Mapping profiles</div>
                        <div class="mt-1 text-2xl font-bold tabular-nums text-slate-900">@_data.Operational.Profiles</div>
                    </div>
                </div>
                <div class="mt-6 border-t border-slate-100 pt-5">
                    <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Runtime registry</div>
                    <div class="mt-2 text-sm text-slate-600">Active health rows: <span class="font-semibold text-slate-900">@_data.Runtime.ActiveHealthRows</span></div>
                    <div class="mt-2 break-all font-mono text-xs leading-relaxed text-slate-600">@string.Join(", ", _data.Runtime.RegistryCodes ?? [])</div>
                </div>
            </div>
        }
        else if (!_loading && _error is null)
        {
            <EmptyState Message="No health summary data returned." />
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IntegrationHealthSummaryDto? _data;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetIntegrationHealthAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _data = res.Data;
        }

        StateHasChanged();
    }
}
