@page "/integration/health"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Integration health</PageTitle>

<PageHeader Title="Integration health summary"
            Subtitle="Operational counts and connector runtime registry · from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Integration</li>
                <li class="breadcrumb-item active">Health</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Padded="true">
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_data is not null)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="xm-health-tile">
                        <div class="xm-health-tile-label">Definitions</div>
                        <div class="xm-health-tile-value">@_data.Operational.Definitions</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="xm-health-tile">
                        <div class="xm-health-tile-label">Instances</div>
                        <div class="xm-health-tile-value">@_data.Operational.Instances</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="xm-health-tile">
                        <div class="xm-health-tile-label">Mapping profiles</div>
                        <div class="xm-health-tile-value">@_data.Operational.Profiles</div>
                    </div>
                </div>
            </div>
            <div class="xm-health-runtime mt-4">
                <div class="xm-health-tile-label mb-2">Runtime registry</div>
                <div class="small text-body-secondary mb-2">Active health rows: <strong class="text-body">@_data.Runtime.ActiveHealthRows</strong></div>
                <div class="font-monospace small xm-health-codes">@string.Join(", ", _data.Runtime.RegistryCodes ?? [])</div>
            </div>
        }
        else if (!_loading && _error is null)
        {
            <EmptyState Message="No health summary data returned." />
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IntegrationHealthSummaryDto? _data;

    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetIntegrationHealthAsync().ConfigureAwait(false);
        _loading = false;
        _error = res.Error;
        _data = res.Data;
    }
}
