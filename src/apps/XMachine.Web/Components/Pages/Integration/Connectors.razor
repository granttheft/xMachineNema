@page "/integration/connectors"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Connectors</PageTitle>

<PageHeader Title="Connectors"
            Subtitle="Integration definitions and deployed instances · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Integration</li>
                <li class="breadcrumb-item active">Connectors</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Title="Definitions">
    <ApiStateDisplay Loading="_loadingDefs" Error="@_errDefs">
        @if (_defs.Count == 0)
        {
            <EmptyState Message="No connector definitions returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Code</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Category</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Direction</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _defs)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@r.Code</td>
                                <td class="px-4 py-3 text-sm text-slate-700">@r.Name</td>
                                <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(r.Category)</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><StatusBadge Text="@UiLabels.ConnectorDirection(r.Direction)" Tone="@UiLabels.ConnectorDirectionTone(r.Direction)" /></td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

<div class="mt-4">
<DataPanel Title="Instances">
    <ApiStateDisplay Loading="_loadingInst" Error="@_errInst">
        @if (_inst.Count == 0)
        {
            <EmptyState Message="No connector instances returned." />
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Code</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Connector definition</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Site ID</th>
                            <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var r in _inst)
                        {
                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@r.Code</td>
                                <td class="px-4 py-3 text-sm text-slate-700">@r.Name</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.ConnectorDefinitionId</td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.SiteId</td>
                                <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>
</div>

@code {
    private bool _loadingDefs = true;
    private bool _loadingInst = true;
    private string? _errDefs;
    private string? _errInst;
    private IReadOnlyList<ConnectorDefinitionRowDto> _defs = [];
    private IReadOnlyList<ConnectorInstanceRowDto> _inst = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var tDefs = Api.GetConnectorDefinitionsAsync();
        var tInst = Api.GetConnectorInstancesAsync();
        await Task.WhenAll(tDefs, tInst);
        var d = await tDefs;
        var i = await tInst;
        _loadingDefs = false;
        _loadingInst = false;
        if (d.Error is not null)
            _errDefs = d.Error;
        else
        {
            _errDefs = null;
            _defs = d.Data ?? [];
        }

        if (i.Error is not null)
            _errInst = i.Error;
        else
        {
            _errInst = null;
            _inst = i.Data ?? [];
        }

        StateHasChanged();
    }
}
