@page "/integration/connectors"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Connectors</PageTitle>

<PageHeader Title="Connectors"
            Subtitle="Integration definitions and deployed instances · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Integration</li>
                <li class="breadcrumb-item active">Connectors</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Title="Definitions">
    <ApiStateDisplay Loading="_loadingDefs" Error="_errDefs">
        @if (_defs.Count == 0)
        {
            <EmptyState Message="No connector definitions returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Category</th><th>Direction</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _defs)
                    {
                        <tr>
                            <td class="font-monospace small">@r.Code</td>
                            <td>@r.Name</td>
                            <td class="small">@UiLabels.HumanizeToken(r.Category)</td>
                            <td><StatusBadge Text="@UiLabels.ConnectorDirection(r.Direction)" Tone="@UiLabels.ConnectorDirectionTone(r.Direction)" /></td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

<div class="mt-4">
<DataPanel Title="Instances">
    <ApiStateDisplay Loading="_loadingInst" Error="_errInst">
        @if (_inst.Count == 0)
        {
            <EmptyState Message="No connector instances returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Connector definition</th><th>Site ID</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _inst)
                    {
                        <tr>
                            <td class="font-monospace small">@r.Code</td>
                            <td>@r.Name</td>
                            <td class="small font-monospace">@r.ConnectorDefinitionId</td>
                            <td class="small font-monospace">@r.SiteId</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>
</div>

@code {
    private bool _loadingDefs = true;
    private bool _loadingInst = true;
    private string? _errDefs;
    private string? _errInst;
    private IReadOnlyList<ConnectorDefinitionRowDto> _defs = [];
    private IReadOnlyList<ConnectorInstanceRowDto> _inst = [];

    protected override async Task OnInitializedAsync()
    {
        var d = await Api.GetConnectorDefinitionsAsync().ConfigureAwait(false);
        var i = await Api.GetConnectorInstancesAsync().ConfigureAwait(false);
        _loadingDefs = false;
        _loadingInst = false;
        if (d.Error is not null)
            _errDefs = d.Error;
        else
        {
            _errDefs = null;
            _defs = d.Data ?? [];
        }

        if (i.Error is not null)
            _errInst = i.Error;
        else
        {
            _errInst = null;
            _inst = i.Data ?? [];
        }
    }
}
