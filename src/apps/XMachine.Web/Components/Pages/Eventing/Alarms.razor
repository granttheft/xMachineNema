@page "/eventing/alarms"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Alarms</PageTitle>

<PageHeader Title="Alarm events"
            Subtitle="Equipment and line alarms · chronological feed from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Eventing</li>
                <li class="breadcrumb-item active">Alarms</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No alarm events returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Code</th><th>Severity</th><th>Category</th><th>Start (UTC)</th><th>Alarm state</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="font-monospace small">@r.AlarmCode</td>
                            <td><StatusBadge Text="@UiLabels.AlarmSeverity(r.Severity)" Tone="@UiLabels.AlarmSeverityTone(r.Severity)" /></td>
                            <td class="small">@UiLabels.HumanizeToken(r.Category)</td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.StartTime)</td>
                            <td><StatusBadge Text="@UiLabels.AlarmLifecycle(r.AlarmStatus)" Tone="@UiLabels.AlarmLifecycleTone(r.AlarmStatus)" /></td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<AlarmRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetAlarmsAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _rows = res.Data ?? [];
        }

        StateHasChanged();
    }
}
