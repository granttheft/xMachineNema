@page "/eventing/alarms"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Alarms</PageTitle>
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active">Eventing</li>
        <li class="breadcrumb-item active">Alarms</li>
    </ol>
</nav>
<h1 class="h3 mb-3">Alarm events</h1>
<div class="mb-3"><input class="form-control form-control-sm" style="max-width:20rem" placeholder="Filter (placeholder)" disabled /></div>
<ApiStateDisplay Loading="_loading" Error="_error">
    <div class="table-responsive border rounded bg-white">
        <table class="table table-sm table-striped mb-0">
            <thead class="table-light"><tr><th>Code</th><th>Severity</th><th>Category</th><th>Start</th><th>Status</th></tr></thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td class="font-monospace small">@r.AlarmCode</td>
                    <td>@r.Severity</td>
                    <td>@r.Category</td>
                    <td class="small">@r.StartTime.LocalDateTime.ToString("g")</td>
                    <td>@r.AlarmStatus</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</ApiStateDisplay>
@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<AlarmRowDto> _rows = [];
    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetAlarmsAsync().ConfigureAwait(false);
        _loading = false;
        _error = res.Error;
        _rows = res.Data ?? [];
    }
}
