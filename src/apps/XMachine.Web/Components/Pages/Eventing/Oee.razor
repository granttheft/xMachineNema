@page "/eventing/oee"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>OEE</PageTitle>

<PageHeader Title="OEE snapshots"
            Subtitle="Availability, performance, quality, and composite OEE · stored slices from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Eventing</li>
                <li class="breadcrumb-item active">OEE</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No OEE snapshots returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Period</th><th>Period start (UTC)</th><th>Availability</th><th>Performance</th><th>Quality</th><th>OEE</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td><StatusBadge Text="@UiLabels.OeePeriodType(r.PeriodType)" Tone="@StatusBadgeTone.Neutral" /></td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.PeriodStart)</td>
                            <td>@r.Availability</td>
                            <td>@r.Performance</td>
                            <td>@r.Quality</td>
                            <td class="fw-semibold">@r.OeeValue</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<OeeRowDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetOeeSnapshotsAsync().ConfigureAwait(false);
        _loading = false;
        _error = res.Error;
        _rows = res.Data ?? [];
    }
}
