@page "/eventing/kpis"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>KPIs</PageTitle>

<PageHeader Title="KPI definitions &amp; results"
            Subtitle="Registered KPIs and latest calculated values · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Eventing</li>
                <li class="breadcrumb-item active">KPIs</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<ApiStateDisplay Loading="_loading" Error="@_error">
    @if (_error is null && !_loading)
    {
        <DataPanel Title="Definitions">
            @if (_defs.Count == 0)
            {
                <EmptyState Message="No KPI definitions returned." />
            }
            else
            {
                <div class="table-responsive xm-table-wrap">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Scope</th><th>Data source</th><th>Record</th></tr></thead>
                        <tbody>
                        @foreach (var d in _defs)
                        {
                            <tr>
                                <td class="font-monospace small">@d.Code</td>
                                <td>@d.Name</td>
                                <td class="small">@UiLabels.HumanizeToken(d.ScopeType)</td>
                                <td class="small">@UiLabels.HumanizeToken(d.DataSourceType)</td>
                                <td><EntityStatusBadge Status="@d.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </DataPanel>

        <div class="mt-4">
        <DataPanel Title="Results">
            @if (_results.Count == 0)
            {
                <EmptyState Message="No KPI results returned." />
            }
            else
            {
                <div class="table-responsive xm-table-wrap">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light"><tr><th>KPI definition</th><th>Scope</th><th>Scope ID</th><th>Period start (UTC)</th><th>Value</th><th>Record</th></tr></thead>
                        <tbody>
                        @foreach (var r in _results)
                        {
                            <tr>
                                <td class="small font-monospace">@r.KpiDefinitionId</td>
                                <td class="small">@UiLabels.HumanizeToken(r.ScopeType)</td>
                                <td class="small font-monospace">@r.ScopeId</td>
                                <td class="small text-nowrap">@UiFormats.UtcMinute(r.PeriodStart)</td>
                                <td class="fw-semibold">@r.Value</td>
                                <td><EntityStatusBadge Status="@r.Status" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </DataPanel>
        </div>
    }
</ApiStateDisplay>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<KpiDefinitionRowDto> _defs = [];
    private IReadOnlyList<KpiResultRowDto> _results = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetKpisAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _defs = res.Data?.Definitions ?? [];
            _results = res.Data?.Results ?? [];
        }

        StateHasChanged();
    }
}
