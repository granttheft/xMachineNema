@page "/eventing/kpis"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>KPIs</PageTitle>

<PageHeader Title="KPI definitions &amp; results"
            Subtitle="Registered KPIs and latest calculated values · read-only from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Eventing</li>
                <li class="breadcrumb-item active">KPIs</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<ApiStateDisplay Loading="_loading" Error="@_error">
    @if (_error is null && !_loading)
    {
        <DataPanel Title="Definitions">
            @if (_defs.Count == 0)
            {
                <EmptyState Message="No KPI definitions returned." />
            }
            else
            {
                <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50">
                            <tr>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Code</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Scope</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Data source</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                            @foreach (var d in _defs)
                            {
                                <tr class="transition-colors hover:bg-slate-50">
                                    <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-700">@d.Code</td>
                                    <td class="px-4 py-3 text-sm text-slate-700">@d.Name</td>
                                    <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(d.ScopeType)</td>
                                    <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(d.DataSourceType)</td>
                                    <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@d.Status" /></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </DataPanel>

        <div class="mt-4">
        <DataPanel Title="Results">
            @if (_results.Count == 0)
            {
                <EmptyState Message="No KPI results returned." />
            }
            else
            {
                <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50">
                            <tr>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">KPI definition</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Scope</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Scope ID</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Period start (UTC)</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Value</th>
                                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Record</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                            @foreach (var r in _results)
                            {
                                <tr class="transition-colors hover:bg-slate-50">
                                    <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.KpiDefinitionId</td>
                                    <td class="px-4 py-3 text-sm text-slate-600">@UiLabels.HumanizeToken(r.ScopeType)</td>
                                    <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-slate-600">@r.ScopeId</td>
                                    <td class="whitespace-nowrap px-4 py-3 text-sm text-slate-600">@UiFormats.UtcMinute(r.PeriodStart)</td>
                                    <td class="whitespace-nowrap px-4 py-3 text-sm font-semibold tabular-nums text-slate-900">@r.Value</td>
                                    <td class="px-4 py-3 text-sm text-slate-700"><EntityStatusBadge Status="@r.Status" /></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </DataPanel>
        </div>
    }
</ApiStateDisplay>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<KpiDefinitionRowDto> _defs = [];
    private IReadOnlyList<KpiResultRowDto> _results = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetKpisAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _defs = res.Data?.Definitions ?? [];
            _results = res.Data?.Results ?? [];
        }

        StateHasChanged();
    }
}
