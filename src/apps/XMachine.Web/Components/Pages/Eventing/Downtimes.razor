@page "/eventing/downtimes"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Downtimes</PageTitle>

<PageHeader Title="Downtime records"
            Subtitle="Stops and slowdowns · read-only operational history from XMachine.Api.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Eventing</li>
                <li class="breadcrumb-item active">Downtimes</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<div class="mb-3">
    <input class="form-control form-control-sm xm-toolbar-filter" style="max-width:20rem" placeholder="Filter (placeholder)" disabled />
</div>

<DataPanel>
    <ApiStateDisplay Loading="_loading" Error="_error">
        @if (_rows.Count == 0)
        {
            <EmptyState Message="No downtime records returned." />
        }
        else
        {
            <div class="table-responsive xm-table-wrap">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light"><tr><th>Reason</th><th>Planned stop</th><th>Start (UTC)</th><th>Duration (ms)</th><th>Machine</th><th>Production order</th><th>Record</th></tr></thead>
                    <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td class="font-monospace small">@r.DowntimeReasonCode</td>
                            <td>
                                @if (r.PlannedFlag)
                                {
                                    <StatusBadge Text="Yes" Tone="@StatusBadgeTone.Warning" />
                                }
                                else
                                {
                                    <StatusBadge Text="No" Tone="@StatusBadgeTone.Success" />
                                }
                            </td>
                            <td class="small text-nowrap">@UiFormats.UtcMinute(r.StartTime)</td>
                            <td class="small">@r.DurationMs</td>
                            <td class="small font-monospace">@r.MachineId</td>
                            <td class="small font-monospace">@r.ProductionOrderId</td>
                            <td><EntityStatusBadge Status="@r.Status" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </ApiStateDisplay>
</DataPanel>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<DowntimeRowDto> _rows = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var res = await Api.GetDowntimesAsync();
        _loading = false;
        if (res.Error is not null)
            _error = res.Error;
        else
        {
            _error = null;
            _rows = res.Data ?? [];
        }

        StateHasChanged();
    }
}
