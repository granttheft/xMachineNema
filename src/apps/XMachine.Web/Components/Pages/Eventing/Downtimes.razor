@page "/eventing/downtimes"
@rendermode InteractiveServer
@inject XMachineApiClient Api

<PageTitle>Downtimes</PageTitle>
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active">Eventing</li>
        <li class="breadcrumb-item active">Downtimes</li>
    </ol>
</nav>
<h1 class="h3 mb-3">Downtime records</h1>
<div class="mb-3"><input class="form-control form-control-sm" style="max-width:20rem" placeholder="Filter (placeholder)" disabled /></div>
<ApiStateDisplay Loading="_loading" Error="_error">
    <div class="table-responsive border rounded bg-white">
        <table class="table table-sm table-striped mb-0">
            <thead class="table-light"><tr><th>Reason</th><th>Planned</th><th>Start</th><th>Duration ms</th><th>Machine</th><th>Order</th></tr></thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td class="font-monospace small">@r.DowntimeReasonCode</td>
                    <td>@(r.PlannedFlag ? "Yes" : "No")</td>
                    <td class="small">@r.StartTime.LocalDateTime.ToString("g")</td>
                    <td>@r.DurationMs</td>
                    <td class="small">@r.MachineId</td>
                    <td class="small">@r.ProductionOrderId</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</ApiStateDisplay>
@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<DowntimeRowDto> _rows = [];
    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetDowntimesAsync().ConfigureAwait(false);
        _loading = false;
        _error = res.Error;
        _rows = res.Data ?? [];
    }
}
