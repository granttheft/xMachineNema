@page "/Error"
@layout MainLayout
@using System.Diagnostics
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment HostEnv

<PageTitle>Error</PageTitle>

<PageHeader Title="Something went wrong"
            Subtitle="The application could not finish this request. Your work on other pages may still be intact.">
    <TopSlot>
        <nav aria-label="breadcrumb" class="xm-breadcrumb-nav">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item active">Error</li>
            </ol>
        </nav>
    </TopSlot>
</PageHeader>

<DataPanel Padded="true">
    <p class="mb-3">
        <a href="/dashboard" class="xm-inline-link">Return to the dashboard</a>
        ·
        <a href="." class="xm-inline-link">Reload this page</a>
    </p>
    @if (HostEnv.IsDevelopment() && ShowRequestId)
    {
        <p class="small text-body-secondary mb-1">Development diagnostic</p>
        <p class="font-monospace small mb-0"><strong>Request ID:</strong> @RequestId</p>
    }
    else
    {
        <p class="small text-body-secondary mb-0">
            Technical details are hidden in production. If you are an administrator, check server logs for the same time window.
        </p>
    }
</DataPanel>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
