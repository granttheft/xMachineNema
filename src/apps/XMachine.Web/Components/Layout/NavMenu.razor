@using Microsoft.AspNetCore.Components.Routing

<nav class="shrink-0 flex flex-col h-screen bg-white border-r border-black/10 transition-[width] duration-300 @(_open ? "w-[280px]" : "w-16")"
     style="min-height: 100vh;">

    <!-- Header -->
    <div class="flex items-center h-16 px-4 border-b border-black/10 shrink-0 @(_open ? "justify-between" : "justify-center")">
        @if (_open)
        {
            <div class="min-w-0 pr-2">
                <div class="text-[18px] font-semibold text-[#030213] leading-tight">xMachine</div>
                <div class="text-xs text-[#717182]">Operations console</div>
            </div>
        }
        <button type="button"
                @onclick="Toggle"
                class="p-2 rounded-lg hover:bg-slate-100 text-slate-600 shrink-0 @(_open ? "" : "")"
                aria-expanded="@_open"
                aria-label="@(_open ? "Collapse navigation" : "Expand navigation")">
            @if (_open)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            }
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto py-3 px-2 space-y-0.5 min-h-0">

        @SectionHeader("OVERVIEW")
        @NavItem("/dashboard", GridSvg, "Dashboard", NavLinkMatch.All)

        @SectionHeader("MES")
        @NavItem("/mes/orders", ClipboardSvg, "Production orders")
        @NavItem("/mes/recipes", BookSvg, "Recipes")
        @NavItem("/mes/lots", LayersSvg, "Lots")
        @NavItem("/mes/shifts", ClockSvg, "Shifts")

        @SectionHeader("QUALITY")
        @NavItem("/quality/checks", CheckSvg, "Checks")
        @NavItem("/quality/nonconformances", AlertSvg, "Nonconformances")

        @SectionHeader("EVENTING")
        @NavItem("/eventing/alarms", BellSvg, "Alarms")
        @NavItem("/eventing/downtimes", PauseSvg, "Downtimes")
        @NavItem("/eventing/oee", ActivitySvg, "OEE snapshots")
        @NavItem("/eventing/kpis", TrendingSvg, "KPIs")

        @SectionHeader("MONITORING")
        @NavItem("/monitoring/live", MonitorSvg, "Live Monitoring")
        @NavItem("/monitoring/machines", LayoutGridNavSvg, "Machine Overview")

        @SectionHeader("PRODUCTION")
        @NavItem("/production", ProductionOverviewNavSvg, "Module Overview", NavLinkMatch.All)
        @NavItem("/production/control", ProductionControlNavSvg, "Control", NavLinkMatch.All)
        @NavItem("/production/kiosk", ProductionKioskNavSvg, "Operator Kiosk", NavLinkMatch.All)
        @NavItem("/production/supervisor", ProductionSupervisorNavSvg, "Supervisor", NavLinkMatch.All)
        @NavItem("/production/jobs", ProductionJobsNavSvg, "Job Tracker", NavLinkMatch.All)

        @SectionHeader("ENGINEERING")
        @NavItem("/engineering", WrenchNavSvg, "Module", NavLinkMatch.All)
        @NavItem("/engineering/dashboard", WrenchNavSvg, "Engineering Dashboard")
        @NavItem("/engineering/calendar", CalendarNavSvg, "Calendar")
        @NavItem("/engineering/mold-changes", CogNavSvg, "Mold Changes")

        @SectionHeader("WORKFLOW")
        @NavItem("/workflow/definitions", GitSvg, "Definitions")
        @NavItem("/workflow/instances", PlaySvg, "Instances")

        @SectionHeader("INTEGRATION")
        @NavItem("/integration/connectors", PlugSvg, "Connectors")
        @NavItem("/integration/mappings", ArrowSvg, "Mappings")
        @NavItem("/integration/health", HeartPulseSvg, "Health")

        <AuthorizeView Policy="@AuthPolicies.AdminArea">
            <Authorized>
                @SectionHeader("ADMIN")
                @NavItem("/admin/tenants", BuildingSvg, "Tenants")
                @NavItem("/admin/licenses", KeySvg, "Licenses")
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private bool _open = true;

    private void Toggle()
    {
        _open = !_open;
    }

    private RenderFragment SectionHeader(string title) => __builder =>
    {
        if (_open)
        {
            <div class="px-3 pt-3 pb-1">
                <span class="text-[11px] font-semibold uppercase tracking-wider text-[#717182]">@title</span>
            </div>
        }
    };

    private RenderFragment NavItem(string href, string iconSvg, string label, NavLinkMatch match = NavLinkMatch.Prefix) => __builder =>
    {
        var row = _open
            ? "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium border-l-2 border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900 no-underline w-full text-left"
            : "flex items-center justify-center px-2 py-2 rounded-md text-sm font-medium border-l-2 border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900 no-underline w-full";

        <NavLink href="@href"
                 Match="@match"
                 class="@row"
                 ActiveClass="bg-blue-50 text-blue-700 border-blue-500">
            <span class="shrink-0 w-4 h-4 inline-flex items-center justify-center [&>svg]:block">@((MarkupString)iconSvg)</span>
            @if (_open)
            {
                <span class="truncate">@label</span>
            }
        </NavLink>
    };

