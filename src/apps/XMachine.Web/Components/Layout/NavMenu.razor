@using Microsoft.AspNetCore.Components.Routing
@using XMachine.Web.Services
@inject ITranslationService T
@inject NavigationManager Navigation

<nav class="shrink-0 flex flex-col h-screen bg-white border-r border-black/10 transition-[width] duration-300 @(_open ? "w-[280px]" : "w-16")"
     style="min-height: 100vh;">

    <!-- Header -->
    <div class="flex items-center h-16 px-4 border-b border-black/10 shrink-0 @(_open ? "justify-between" : "justify-center")">
        @if (_open)
        {
            <div class="min-w-0 pr-2">
                <div class="text-[18px] font-semibold text-[#030213] leading-tight">xMachine</div>
                <div class="text-xs text-[#717182]">Operations console</div>
            </div>
        }
        <button type="button"
                @onclick="Toggle"
                class="p-2 rounded-lg hover:bg-slate-100 text-slate-600 shrink-0 @(_open ? "" : "")"
                aria-expanded="@_open"
                aria-label="@(_open ? "Collapse navigation" : "Expand navigation")">
            @if (_open)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            }
        </button>
    </div>

    <div class="flex-1 flex flex-col min-h-0">
        <!-- Navigation (scrollable) -->
        <div class="flex-1 overflow-y-auto py-3 px-2 space-y-0.5 min-h-0">

            @SectionHeader(T["nav.section.overview"].ToUpper())
            @NavItem("/dashboard", GridSvg, T["nav.dashboard"], NavLinkMatch.All)

            @SectionHeader(T["nav.section.mes"].ToUpper())
            @NavItem("/mes/orders", ClipboardSvg, T["nav.production_orders"])
            @NavItem("/mes/recipes", BookSvg, T["nav.recipes"])
            @NavItem("/mes/lots", LayersSvg, T["nav.lots"])
            @NavItem("/mes/shifts", ClockSvg, T["nav.shifts"])

            @SectionHeader(T["nav.section.quality"].ToUpper())
            @NavItem("/quality/checks", CheckSvg, T["nav.checks"])
            @NavItem("/quality/nonconformances", AlertSvg, T["nav.nonconformances"])

            @SectionHeader(T["nav.section.eventing"].ToUpper())
            @NavItem("/eventing/alarms", BellSvg, T["nav.alarms"])
            @NavItem("/eventing/downtimes", PauseSvg, T["nav.downtimes"])
            @NavItem("/eventing/oee", ActivitySvg, T["nav.oee"])
            @NavItem("/eventing/kpis", TrendingSvg, T["nav.kpis"])

            @SectionHeader(T["nav.section.monitoring"].ToUpper())
            @NavItem("/monitoring/live", MonitorSvg, T["nav.live_monitoring"])
            @NavItem("/monitoring/machines", LayoutGridNavSvg, T["nav.machine_overview"])

            @SectionHeader(T["nav.section.production"].ToUpper())
            @NavItem("/production", ProductionOverviewNavSvg, T["nav.module_overview"], NavLinkMatch.All)
            @NavItem("/production/control", ProductionControlNavSvg, T["nav.control"], NavLinkMatch.All)
            @NavItem("/production/mcr", ProductionMcrNavSvg, T["nav.mcr"], NavLinkMatch.All)
            @NavItem("/production/kiosk", ProductionKioskNavSvg, T["nav.operator_kiosk"], NavLinkMatch.All)
            @NavItem("/production/supervisor", ProductionSupervisorNavSvg, T["nav.supervisor"], NavLinkMatch.All)
            @NavItem("/production/jobs", ProductionJobsNavSvg, T["nav.job_tracker"], NavLinkMatch.All)

            @SectionHeader(T["nav.section.engineering"].ToUpper())
            @NavItem("/engineering", WrenchNavSvg, T["nav.engineering_module"], NavLinkMatch.All)
            @NavItem("/engineering/dashboard", WrenchNavSvg, T["nav.eng_dashboard"])
            @NavItem("/engineering/calendar", CalendarNavSvg, T["nav.calendar"])
            @NavItem("/engineering/mold-changes", CogNavSvg, T["nav.mold_changes"])

            @SectionHeader(T["nav.section.workflow"].ToUpper())
            @NavItem("/workflow/definitions", GitSvg, T["nav.definitions"])
            @NavItem("/workflow/instances", PlaySvg, T["nav.instances"])

            @SectionHeader(T["nav.section.integration"].ToUpper())
            @NavItem("/integration/connectors", PlugSvg, T["nav.connectors"])
            @NavItem("/integration/mappings", ArrowSvg, T["nav.mappings"])
            @NavItem("/integration/health", HeartPulseSvg, T["nav.health"])

            <AuthorizeView Policy="@AuthPolicies.AdminArea">
                <Authorized>
                    @SectionHeader(T["nav.section.admin"].ToUpper())
                    @NavItem("/admin/tenants", BuildingSvg, T["nav.tenants"])
                    @NavItem("/admin/licenses", KeySvg, T["nav.licenses"])
                    @NavItem("/admin/languages", GlobeSvg, T["nav.languages"], NavLinkMatch.All)
                </Authorized>
            </AuthorizeView>
        </div>

        <!-- Language (footer) -->
        <div class="border-t border-slate-100 py-3 px-2 shrink-0">
            @if (_open)
            {
                <div class="flex flex-wrap gap-1 justify-center">
                    <a href="@LangSwitchHref("en")" data-enhance-nav="false" class="px-2 py-1 text-xs font-medium rounded-md no-underline inline-flex items-center justify-center @(LangActive("en") ? "bg-blue-100 text-blue-700" : "text-slate-500 hover:bg-slate-100")">🇬🇧 EN</a>
                    <a href="@LangSwitchHref("tr")" data-enhance-nav="false" class="px-2 py-1 text-xs font-medium rounded-md no-underline inline-flex items-center justify-center @(LangActive("tr") ? "bg-blue-100 text-blue-700" : "text-slate-500 hover:bg-slate-100")">🇹🇷 TR</a>
                    <a href="@LangSwitchHref("de")" data-enhance-nav="false" class="px-2 py-1 text-xs font-medium rounded-md no-underline inline-flex items-center justify-center @(LangActive("de") ? "bg-blue-100 text-blue-700" : "text-slate-500 hover:bg-slate-100")">🇩🇪 DE</a>
                    <a href="@LangSwitchHref("pl")" data-enhance-nav="false" class="px-2 py-1 text-xs font-medium rounded-md no-underline inline-flex items-center justify-center @(LangActive("pl") ? "bg-blue-100 text-blue-700" : "text-slate-500 hover:bg-slate-100")">🇵🇱 PL</a>
                </div>
            }
            else
            {
                <div class="flex justify-center text-slate-500" aria-hidden="true">
                    <span class="shrink-0 w-4 h-4 inline-flex items-center justify-center [&>svg]:block">@((MarkupString)GlobeSvg)</span>
                </div>
            }
        </div>
    </div>
</nav>

@code {
    private bool _open = true;

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await T.EnsureInitializedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private bool LangActive(string code) =>
        string.Equals(T.CurrentLanguage, code, StringComparison.OrdinalIgnoreCase);

    /// <summary>Builds a full navigation URL that sets UI language cookie and returns to the current page.</summary>
    private string LangSwitchHref(string code)
    {
        var pathAndQuery = new Uri(Navigation.Uri).PathAndQuery;
        if (string.IsNullOrEmpty(pathAndQuery))
            pathAndQuery = "/";
        return $"/ui-lang/{code}?returnUrl={Uri.EscapeDataString(pathAndQuery)}";
    }

    private void Toggle()
    {
        _open = !_open;
    }

    private RenderFragment SectionHeader(string title) => __builder =>
    {
        if (_open)
        {
            <div class="px-3 pt-3 pb-1">
                <span class="text-[11px] font-semibold uppercase tracking-wider text-[#717182]">@title</span>
            </div>
        }
    };

    private RenderFragment NavItem(string href, string iconSvg, string label, NavLinkMatch match = NavLinkMatch.Prefix) => __builder =>
    {
        var row = _open
            ? "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium border-l-2 border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900 no-underline w-full text-left"
            : "flex items-center justify-center px-2 py-2 rounded-md text-sm font-medium border-l-2 border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900 no-underline w-full";

        <NavLink href="@href"
                 Match="@match"
                 class="@row"
                 ActiveClass="bg-blue-50 text-blue-700 border-blue-500">
            <span class="shrink-0 w-4 h-4 inline-flex items-center justify-center [&>svg]:block">@((MarkupString)iconSvg)</span>
            @if (_open)
            {
                <span class="truncate">@label</span>
            }
        </NavLink>
    };

    private const string GridSvg = """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>""";

