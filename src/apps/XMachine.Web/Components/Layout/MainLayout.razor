@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar border-end">
        <NavMenu />
    </div>

    <main>
        <header class="top-bar border-bottom px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3 py-2">
                <span class="fw-semibold text-secondary text-uppercase small">xMachine</span>
                <span class="text-body-secondary small">Operations shell</span>
            </div>
            <div class="d-flex align-items-center gap-3 small">
                <span class="badge text-bg-secondary">Dev · no auth</span>
                <a class="link-secondary" href="/login">Sign in (placeholder)</a>
            </div>
        </header>

        <article class="content px-4 pb-5">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>
