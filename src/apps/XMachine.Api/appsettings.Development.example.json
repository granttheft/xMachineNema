{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "XMachineOperationalDb": "Host=localhost;Port=5432;Database=xmachine_nema;Username=postgres;Password=YOUR_PASSWORD_HERE"
  },
  "XMachine": {
    "Database": {
      "MigrateOnStartup": true
    },
    "Seed": {
      "Enabled": true
    },
    "DevAuth": {
      "Comment": "Sign-in is handled by XMachine.Web; this block documents the shared dev password used there.",
      "SharedPassword": "YOUR_DEV_PASSWORD_HERE"
    }
  }
}
